Source: "main.asm"
                            	   177:     include "rooms.asm"

Source: "rooms.asm"
                            	     1: ; =============================================================================
                            	     2: ; Room Loader
                            	     3: ; =============================================================================
                            	     4: ; Phase 3 bootstrap:
                            	     5: ; - load the real overworld start room ($77)
                            	     6: ; - decode the original compressed column format at runtime
                            	     7: ; - convert extracted NES palette bytes to Genesis CRAM words
                            	     8: ; - queue a 32x22 room tilemap onto Plane A
                            	     9: ; =============================================================================
                            	    10: 
                            	    11: ROOM_SQUARE_COLS         equ 16
                            	    12: ROOM_SQUARE_ROWS         equ 11
                            	    13: ROOM_TILE_COLS           equ 32
                            	    14: ROOM_TILE_ROWS           equ 22
                            	    15: ROOM_TILE_ROW_STRIDE     equ ROOM_TILE_COLS*2
                            	    16: ROOM_PLAYAREA_ATTR_COLS  equ 8
                            	    17: ROOM_PLAYAREA_ATTR_ROWS  equ 6
                            	    18: ROOM_PLAYAREA_ATTR_COUNT equ ROOM_PLAYAREA_ATTR_COLS*ROOM_PLAYAREA_ATTR_ROWS
                            	    19: ROOM_START_ROOM_OFFSET   equ $002F
                            	    20: 
                            	    21: Room_LoadStartingOverworld:
03:00000B4A 7000            	    22:     moveq   #0,D0
03:00000B4C 103A1847        	    23:     move.b  LevelInfoOW+ROOM_START_ROOM_OFFSET(pc),D0
                            	    24:     bra     Room_LoadOverworldById
                            	    25: 
                            	    26: ; D0 = overworld room id
                            	    27: Room_LoadOverworldById:
03:00000B50 33FC020000FF0040	    28:     move.w  #$0200,(BOOT_STAGE).l
03:00000B58 33C000FF003C    	    29:     move.w  D0,(CURRENT_ROOM_ID).l
03:00000B5E 614E            	    30:     bsr     Room_ConvertOverworldPalette
03:00000B60 33FC020100FF0040	    31:     move.w  #$0201,(BOOT_STAGE).l
03:00000B68 610000A6        	    32:     bsr     Room_BuildOverworldPlayAreaAttrs
03:00000B6C 33FC020200FF0040	    33:     move.w  #$0202,(BOOT_STAGE).l
03:00000B74 61000148        	    34:     bsr     Room_BuildOverworldTilemap
03:00000B78 33FC020300FF0040	    35:     move.w  #$0203,(BOOT_STAGE).l
03:00000B80 303C0004        	    36:     move.w  #PLAYFIELD_TOP_ROW,D0
03:00000B84 7200            	    37:     moveq   #0,D1
03:00000B86 6100034C        	    38:     bsr     Room_QueueOverworldTilemapAt
03:00000B8A 33FC020400FF0040	    39:     move.w  #$0204,(BOOT_STAGE).l
03:00000B92 4E75            	    40:     rts
                            	    41: 
                            	    42: ; D0 = overworld room id
                            	    43: ; Builds the room into ROOM_TILEMAP_BUFFER without committing it as CURRENT_ROOM_ID
                            	    44: Room_BuildOverworldTilemapForRoomId:
03:00000B94 3F3900FF003C    	    45:     move.w  (CURRENT_ROOM_ID).l,-(A7)
03:00000B9A 33C000FF003C    	    46:     move.w  D0,(CURRENT_ROOM_ID).l
03:00000BA0 616E            	    47:     bsr     Room_BuildOverworldPlayAreaAttrs
03:00000BA2 6100011A        	    48:     bsr     Room_BuildOverworldTilemap
03:00000BA6 33DF00FF003C    	    49:     move.w  (A7)+,(CURRENT_ROOM_ID).l
03:00000BAC 4E75            	    50:     rts
                            	    51: 
                            	    52: Room_ConvertOverworldPalette:
03:00000BAE 33FC021000FF0042	    53:     move.w  #$0210,(BOOT_DETAIL).l
                            	    54: 
                            	    55:     ; Genesis CRAM is organized as 4 palette lines of 16 colors each.
                            	    56:     ; The NES overworld BG data gives us 4 sub-palettes of 4 colors each, so
                            	    57:     ; spread them into color slots 0-3 of Genesis palette lines 0-3 and leave
                            	    58:     ; the remaining entries clear.
03:00000BB6 43F900FF0C00    	    59:     lea     (ROOM_PALETTE_BUFFER).l,A1
03:00000BBC 7000            	    60:     moveq   #0,D0
03:00000BBE 3E3C003F        	    61:     move.w  #63,D7
                            	    62: .clear_loop:
03:00000BC2 32C0            	    63:     move.w  D0,(A1)+
03:00000BC4 51CFFFFC        	    64:     dbra    D7,.clear_loop
                            	    65: 
                            	    66:     ; LevelInfoOW begins with an NES palette transfer header:
                            	    67:     ;   $3F,$00,$20,<16 BG palette bytes>...
                            	    68:     ; Skip the 3-byte header and load the 4 BG sub-palettes.
03:00000BC8 41FA179F        	    69:     lea     LevelInfoOW+3(pc),A0
03:00000BCC 43F900FF0C00    	    70:     lea     (ROOM_PALETTE_BUFFER).l,A1
03:00000BD2 45FA03E2        	    71:     lea     NesColorToGenesisCRAM(pc),A2
03:00000BD6 7C00            	    72:     moveq   #0,D6               ; palette line index
                            	    73: .palette_loop:
03:00000BD8 3A06            	    74:     move.w  D6,D5
03:00000BDA EB4D            	    75:     lsl.w   #5,D5               ; 16 colors x 2 bytes
03:00000BDC 47F15000        	    76:     lea     0(A1,D5.w),A3
03:00000BE0 7E03            	    77:     moveq   #3,D7
                            	    78: .color_loop:
03:00000BE2 7000            	    79:     moveq   #0,D0
03:00000BE4 1018            	    80:     move.b  (A0)+,D0
03:00000BE6 D040            	    81:     add.w   D0,D0
03:00000BE8 36F20000        	    82:     move.w  0(A2,D0.w),(A3)+
03:00000BEC 51CFFFF4        	    83:     dbra    D7,.color_loop
03:00000BF0 5246            	    84:     addq.w  #1,D6
03:00000BF2 0C460004        	    85:     cmpi.w  #4,D6
03:00000BF6 65E0            	    86:     bcs.s   .palette_loop
                            	    87: 
                            	    88:     ; Queue the full CRAM image so palette lines 0-3 land in their correct
                            	    89:     ; 16-color slots.
03:00000BF8 41F900FF0C00    	    90:     lea     (ROOM_PALETTE_BUFFER).l,A0
03:00000BFE 3E3C003F        	    91:     move.w  #63,D7
03:00000C02 6100FB04        	    92:     bsr     Renderer_QueueCRAMWords
03:00000C06 33FC021100FF0042	    93:     move.w  #$0211,(BOOT_DETAIL).l
03:00000C0E 4E75            	    94:     rts
                            	    95: 
                            	    96: Room_BuildOverworldPlayAreaAttrs:
03:00000C10 33FC021200FF0042	    97:     move.w  #$0212,(BOOT_DETAIL).l
03:00000C18 303900FF003C    	    98:     move.w  (CURRENT_ROOM_ID).l,D0
                            	    99: 
03:00000C1E 41FA084E        	   100:     lea     RoomAttrsOW_A(pc),A0
03:00000C22 7200            	   101:     moveq   #0,D1
03:00000C24 12300000        	   102:     move.b  0(A0,D0.w),D1
03:00000C28 02410003        	   103:     andi.w  #$0003,D1
03:00000C2C 43FA030C        	   104:     lea     RoomPaletteSelectorToNTAttr(pc),A1
03:00000C30 7400            	   105:     moveq   #0,D2
03:00000C32 14311000        	   106:     move.b  0(A1,D1.w),D2
                            	   107: 
03:00000C36 41F900FF0B80    	   108:     lea     (ROOM_PLAYAREA_ATTR_BUFFER).l,A0
03:00000C3C 3E3C002F        	   109:     move.w  #ROOM_PLAYAREA_ATTR_COUNT-1,D7
                            	   110: .fill_outer:
03:00000C40 10C2            	   111:     move.b  D2,(A0)+
03:00000C42 51CFFFFC        	   112:     dbra    D7,.fill_outer
                            	   113: 
03:00000C46 41FA08A6        	   114:     lea     RoomAttrsOW_B(pc),A0
03:00000C4A 7200            	   115:     moveq   #0,D1
03:00000C4C 12300000        	   116:     move.b  0(A0,D0.w),D1
03:00000C50 02410003        	   117:     andi.w  #$0003,D1
03:00000C54 43FA02E4        	   118:     lea     RoomPaletteSelectorToNTAttr(pc),A1
03:00000C58 7400            	   119:     moveq   #0,D2
03:00000C5A 14311000        	   120:     move.b  0(A1,D1.w),D2
                            	   121: 
03:00000C5E 41F900FF0B80    	   122:     lea     (ROOM_PLAYAREA_ATTR_BUFFER).l,A0
03:00000C64 3E3C0009        	   123:     move.w  #$0009,D7
                            	   124: .fill_inner:
03:00000C68 3007            	   125:     move.w  D7,D0
03:00000C6A 02400007        	   126:     andi.w  #$0007,D0
03:00000C6E 6728            	   127:     beq.s   .next_inner
03:00000C70 0C400007        	   128:     cmpi.w  #$0007,D0
03:00000C74 6722            	   129:     beq.s   .next_inner
03:00000C76 0C470021        	   130:     cmpi.w  #$0021,D7
03:00000C7A 6406            	   131:     bcc.s   .combine_inner_outer
03:00000C7C 11827000        	   132:     move.b  D2,0(A0,D7.w)
03:00000C80 6016            	   133:     bra.s   .next_inner
                            	   134: .combine_inner_outer:
03:00000C82 7000            	   135:     moveq   #0,D0
03:00000C84 10307000        	   136:     move.b  0(A0,D7.w),D0
03:00000C88 024000F0        	   137:     andi.w  #$00F0,D0
03:00000C8C 3202            	   138:     move.w  D2,D1
03:00000C8E 0241000F        	   139:     andi.w  #$000F,D1
03:00000C92 8041            	   140:     or.w    D1,D0
03:00000C94 11807000        	   141:     move.b  D0,0(A0,D7.w)
                            	   142: .next_inner:
03:00000C98 5247            	   143:     addq.w  #1,D7
03:00000C9A 0C470027        	   144:     cmpi.w  #$0027,D7
03:00000C9E 65C8            	   145:     bcs.s   .fill_inner
03:00000CA0 33FC021300FF0042	   146:     move.w  #$0213,(BOOT_DETAIL).l
03:00000CA8 4E75            	   147:     rts
