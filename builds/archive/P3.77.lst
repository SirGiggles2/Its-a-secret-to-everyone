Source: "dungeon.asm"
                            	     1: ; =============================================================================
                            	     2: ; Dungeon Navigation System
                            	     3: ; =============================================================================
                            	     4: ; Phase 3 dungeon implementation:
                            	     5: ; - 8x8 room grid navigation per level
                            	     6: ; - Door state handling (locked, bombed, key, shutter)
                            	     7: ; - Secret detection (bomb walls, push rocks, burn bushes)
                            	     8: ; - Warp/staircase system
                            	     9: ; =============================================================================
                            	    10: 
                            	    11: DUNGEON_ROOMS_PER_LEVEL equ 64
                            	    12: DUNGEON_GRID_COLS        equ 8
                            	    13: DUNGEON_GRID_ROWS        equ 8
                            	    14: 
                            	    15: ; Dungeon door types
                            	    16: DOOR_TYPE_NORMAL        equ $00
                            	    17: DOOR_TYPE_LOCKED        equ $01
                            	    18: DOOR_TYPE_BOMBED        equ $02
                            	    19: DOOR_TYPE_KEY           equ $03
                            	    20: DOOR_TYPE_SHUTTER       equ $04
                            	    21: 
                            	    22: ; Dungeon room flags
                            	    23: ROOM_FLAG_SECRET_WALL   equ $01
                            	    24: ROOM_FLAG_SECRET_ROCK   equ $02
                            	    25: ROOM_FLAG_SECRET_BUSH   equ $04
                            	    26: ROOM_FLAG_STAIR_DOWN    equ $08
                            	    27: ROOM_FLAG_STAIR_UP      equ $10
                            	    28: ROOM_FLAG_WARP          equ $20
                            	    29: 
                            	    30: ; D0 = new room id
                            	    31: ; D1 = direction (0=up,1=right,2=down,3=left)
                            	    32: Room_TransitionToDungeonRoom:
03:00003CCE 33C000FF0052    	    33:     move.w  D0,(ROOM_TRANSITION_TARGET_ROOM).l
03:00003CD4 33C100FF004E    	    34:     move.w  D1,(ROOM_TRANSITION_DIRECTION).l
03:00003CDA 33FC000100FF004C	    35:     move.w  #1,(ROOM_TRANSITION_ACTIVE).l
03:00003CE2 33FC000000FF0050	    36:     move.w  #0,(ROOM_TRANSITION_OFFSET).l
03:00003CEA 4E75            	    37:     rts
                            	    38: 
                            	    39: ; Check if dungeon room transition is valid
                            	    40: ; D0 = current room id
                            	    41: ; D1 = direction (0=up,1=right,2=down,3=left)
                            	    42: ; Returns: D0 = new room id (or -1 if invalid)
                            	    43: Room_GetDungeonAdjacentRoom:
03:00003CEC 3F00            	    44:     move.w  D0,-(A7)
03:00003CEE 3F01            	    45:     move.w  D1,-(A7)
                            	    46:     
                            	    47:     ; Calculate grid position
03:00003CF0 3400            	    48:     move.w  D0,D2
03:00003CF2 0242003F        	    49:     andi.w  #$003F,D2        ; mask to room within level
03:00003CF6 3602            	    50:     move.w  D2,D3
03:00003CF8 3803            	    51:     move.w  D3,D4
03:00003CFA E64B            	    52:     lsr.w   #3,D3           ; row index (0-7)
03:00003CFC 02440007        	    53:     andi.w  #$0007,D4        ; col index (0-7)
                            	    54:     
                            	    55:     ; Check bounds and calculate adjacent
03:00003D00 4A41            	    56:     cmpi.w  #0,D1
03:00003D02 6714            	    57:     beq.s   .check_up
03:00003D04 0C410001        	    58:     cmpi.w  #1,D1
03:00003D08 6716            	    59:     beq.s   .check_right
03:00003D0A 0C410002        	    60:     cmpi.w  #2,D1
03:00003D0E 671A            	    61:     beq.s   .check_down
03:00003D10 0C410003        	    62:     cmpi.w  #3,D1
03:00003D14 671E            	    63:     beq.s   .check_left
03:00003D16 6038            	    64:     bra.s   .invalid
                            	    65:     
                            	    66: .check_up:
03:00003D18 4A43            	    67:     tst.w   D3
03:00003D1A 6734            	    68:     beq.s   .invalid        ; top row
03:00003D1C 5343            	    69:     subq.w  #1,D3
03:00003D1E 601C            	    70:     bra.s   .calculate
                            	    71:     
                            	    72: .check_right:
03:00003D20 0C440007        	    73:     cmpi.w  #7,D4
03:00003D24 672A            	    74:     beq.s   .invalid        ; rightmost column
03:00003D26 5244            	    75:     addq.w  #1,D4
03:00003D28 6012            	    76:     bra.s   .calculate
                            	    77:     
                            	    78: .check_down:
03:00003D2A 0C430007        	    79:     cmpi.w  #7,D3
03:00003D2E 6720            	    80:     beq.s   .invalid        ; bottom row
03:00003D30 5243            	    81:     addq.w  #1,D3
03:00003D32 6008            	    82:     bra.s   .calculate
                            	    83:     
                            	    84: .check_left:
03:00003D34 4A44            	    85:     tst.w   D4
03:00003D36 6718            	    86:     beq.s   .invalid        ; leftmost column
03:00003D38 5344            	    87:     subq.w  #1,D4
03:00003D3A 4DD6            	    88:     bra.s   .calculate
                            	    89:     
                            	    90: .calculate:
                            	    91:     ; Convert back to room id
03:00003D3C 3003            	    92:     move.w  D3,D0
03:00003D3E E748            	    93:     lsl.w   #3,D0
03:00003D40 D044            	    94:     add.w   D4,D0
                            	    95:     ; Restore level offset
03:00003D42 341F            	    96:     move.w  (A7)+,D2
03:00003D44 0242FFC0        	    97:     andi.w  #$FFC0,D2        ; keep level bits
03:00003D48 8440            	    98:     or.w    D0,D2
03:00003D4A 3002            	    99:     move.w  D2,D0
03:00003D4C 584F            	   100:     addq.w  #4,A7           ; clean up stack
03:00003D4E 4E75            	   101:     rts
                            	   102:     
                            	   103: .invalid:
03:00003D50 303CFFFF        	   104:     move.w  #-1,D0
03:00003D54 584F            	   105:     addq.w  #4,A7           ; clean up stack
03:00003D56 4E75            	   106:     rts
                            	   107: 
                            	   108: ; Check if door can be passed
                            	   109: ; D0 = current room id
                            	   110: ; D1 = direction (0=up,1=right,2=down,3=left)
                            	   111: ; Returns: D0 = door type (or -1 if no door)
                            	   112: Room_GetDungeonDoorType:
03:00003D58 3400            	   113:     move.w  D0,D2
03:00003D5A 0242003F        	   114:     andi.w  #$003F,D2        ; room within level
03:00003D5E 3601            	   115:     move.w  D1,D3
                            	   116:     ; Load room attributes to check door type
03:00003D60 303900FF0062    	   117:     move.w  (CURRENT_LEVEL_ID).l,D0
03:00003D66 0C400006        	   118:     cmpi.w  #6,D0
03:00003D6A 6506            	   119:     bcs.s   .q1_attrs
                            	   120: .q2_attrs:
03:00003D6C 41FAE3E8        	   121:     lea     RoomAttrsUW2Q1_B(pc),A0
03:00003D70 6004            	   122:     bra.s   .check_door
                            	   123: .q1_attrs:
03:00003D72 41FADDE2        	   124:     lea     RoomAttrsUW1Q1_B(pc),A0
                            	   125: .check_door:
03:00003D76 7000            	   126:     moveq   #0,D0
03:00003D78 10302000        	   127:     move.b  0(A0,D2.w),D0
                            	   128:     ; Extract door type based on direction
03:00003D7C E668            	   129:     lsr.w   D3,D0
03:00003D7E 02400003        	   130:     andi.w  #$0003,D0
03:00003D82 4E75            	   131:     rts
                            	   132: 
                            	   133: ; Initialize dungeon for a level
                            	   134: ; D0 = level id (0-8)
                            	   135: Room_InitDungeonLevel:
03:00003D84 33C000FF0062    	   136:     move.w  D0,(CURRENT_LEVEL_ID).l
03:00003D8A 33FC000000FF003C	   137:     move.w  #0,(CURRENT_ROOM_ID).l
                            	   138:     ; Load starting room for this level
03:00003D92 7200            	   139:     moveq   #0,D1
03:00003D94 6100CE46        	   140:     bsr     Room_LoadUnderworldById
03:00003D98 4E75            	   141:     rts
                            	   142: 
                            	   143: ; Handle dungeon room interactions
                            	   144: Room_HandleDungeonInteractions:
                            	   145:     ; Check for secrets
03:00003D9A 6104            	   146:     bsr     Room_CheckDungeonSecrets
                            	   147:     ; Check for stairs/warps
03:00003D9C 6130            	   148:     bsr     Room_CheckDungeonWarps
03:00003D9E 4E75            	   149:     rts
                            	   150: 
                            	   151: ; Check and trigger dungeon secrets
                            	   152: Room_CheckDungeonSecrets:
03:00003DA0 303900FF003C    	   153:     move.w  (CURRENT_ROOM_ID).l,D0
03:00003DA6 0240003F        	   154:     andi.w  #$003F,D0
03:00003DAA 323900FF0062    	   155:     move.w  (CURRENT_LEVEL_ID).l,D1
03:00003DB0 0C410006        	   156:     cmpi.w  #6,D1
03:00003DB4 6506            	   157:     bcs.s   .q1_secrets
                            	   158: .q2_secrets:
03:00003DB6 41FAE41E        	   159:     lea     RoomAttrsUW2Q1_C(pc),A0
03:00003DBA 6004            	   160:     bra.s   .check_flags
                            	   161: .q1_secrets:
03:00003DBC 41FADE18        	   162:     lea     RoomAttrsUW1Q1_C(pc),A0
                            	   163: .check_flags:
03:00003DC0 7200            	   164:     moveq   #0,D1
03:00003DC2 12300000        	   165:     move.b  0(A0,D0.w),D1
                            	   166:     ; Check for secret walls (bomb walls)
03:00003DC6 4A01            	   167:     tst.b   D1
03:00003DC8 6B02            	   168:     bmi.s   .has_secret_wall
                            	   169:     ; Check for other secrets based on flags
03:00003DCA 4E75            	   170:     rts
                            	   171:     
