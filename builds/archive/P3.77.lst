                            	   176: ; Check for dungeon stairs and warps
                            	   177: Room_CheckDungeonWarps:
03:00003DCE 303900FF003C    	   178:     move.w  (CURRENT_ROOM_ID).l,D0
03:00003DD4 0240003F        	   179:     andi.w  #$003F,D0
03:00003DD8 323900FF0062    	   180:     move.w  (CURRENT_LEVEL_ID).l,D1
03:00003DDE 0C410006        	   181:     cmpi.w  #6,D1
03:00003DE2 6506            	   182:     bcs.s   .q1_warps
