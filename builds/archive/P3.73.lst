                            	   110: Room_GetOverworldCaveSpawnY:
03:00000C5C 618E            	   111:     bsr     Room_GetOverworldCaveIndex
03:00000C5E 0C400002        	   112:     cmpi.w  #$0002,D0
03:00000C62 6302            	   113:     bls.s   .index_ok
03:00000C64 7000            	   114:     moveq   #0,D0
                            	   115: .index_ok:
03:00000C66 D040            	   116:     add.w   D0,D0
03:00000C68 41FA03B6        	   117:     lea     RoomOverworldCaveSpawnYTable(pc),A0
03:00000C6C 7200            	   118:     moveq   #0,D1
03:00000C6E 32300000        	   119:     move.w  0(A0,D0.w),D1
03:00000C72 3001            	   120:     move.w  D1,D0
03:00000C74 4E75            	   121:     rts
