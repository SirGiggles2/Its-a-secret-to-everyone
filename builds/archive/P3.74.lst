                            	   153: .clear_loop:
03:00000CDC 32C0            	   154:     move.w  D0,(A1)+
03:00000CDE 51CFFFFC        	   155:     dbra    D7,.clear_loop
                            	   156: 
                            	   157:     ; LevelInfoOW begins with an NES palette transfer header:
                            	   158:     ;   $3F,$00,$20,<16 BG palette bytes>...
                            	   159:     ; Skip the 3-byte header and load the 4 BG sub-palettes.
03:00000CE2 41FA24C5        	   160:     lea     LevelInfoOW+3(pc),A0
03:00000CE6 43F900FF0C00    	   161:     lea     (ROOM_PALETTE_BUFFER).l,A1
