                            	   143: Room_ConvertOverworldPalette:
03:00000CC8 33FC021000FF0042	   144:     move.w  #$0210,(BOOT_DETAIL).l
                            	   145: 
                            	   146:     ; Genesis CRAM is organized as 4 palette lines of 16 colors each.
                            	   147:     ; The NES overworld BG data gives us 4 sub-palettes of 4 colors each, so
                            	   148:     ; spread them into color slots 0-3 of Genesis palette lines 0-3 and leave
                            	   149:     ; the remaining entries clear.
