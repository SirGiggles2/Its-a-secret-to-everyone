03:00000BF6 7200            	    68:     moveq   #0,D1
03:00000BF8 12300000        	    69:     move.b  0(A0,D0.w),D1
03:00000BFC E849            	    70:     lsr.w   #4,D1
03:00000BFE 0241000F        	    71:     andi.w  #$000F,D1
03:00000C02 3001            	    72:     move.w  D1,D0
03:00000C04 4E75            	    73:     rts
