03:00000BA4 61000098        	    45:     bsr     Room_ConvertOverworldPalette
03:00000BA8 33FC024100FF0040	    46:     move.w  #$0241,(BOOT_STAGE).l
03:00000BB0 610000EE        	    47:     bsr     Room_BuildOverworldPlayAreaAttrs
03:00000BB4 33FC024200FF0040	    48:     move.w  #$0242,(BOOT_STAGE).l
03:00000BBC 610001A0        	    49:     bsr     Room_BuildOverworldCaveTilemap
03:00000BC0 33FC024300FF0040	    50:     move.w  #$0243,(BOOT_STAGE).l
03:00000BC8 303C0006        	    51:     move.w  #PLAYFIELD_TOP_ROW,D0
03:00000BCC 7200            	    52:     moveq   #0,D1
03:00000BCE 610003A4        	    53:     bsr     Room_QueueOverworldTilemapAt
03:00000BD2 33FC024400FF0040	    54:     move.w  #$0244,(BOOT_STAGE).l
03:00000BDA 4E75            	    55:     rts
