03:00000C10 7200            	    78:     moveq   #0,D1
03:00000C12 12300000        	    79:     move.b  0(A0,D0.w),D1
03:00000C16 024100F0        	    80:     andi.w  #$00F0,D1
03:00000C1A 3001            	    81:     move.w  D1,D0
03:00000C1C 4E75            	    82:     rts
