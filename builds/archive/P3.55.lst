                            	    59: Room_BuildOverworldTilemapForRoomId:
03:00000BDC 33C000FF0054    	    60:     move.w  D0,(ROOM_BUILD_ROOM_ID).l
03:00000BE2 610000BC        	    61:     bsr     Room_BuildOverworldPlayAreaAttrs
03:00000BE6 61000166        	    62:     bsr     Room_BuildOverworldTilemap
