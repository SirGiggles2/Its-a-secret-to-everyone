03:00000C20 0C400001        	    86:     cmpi.w  #$0001,D0
03:00000C24 670C            	    87:     beq.s   .cave1
03:00000C26 0C400002        	    88:     cmpi.w  #$0002,D0
03:00000C2A 670C            	    89:     beq.s   .cave2
03:00000C2C 41FA0F7E        	    90:     lea     RoomLayoutOWCave0(pc),A0
03:00000C30 4E75            	    91:     rts
                            	    92: .cave1:
03:00000C32 41FA0F88        	    93:     lea     RoomLayoutOWCave1(pc),A0
03:00000C36 4E75            	    94:     rts
                            	    95: .cave2:
03:00000C38 41FA0F92        	    96:     lea     RoomLayoutOWCave2(pc),A0
03:00000C3C 4E75            	    97:     rts
                            	    98: 
                            	    99: Room_ConvertOverworldPalette:
03:00000C3E 33FC021000FF0042	   100:     move.w  #$0210,(BOOT_DETAIL).l
                            	   101: 
                            	   102:     ; Genesis CRAM is organized as 4 palette lines of 16 colors each.
                            	   103:     ; The NES overworld BG data gives us 4 sub-palettes of 4 colors each, so
                            	   104:     ; spread them into color slots 0-3 of Genesis palette lines 0-3 and leave
                            	   105:     ; the remaining entries clear.
03:00000C46 43F900FF0C00    	   106:     lea     (ROOM_PALETTE_BUFFER).l,A1
03:00000C4C 7000            	   107:     moveq   #0,D0
03:00000C4E 3E3C003F        	   108:     move.w  #63,D7
                            	   109: .clear_loop:
03:00000C52 32C0            	   110:     move.w  D0,(A1)+
03:00000C54 51CFFFFC        	   111:     dbra    D7,.clear_loop
                            	   112: 
                            	   113:     ; LevelInfoOW begins with an NES palette transfer header:
                            	   114:     ;   $3F,$00,$20,<16 BG palette bytes>...
                            	   115:     ; Skip the 3-byte header and load the 4 BG sub-palettes.
03:00000C58 41FA17BD        	   116:     lea     LevelInfoOW+3(pc),A0
03:00000C5C 43F900FF0C00    	   117:     lea     (ROOM_PALETTE_BUFFER).l,A1
03:00000C62 45FA0400        	   118:     lea     NesColorToGenesisCRAM(pc),A2
03:00000C66 7C00            	   119:     moveq   #0,D6               ; palette line index
                            	   120: .palette_loop:
03:00000C68 3A06            	   121:     move.w  D6,D5
03:00000C6A EB4D            	   122:     lsl.w   #5,D5               ; 16 colors x 2 bytes
03:00000C6C 47F15000        	   123:     lea     0(A1,D5.w),A3
03:00000C70 7E03            	   124:     moveq   #3,D7
                            	   125: .color_loop:
03:00000C72 7000            	   126:     moveq   #0,D0
03:00000C74 1018            	   127:     move.b  (A0)+,D0
03:00000C76 D040            	   128:     add.w   D0,D0
03:00000C78 36F20000        	   129:     move.w  0(A2,D0.w),(A3)+
03:00000C7C 51CFFFF4        	   130:     dbra    D7,.color_loop
03:00000C80 5246            	   131:     addq.w  #1,D6
03:00000C82 0C460004        	   132:     cmpi.w  #4,D6
03:00000C86 65E0            	   133:     bcs.s   .palette_loop
                            	   134: 
                            	   135:     ; Queue the full CRAM image so palette lines 0-3 land in their correct
                            	   136:     ; 16-color slots.
03:00000C88 41F900FF0C00    	   137:     lea     (ROOM_PALETTE_BUFFER).l,A0
03:00000C8E 3E3C003F        	   138:     move.w  #63,D7
03:00000C92 6100FA74        	   139:     bsr     Renderer_QueueCRAMWords
03:00000C96 33FC021100FF0042	   140:     move.w  #$0211,(BOOT_DETAIL).l
03:00000C9E 4E75            	   141:     rts
                            	   142: 
                            	   143: Room_BuildOverworldPlayAreaAttrs:
03:00000CA0 33FC021200FF0042	   144:     move.w  #$0212,(BOOT_DETAIL).l
03:00000CA8 303900FF0054    	   145:     move.w  (ROOM_BUILD_ROOM_ID).l,D0
                            	   146: 
03:00000CAE 41FA086C        	   147:     lea     RoomAttrsOW_A(pc),A0
03:00000CB2 7200            	   148:     moveq   #0,D1
03:00000CB4 12300000        	   149:     move.b  0(A0,D0.w),D1
