03:00000450 0004
03:00000452 33FC8F0200C00004	    17:     move.w  #$8F02,(VDP_CTRL).l
03:0000045A 7000            	    18:     moveq   #0,D0
03:0000045C 3E3C7FFF        	    19:     move.w  #32767,D7
                            	    20: .clear_loop:
03:00000460 33C000C00000    	    21:     move.w  D0,(VDP_DATA).l
03:00000466 51CFFFF8        	    22:     dbra    D7,.clear_loop
