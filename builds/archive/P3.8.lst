03:00000C1E 7600            	   123:     moveq   #0,D3
03:00000C20 16322000        	   124:     move.b  0(A2,D2.w),D3
03:00000C24 0C4300E5        	   125:     cmpi.w  #$00E5,D3
03:00000C28 6516            	   126:     bcs.s   .primary_ready
03:00000C2A 0C4300EA        	   127:     cmpi.w  #$00EA,D3
03:00000C2E 6210            	   128:     bhi.s   .primary_ready
03:00000C30 3003            	   129:     move.w  D3,D0
03:00000C32 044000E5        	   130:     subi.w  #$00E5,D0
