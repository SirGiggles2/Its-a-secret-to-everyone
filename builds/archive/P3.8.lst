03:00000BDE 024100F0        	    96:     andi.w  #$00F0,D1
03:00000BE2 E649            	    97:     lsr.w   #3,D1
03:00000BE4 43FA10D2        	    98:     lea     ColumnDirectoryOW(pc),A1
