03:00000BEA 34311000        	   100:     move.w  0(A1,D1.w),D2
03:00000BEE 2242            	   101:     movea.l D2,A1
                            	   102: 
03:00000BF0 3600            	   103:     move.w  D0,D3
03:00000BF2 0243000F        	   104:     andi.w  #$000F,D3
03:00000BF6 78FF            	   105:     moveq   #-1,D4
                            	   106: .find_column_start:
03:00000BF8 5244            	   107:     addq.w  #1,D4
03:00000BFA 7200            	   108:     moveq   #0,D1
03:00000BFC 12314000        	   109:     move.b  0(A1,D4.w),D1
