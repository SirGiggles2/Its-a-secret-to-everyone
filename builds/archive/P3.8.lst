03:00000C3A 7600            	   132:     moveq   #0,D3
03:00000C3C 16320000        	   133:     move.b  0(A2,D0.w),D3
                            	   134: .primary_ready:
03:00000C40 3006            	   135:     move.w  D6,D0
03:00000C42 3207            	   136:     move.w  D7,D1
03:00000C44 612A            	   137:     bsr     Room_WriteSquareOW
