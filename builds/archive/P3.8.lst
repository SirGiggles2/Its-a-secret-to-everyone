                            	     1: ; =============================================================================
                            	     2: ; Renderer - Genesis VDP primitives
                            	     3: ; =============================================================================
                            	     4: ; Core VRAM/CRAM/tilemap operations. No game-specific rendering here.
                            	     5: ; Game systems will call these primitives to draw their scenes.
                            	     6: ;
                            	     7: ; Phase 2 will extend this with:
                            	     8: ;   - Sprite table manager (80-slot RAM table, DMA to VRAM)
                            	     9: ;   - DMA-based VBlank transfer queue
                            	    10: ;   - Room scrolling (column/row tilemap updates)
                            	    11: ; =============================================================================
                            	    12: 
                            	    13: ; --- VRAM clear ---
                            	    14: 
                            	    15: Renderer_ClearVRAM:
03:0000043A 23FC4000000000C0	    16:     move.l  #VRAM_WRITE_0000,(VDP_CTRL).l
03:00000442 0004
03:00000444 33FC8F0200C00004	    17:     move.w  #$8F02,(VDP_CTRL).l
03:0000044C 7000            	    18:     moveq   #0,D0
03:0000044E 3E3C7FFF        	    19:     move.w  #32767,D7
                            	    20: .clear_loop:
03:00000452 33C000C00000    	    21:     move.w  D0,(VDP_DATA).l
03:00000458 51CFFFF8        	    22:     dbra    D7,.clear_loop
03:0000045C 4E75            	    23:     rts
