                            	   171:     include "rooms.asm"

Source: "rooms.asm"
                            	     1: ; =============================================================================
                            	     2: ; Room Loader
                            	     3: ; =============================================================================
                            	     4: ; Phase 3 bootstrap:
                            	     5: ; - load the real overworld start room ($77)
                            	     6: ; - decode the original compressed column format at runtime
                            	     7: ; - convert extracted NES palette bytes to Genesis CRAM words
                            	     8: ; - queue a 32x22 room tilemap onto Plane A
                            	     9: ; =============================================================================
                            	    10: 
                            	    11: ROOM_START_SCREEN         equ $0077
                            	    12: ROOM_SQUARE_COLS         equ 16
                            	    13: ROOM_SQUARE_ROWS         equ 11
                            	    14: ROOM_TILE_COLS           equ 32
                            	    15: ROOM_TILE_ROWS           equ 22
                            	    16: ROOM_TILE_ROW_STRIDE     equ ROOM_TILE_COLS*2
                            	    17: 
                            	    18: Room_LoadStartingOverworld:
03:00000B06 303C0077        	    19:     move.w  #ROOM_START_SCREEN,D0
                            	    20:     bra     Room_LoadOverworldById
                            	    21: 
                            	    22: ; D0 = overworld room id
                            	    23: Room_LoadOverworldById:
03:00000B0A 33FC020000FF0040	    24:     move.w  #$0200,(BOOT_STAGE).l
03:00000B12 33C000FF003C    	    25:     move.w  D0,(CURRENT_ROOM_ID).l
03:00000B18 6122            	    26:     bsr     Room_ConvertOverworldPalette
03:00000B1A 33FC020100FF0040	    27:     move.w  #$0201,(BOOT_STAGE).l
03:00000B22 61000082        	    28:     bsr     Room_BuildOverworldTilemap
03:00000B26 33FC020200FF0040	    29:     move.w  #$0202,(BOOT_STAGE).l
03:00000B2E 610001B0        	    30:     bsr     Room_QueueOverworldTilemap
03:00000B32 33FC020300FF0040	    31:     move.w  #$0203,(BOOT_STAGE).l
03:00000B3A 4E75            	    32:     rts
                            	    33: 
                            	    34: Room_ConvertOverworldPalette:
03:00000B3C 33FC021000FF0042	    35:     move.w  #$0210,(BOOT_DETAIL).l
                            	    36: 
                            	    37:     ; Read outer palette index from bits 7-6 of RoomAttrsOW_A[current_room]
03:00000B44 41FA0722        	    38:     lea     RoomAttrsOW_A(pc),A0
03:00000B48 303900FF003C    	    39:     move.w  (CURRENT_ROOM_ID).l,D0
03:00000B4E 7200            	    40:     moveq   #0,D1
03:00000B50 12300000        	    41:     move.b  0(A0,D0.w),D1      ; D1 = full attrs byte
03:00000B54 EC09            	    42:     lsr.b   #6,D1               ; D1 = bits 7-6 = outer palette index (0-3)
03:00000B56 E549            	    43:     lsl.w   #2,D1               ; D1 = index * 4 = byte offset into LevelInfoOW
                            	    44: 
                            	    45:     ; Convert 4 NES color bytes of that sub-palette to Genesis CRAM words
03:00000B58 41FA1656        	    46:     lea     LevelInfoOW(pc),A0
03:00000B5C D0C1            	    47:     adda.w  D1,A0               ; A0 = start of outer sub-palette in LevelInfoOW
03:00000B5E 43F900FF0C00    	    48:     lea     (ROOM_PALETTE_BUFFER).l,A1
03:00000B64 45FA024A        	    49:     lea     NesColorToGenesisCRAM(pc),A2
03:00000B68 3E3C0003        	    50:     move.w  #3,D7               ; 4 words (CRAM colors 0-3)
                            	    51: .convert_loop:
03:00000B6C 7000            	    52:     moveq   #0,D0
03:00000B6E 1018            	    53:     move.b  (A0)+,D0
03:00000B70 D040            	    54:     add.w   D0,D0
03:00000B72 32F20000        	    55:     move.w  0(A2,D0.w),(A1)+
03:00000B76 51CFFFF4        	    56:     dbra    D7,.convert_loop
                            	    57: 
                            	    58:     ; Queue 4 CRAM words -> palette line 0 colors 0-3
03:00000B7A 41F900FF0C00    	    59:     lea     (ROOM_PALETTE_BUFFER).l,A0
03:00000B80 3E3C0003        	    60:     move.w  #3,D7
03:00000B84 6100FB74        	    61:     bsr     Renderer_QueueCRAMWords
03:00000B88 33FC021100FF0042	    62:     move.w  #$0211,(BOOT_DETAIL).l
03:00000B90 4E75            	    63:     rts
                            	    64: 
                            	    65: Room_ClearTilemapBuffer:
03:00000B92 41F900FF0600    	    66:     lea     (ROOM_TILEMAP_BUFFER).l,A0
