                            	   145: .desc_done:
03:00000C54 5247            	   146:     addq.w  #1,D7
03:00000C56 0C47000B        	   147:     cmpi.w  #ROOM_SQUARE_ROWS,D7
03:00000C5A 65AE            	   148:     bcs.s   .square_loop
