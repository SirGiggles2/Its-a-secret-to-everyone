                            	   115: .square_loop:
03:00000C0A 33C700FF0046    	   116:     move.w  D7,(ROOM_DEBUG_ROW).l
03:00000C10 7800            	   117:     moveq   #0,D4
03:00000C12 1811            	   118:     move.b  (A1),D4
                            	   119: 
03:00000C14 3404            	   120:     move.w  D4,D2
03:00000C16 0242003F        	   121:     andi.w  #$003F,D2
