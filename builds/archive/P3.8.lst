03:00000BB0 41FA0836        	    78:     lea     RoomAttrsOW_D(pc),A0
03:00000BB4 303900FF003C    	    79:     move.w  (CURRENT_ROOM_ID).l,D0
03:00000BBA 7200            	    80:     moveq   #0,D1
03:00000BBC 12300000        	    81:     move.b  0(A0,D0.w),D1
03:00000BC0 0241003F        	    82:     andi.w  #$003F,D1
03:00000BC4 E949            	    83:     lsl.w   #4,D1
                            	    84: 
03:00000BC6 41FA09A0        	    85:     lea     RoomLayoutsOW(pc),A0
03:00000BCA D0C1            	    86:     adda.w  D1,A0
                            	    87: 
03:00000BCC 7A00            	    88:     moveq   #0,D5                ; repeat-state toggle from the original loader
03:00000BCE 7C00            	    89:     moveq   #0,D6                ; square column
                            	    90: .column_loop:
03:00000BD0 33C600FF0044    	    91:     move.w  D6,(ROOM_DEBUG_COL).l
03:00000BD6 7000            	    92:     moveq   #0,D0
03:00000BD8 10306000        	    93:     move.b  0(A0,D6.w),D0
                            	    94: 
