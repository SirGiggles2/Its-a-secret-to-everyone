Source: "main.asm"
                            	   178:     include "rooms.asm"

Source: "rooms.asm"
                            	     1: ; =============================================================================
                            	     2: ; Room Loader
                            	     3: ; =============================================================================
                            	     4: ; Phase 3 bootstrap:
                            	     5: ; - load the real overworld start room ($77)
                            	     6: ; - decode the original compressed column format at runtime
                            	     7: ; - convert extracted NES palette bytes to Genesis CRAM words
                            	     8: ; - queue a 32x22 room tilemap onto Plane A
                            	     9: ; =============================================================================
                            	    10: 
                            	    11: ROOM_SQUARE_COLS         equ 16
                            	    12: ROOM_SQUARE_ROWS         equ 11
                            	    13: ROOM_TILE_COLS           equ 32
                            	    14: ROOM_TILE_ROWS           equ 22
                            	    15: ROOM_TILE_ROW_STRIDE     equ ROOM_TILE_COLS*2
                            	    16: ROOM_PLAYAREA_ATTR_COLS  equ 8
                            	    17: ROOM_PLAYAREA_ATTR_ROWS  equ 6
                            	    18: ROOM_PLAYAREA_ATTR_COUNT equ ROOM_PLAYAREA_ATTR_COLS*ROOM_PLAYAREA_ATTR_ROWS
                            	    19: ROOM_START_ROOM_OFFSET   equ $002F
                            	    20: 
                            	    21: Room_LoadStartingOverworld:
03:00000B4A 7000            	    22:     moveq   #0,D0
03:00000B4C 103A184F        	    23:     move.b  LevelInfoOW+ROOM_START_ROOM_OFFSET(pc),D0
                            	    24:     bra     Room_LoadOverworldById
                            	    25: 
                            	    26: ; D0 = overworld room id
                            	    27: Room_LoadOverworldById:
03:00000B50 33FC020000FF0040	    28:     move.w  #$0200,(BOOT_STAGE).l
03:00000B58 33C000FF003C    	    29:     move.w  D0,(CURRENT_ROOM_ID).l
03:00000B5E 33C000FF0054    	    30:     move.w  D0,(ROOM_BUILD_ROOM_ID).l
03:00000B64 6142            	    31:     bsr     Room_ConvertOverworldPalette
03:00000B66 33FC020100FF0040	    32:     move.w  #$0201,(BOOT_STAGE).l
03:00000B6E 6100009A        	    33:     bsr     Room_BuildOverworldPlayAreaAttrs
03:00000B72 33FC020200FF0040	    34:     move.w  #$0202,(BOOT_STAGE).l
03:00000B7A 6100013C        	    35:     bsr     Room_BuildOverworldTilemap
03:00000B7E 33FC020300FF0040	    36:     move.w  #$0203,(BOOT_STAGE).l
03:00000B86 303C0004        	    37:     move.w  #PLAYFIELD_TOP_ROW,D0
03:00000B8A 7200            	    38:     moveq   #0,D1
03:00000B8C 61000340        	    39:     bsr     Room_QueueOverworldTilemapAt
03:00000B90 33FC020400FF0040	    40:     move.w  #$0204,(BOOT_STAGE).l
03:00000B98 4E75            	    41:     rts
                            	    42: 
                            	    43: ; D0 = overworld room id
                            	    44: ; Builds the room into ROOM_TILEMAP_BUFFER without committing it as CURRENT_ROOM_ID
                            	    45: Room_BuildOverworldTilemapForRoomId:
03:00000B9A 33C000FF0054    	    46:     move.w  D0,(ROOM_BUILD_ROOM_ID).l
03:00000BA0 6168            	    47:     bsr     Room_BuildOverworldPlayAreaAttrs
03:00000BA2 61000114        	    48:     bsr     Room_BuildOverworldTilemap
03:00000BA6 4E75            	    49:     rts
                            	    50: 
                            	    51: Room_ConvertOverworldPalette:
03:00000BA8 33FC021000FF0042	    52:     move.w  #$0210,(BOOT_DETAIL).l
                            	    53: 
                            	    54:     ; Genesis CRAM is organized as 4 palette lines of 16 colors each.
                            	    55:     ; The NES overworld BG data gives us 4 sub-palettes of 4 colors each, so
                            	    56:     ; spread them into color slots 0-3 of Genesis palette lines 0-3 and leave
                            	    57:     ; the remaining entries clear.
03:00000BB0 43F900FF0C00    	    58:     lea     (ROOM_PALETTE_BUFFER).l,A1
03:00000BB6 7000            	    59:     moveq   #0,D0
03:00000BB8 3E3C003F        	    60:     move.w  #63,D7
                            	    61: .clear_loop:
03:00000BBC 32C0            	    62:     move.w  D0,(A1)+
03:00000BBE 51CFFFFC        	    63:     dbra    D7,.clear_loop
                            	    64: 
                            	    65:     ; LevelInfoOW begins with an NES palette transfer header:
                            	    66:     ;   $3F,$00,$20,<16 BG palette bytes>...
                            	    67:     ; Skip the 3-byte header and load the 4 BG sub-palettes.
03:00000BC2 41FA17AD        	    68:     lea     LevelInfoOW+3(pc),A0
03:00000BC6 43F900FF0C00    	    69:     lea     (ROOM_PALETTE_BUFFER).l,A1
03:00000BCC 45FA03F0        	    70:     lea     NesColorToGenesisCRAM(pc),A2
03:00000BD0 7C00            	    71:     moveq   #0,D6               ; palette line index
                            	    72: .palette_loop:
03:00000BD2 3A06            	    73:     move.w  D6,D5
03:00000BD4 EB4D            	    74:     lsl.w   #5,D5               ; 16 colors x 2 bytes
03:00000BD6 47F15000        	    75:     lea     0(A1,D5.w),A3
03:00000BDA 7E03            	    76:     moveq   #3,D7
                            	    77: .color_loop:
03:00000BDC 7000            	    78:     moveq   #0,D0
03:00000BDE 1018            	    79:     move.b  (A0)+,D0
03:00000BE0 D040            	    80:     add.w   D0,D0
03:00000BE2 36F20000        	    81:     move.w  0(A2,D0.w),(A3)+
03:00000BE6 51CFFFF4        	    82:     dbra    D7,.color_loop
03:00000BEA 5246            	    83:     addq.w  #1,D6
03:00000BEC 0C460004        	    84:     cmpi.w  #4,D6
03:00000BF0 65E0            	    85:     bcs.s   .palette_loop
                            	    86: 
                            	    87:     ; Queue the full CRAM image so palette lines 0-3 land in their correct
                            	    88:     ; 16-color slots.
03:00000BF2 41F900FF0C00    	    89:     lea     (ROOM_PALETTE_BUFFER).l,A0
03:00000BF8 3E3C003F        	    90:     move.w  #63,D7
03:00000BFC 6100FB0A        	    91:     bsr     Renderer_QueueCRAMWords
03:00000C00 33FC021100FF0042	    92:     move.w  #$0211,(BOOT_DETAIL).l
03:00000C08 4E75            	    93:     rts
                            	    94: 
                            	    95: Room_BuildOverworldPlayAreaAttrs:
03:00000C0A 33FC021200FF0042	    96:     move.w  #$0212,(BOOT_DETAIL).l
03:00000C12 303900FF0054    	    97:     move.w  (ROOM_BUILD_ROOM_ID).l,D0
                            	    98: 
03:00000C18 41FA085C        	    99:     lea     RoomAttrsOW_A(pc),A0
03:00000C1C 7200            	   100:     moveq   #0,D1
03:00000C1E 12300000        	   101:     move.b  0(A0,D0.w),D1
03:00000C22 02410003        	   102:     andi.w  #$0003,D1
03:00000C26 43FA031A        	   103:     lea     RoomPaletteSelectorToNTAttr(pc),A1
03:00000C2A 7400            	   104:     moveq   #0,D2
03:00000C2C 14311000        	   105:     move.b  0(A1,D1.w),D2
                            	   106: 
03:00000C30 41F900FF0B80    	   107:     lea     (ROOM_PLAYAREA_ATTR_BUFFER).l,A0
03:00000C36 3E3C002F        	   108:     move.w  #ROOM_PLAYAREA_ATTR_COUNT-1,D7
                            	   109: .fill_outer:
03:00000C3A 10C2            	   110:     move.b  D2,(A0)+
03:00000C3C 51CFFFFC        	   111:     dbra    D7,.fill_outer
                            	   112: 
03:00000C40 41FA08B4        	   113:     lea     RoomAttrsOW_B(pc),A0
03:00000C44 7200            	   114:     moveq   #0,D1
03:00000C46 12300000        	   115:     move.b  0(A0,D0.w),D1
03:00000C4A 02410003        	   116:     andi.w  #$0003,D1
03:00000C4E 43FA02F2        	   117:     lea     RoomPaletteSelectorToNTAttr(pc),A1
03:00000C52 7400            	   118:     moveq   #0,D2
03:00000C54 14311000        	   119:     move.b  0(A1,D1.w),D2
                            	   120: 
03:00000C58 41F900FF0B80    	   121:     lea     (ROOM_PLAYAREA_ATTR_BUFFER).l,A0
03:00000C5E 3E3C0009        	   122:     move.w  #$0009,D7
                            	   123: .fill_inner:
03:00000C62 3007            	   124:     move.w  D7,D0
03:00000C64 02400007        	   125:     andi.w  #$0007,D0
03:00000C68 6728            	   126:     beq.s   .next_inner
03:00000C6A 0C400007        	   127:     cmpi.w  #$0007,D0
03:00000C6E 6722            	   128:     beq.s   .next_inner
03:00000C70 0C470021        	   129:     cmpi.w  #$0021,D7
03:00000C74 6406            	   130:     bcc.s   .combine_inner_outer
03:00000C76 11827000        	   131:     move.b  D2,0(A0,D7.w)
03:00000C7A 6016            	   132:     bra.s   .next_inner
                            	   133: .combine_inner_outer:
03:00000C7C 7000            	   134:     moveq   #0,D0
03:00000C7E 10307000        	   135:     move.b  0(A0,D7.w),D0
03:00000C82 024000F0        	   136:     andi.w  #$00F0,D0
03:00000C86 3202            	   137:     move.w  D2,D1
03:00000C88 0241000F        	   138:     andi.w  #$000F,D1
03:00000C8C 8041            	   139:     or.w    D1,D0
03:00000C8E 11807000        	   140:     move.b  D0,0(A0,D7.w)
                            	   141: .next_inner:
03:00000C92 5247            	   142:     addq.w  #1,D7
03:00000C94 0C470027        	   143:     cmpi.w  #$0027,D7
03:00000C98 65C8            	   144:     bcs.s   .fill_inner
03:00000C9A 33FC021300FF0042	   145:     move.w  #$0213,(BOOT_DETAIL).l
03:00000CA2 4E75            	   146:     rts
                            	   147: 
