Source: "scenes\zelda_data_smoke.asm"
                            	     1: ; =============================================================================
                            	     2: ; Zelda Room Smoke Scene
                            	     3: ; =============================================================================
                            	     4: ; Phase 3 bootstrap scene:
                            	     5: ; - uploads the full overworld + common background tile set
                            	     6: ; - loads the extracted overworld start room from LevelInfo
                            	     7: ; - keeps Plane B fixed for HUD space
                            	     8: ; - draws a simple Link placeholder sprite
                            	     9: ; - keeps the scene stable while room fidelity is debugged
                            	    10: ; =============================================================================
                            	    11: 
                            	    12: ROOM_OW_BG_TILE_COUNT       equ 130
                            	    13: ROOM_COMMON_BG_TILE_COUNT   equ 112
                            	    14: ROOM_COMMON_MISC_TILE_COUNT equ 14
                            	    15: ROOM_COMMON_SPRITE_TILE_COUNT equ 112
                            	    16: ROOM_BG_TILE_COUNT          equ ROOM_OW_BG_TILE_COUNT+ROOM_COMMON_BG_TILE_COUNT+ROOM_COMMON_MISC_TILE_COUNT
                            	    17: ROOM_SPRITE_TILE_COUNT      equ 114
                            	    18: ROOM_OW_BG_VRAM             equ TILE1_VRAM+(ROOM_COMMON_BG_TILE_COUNT*32)
                            	    19: ROOM_COMMON_MISC_VRAM       equ ROOM_OW_BG_VRAM+(ROOM_OW_BG_TILE_COUNT*32)
                            	    20: ROOM_SPRITE_VRAM            equ TILE1_VRAM+(ROOM_BG_TILE_COUNT*32)
                            	    21: ROOM_COMMON_SPRITE_VRAM     equ ROOM_SPRITE_VRAM
                            	    22: ROOM_OW_SPRITE_VRAM         equ ROOM_COMMON_SPRITE_VRAM+(ROOM_COMMON_SPRITE_TILE_COUNT*32)
                            	    23: ROOM_COMMON_SPRITE_TILE_INDEX equ ROOM_COMMON_SPRITE_VRAM/32
                            	    24: ROOM_LINK_TILE_INDEX        equ ROOM_COMMON_SPRITE_TILE_INDEX+$000C
                            	    25: LINK_PLACEHOLDER_SPEED      equ 2
                            	    26: LINK_PLACEHOLDER_WIDTH      equ 16
                            	    27: LINK_PLACEHOLDER_HEIGHT     equ 16
                            	    28: LINK_RENDER_Y_OFFSET        equ 8
                            	    29: LINK_MIN_X                  equ 0
                            	    30: LINK_MAX_X                  equ (VISIBLE_COLS*8)-LINK_PLACEHOLDER_WIDTH
                            	    31: LINK_MIN_Y                  equ PLAYFIELD_TOP_ROW*8
                            	    32: LINK_MAX_Y                  equ (VISIBLE_ROWS*8)-LINK_PLACEHOLDER_HEIGHT
                            	    33: ROOM_TRANSITION_NONE        equ 0
                            	    34: ROOM_TRANSITION_RIGHT       equ 1
                            	    35: ROOM_TRANSITION_LEFT        equ 2
                            	    36: ROOM_TRANSITION_DOWN        equ 3
                            	    37: ROOM_TRANSITION_UP          equ 4
                            	    38: ROOM_TRANSITION_SCROLL_SPEED equ 8
                            	    39: ROOM_TRANSITION_STAGE_COL   equ VISIBLE_COLS
                            	    40: ROOM_TRANSITION_STAGE_ROW_DOWN equ PLAYFIELD_TOP_ROW+ROOM_TILE_ROWS
                            	    41: ROOM_TRANSITION_STAGE_ROW_UP equ PLANE_MAP_ROWS+PLAYFIELD_TOP_ROW-ROOM_TILE_ROWS
                            	    42: ROOM_TRANSITION_HORIZONTAL_PIXELS equ ROOM_TILE_COLS*8
                            	    43: ROOM_TRANSITION_VERTICAL_PIXELS equ ROOM_TILE_ROWS*8
                            	    44: Scene_ZeldaDataSmoke_Init:
