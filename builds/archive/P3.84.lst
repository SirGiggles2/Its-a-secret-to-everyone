Source: "scenes\palette_diagnostic.asm"
                            	     1: ; =============================================================================
                            	     2: ; Palette Diagnostic Scene - Hardware regression test
                            	     3: ; =============================================================================
                            	     4: ; Renders gradient palette bars to verify VDP color output.
                            	     5: ; Keep this scene intact as a baseline sanity check.
                            	     6: ; =============================================================================
                            	     7: 
                            	     8: Scene_PaletteDiagnostic_Init:
03:000040D4 41FA0052        	     9:     lea     PaletteDiagnosticCRAM(pc),A0
03:000040D8 3E3C000F        	    10:     move.w  #15,D7
03:000040DC 6100C3AA        	    11:     bsr     Renderer_LoadCRAM
03:000040E0 6104            	    12:     bsr     .LoadDiagnosticTiles
03:000040E2 6120            	    13:     bsr     .FillPlaneAWithGradient
03:000040E4 4E75            	    14:     rts
                            	    15: 
                            	    16: .LoadDiagnosticTiles:
03:000040E6 23FC4020000000C0	    17:     move.l  #VRAM_WRITE_TILE1,(VDP_CTRL).l
03:000040EE 0004
03:000040F0 41FA0056        	    18:     lea     PaletteDiagnosticTileWords(pc),A0
03:000040F4 3E3C000F        	    19:     move.w  #15,D7
                            	    20: .tile_loop:
03:000040F8 33D800C00000    	    21:     move.w  (A0)+,(VDP_DATA).l
03:000040FE 51CFFFF8        	    22:     dbra    D7,.tile_loop
03:00004102 4E75            	    23:     rts
                            	    24: 
                            	    25: .FillPlaneAWithGradient:
03:00004104 23FC4000000200C0	    26:     move.l  #VRAM_WRITE_PLANE_A,(VDP_CTRL).l
03:0000410C 0004
03:0000410E 3E3C001B        	    27:     move.w  #27,D7
                            	    28: .row_loop:
03:00004112 3C3C003F        	    29:     move.w  #63,D6
                            	    30: .cell_loop:
03:00004116 33FC000100C00000	    31:     move.w  #1,(VDP_DATA).l
03:0000411E 51CEFFF6        	    32:     dbra    D6,.cell_loop
03:00004122 51CFFFEE        	    33:     dbra    D7,.row_loop
03:00004126 4E75            	    34:     rts
                            	    35: 
                            	    36: PaletteDiagnosticCRAM:
03:00004128 0000            	    37:     dc.w $0000
03:0000412A 0EEE            	    38:     dc.w $0EEE
03:0000412C 000E            	    39:     dc.w $000E
03:0000412E 0E00            	    40:     dc.w $0E00
03:00004130 00E0            	    41:     dc.w $00E0
03:00004132 00EE            	    42:     dc.w $00EE
03:00004134 0E0E            	    43:     dc.w $0E0E
03:00004136 0EE0            	    44:     dc.w $0EE0
03:00004138 0888            	    45:     dc.w $0888
03:0000413A 0008            	    46:     dc.w $0008
03:0000413C 0800            	    47:     dc.w $0800
03:0000413E 0080            	    48:     dc.w $0080
03:00004140 0088            	    49:     dc.w $0088
03:00004142 0808            	    50:     dc.w $0808
03:00004144 0880            	    51:     dc.w $0880
03:00004146 0444            	    52:     dc.w $0444
                            	    53: 
                            	    54: PaletteDiagnosticTileWords:
03:00004148 0000            	    55:     dc.w $0000,$0000
03:0000414A 0000
03:0000414C 1111            	    56:     dc.w $1111,$1111
03:0000414E 1111
