Source: "dungeon.asm"
                            	     1: ; =============================================================================
                            	     2: ; Dungeon Navigation System
                            	     3: ; =============================================================================
                            	     4: ; Phase 3 dungeon implementation:
                            	     5: ; - 8x8 room grid navigation per level
                            	     6: ; - Door state handling (locked, bombed, key, shutter)
                            	     7: ; - Secret detection (bomb walls, push rocks, burn bushes)
                            	     8: ; - Warp/staircase system
                            	     9: ; =============================================================================
                            	    10: 
                            	    11: DUNGEON_ROOMS_PER_LEVEL equ 64
                            	    12: DUNGEON_GRID_COLS        equ 8
                            	    13: DUNGEON_GRID_ROWS        equ 8
                            	    14: 
                            	    15: ; Dungeon door types
                            	    16: DOOR_TYPE_NORMAL        equ $00
                            	    17: DOOR_TYPE_LOCKED        equ $01
                            	    18: DOOR_TYPE_BOMBED        equ $02
                            	    19: DOOR_TYPE_KEY           equ $03
                            	    20: DOOR_TYPE_SHUTTER       equ $04
                            	    21: 
                            	    22: ; Dungeon room flags
                            	    23: ROOM_FLAG_SECRET_WALL   equ $01
                            	    24: ROOM_FLAG_SECRET_ROCK   equ $02
                            	    25: ROOM_FLAG_SECRET_BUSH   equ $04
                            	    26: ROOM_FLAG_STAIR_DOWN    equ $08
                            	    27: ROOM_FLAG_STAIR_UP      equ $10
                            	    28: ROOM_FLAG_WARP          equ $20
                            	    29: 
                            	    30: ; D0 = new room id
                            	    31: ; D1 = direction (0=up,1=right,2=down,3=left)
                            	    32: Room_TransitionToDungeonRoom:
03:00003D3E 33C000FF0052    	    33:     move.w  D0,(ROOM_TRANSITION_TARGET_ROOM).l
03:00003D44 33C100FF004E    	    34:     move.w  D1,(ROOM_TRANSITION_DIRECTION).l
03:00003D4A 33FC000100FF004C	    35:     move.w  #1,(ROOM_TRANSITION_ACTIVE).l
03:00003D52 33FC000000FF0050	    36:     move.w  #0,(ROOM_TRANSITION_OFFSET).l
03:00003D5A 4E75            	    37:     rts
                            	    38: 
                            	    39: ; Check if dungeon room transition is valid
                            	    40: ; D0 = current room id
                            	    41: ; D1 = direction (0=up,1=right,2=down,3=left)
                            	    42: ; Returns: D0 = new room id (or -1 if invalid)
                            	    43: Room_GetDungeonAdjacentRoom:
03:00003D5C 3F00            	    44:     move.w  D0,-(A7)
03:00003D5E 3F01            	    45:     move.w  D1,-(A7)
                            	    46:     
                            	    47:     ; Calculate grid position
03:00003D60 3400            	    48:     move.w  D0,D2
03:00003D62 0242003F        	    49:     andi.w  #$003F,D2        ; mask to room within level
03:00003D66 3602            	    50:     move.w  D2,D3
03:00003D68 3803            	    51:     move.w  D3,D4
03:00003D6A E64B            	    52:     lsr.w   #3,D3           ; row index (0-7)
03:00003D6C 02440007        	    53:     andi.w  #$0007,D4        ; col index (0-7)
                            	    54:     
                            	    55:     ; Check bounds and calculate adjacent
03:00003D70 4A41            	    56:     cmpi.w  #0,D1
03:00003D72 6714            	    57:     beq.s   .check_up
03:00003D74 0C410001        	    58:     cmpi.w  #1,D1
03:00003D78 6716            	    59:     beq.s   .check_right
03:00003D7A 0C410002        	    60:     cmpi.w  #2,D1
03:00003D7E 671A            	    61:     beq.s   .check_down
03:00003D80 0C410003        	    62:     cmpi.w  #3,D1
03:00003D84 671E            	    63:     beq.s   .check_left
03:00003D86 6038            	    64:     bra.s   .invalid
                            	    65:     
                            	    66: .check_up:
03:00003D88 4A43            	    67:     tst.w   D3
03:00003D8A 6734            	    68:     beq.s   .invalid        ; top row
03:00003D8C 5343            	    69:     subq.w  #1,D3
03:00003D8E 601C            	    70:     bra.s   .calculate
                            	    71:     
                            	    72: .check_right:
03:00003D90 0C440007        	    73:     cmpi.w  #7,D4
03:00003D94 672A            	    74:     beq.s   .invalid        ; rightmost column
03:00003D96 5244            	    75:     addq.w  #1,D4
03:00003D98 6012            	    76:     bra.s   .calculate
                            	    77:     
                            	    78: .check_down:
03:00003D9A 0C430007        	    79:     cmpi.w  #7,D3
03:00003D9E 6720            	    80:     beq.s   .invalid        ; bottom row
03:00003DA0 5243            	    81:     addq.w  #1,D3
03:00003DA2 6008            	    82:     bra.s   .calculate
                            	    83:     
                            	    84: .check_left:
03:00003DA4 4A44            	    85:     tst.w   D4
03:00003DA6 6718            	    86:     beq.s   .invalid        ; leftmost column
03:00003DA8 5344            	    87:     subq.w  #1,D4
03:00003DAA 4DD6            	    88:     bra.s   .calculate
                            	    89:     
                            	    90: .calculate:
                            	    91:     ; Convert back to room id
03:00003DAC 3003            	    92:     move.w  D3,D0
03:00003DAE E748            	    93:     lsl.w   #3,D0
03:00003DB0 D044            	    94:     add.w   D4,D0
                            	    95:     ; Restore level offset
03:00003DB2 341F            	    96:     move.w  (A7)+,D2
03:00003DB4 0242FFC0        	    97:     andi.w  #$FFC0,D2        ; keep level bits
03:00003DB8 8440            	    98:     or.w    D0,D2
03:00003DBA 3002            	    99:     move.w  D2,D0
03:00003DBC 584F            	   100:     addq.w  #4,A7           ; clean up stack
03:00003DBE 4E75            	   101:     rts
                            	   102:     
                            	   103: .invalid:
03:00003DC0 303CFFFF        	   104:     move.w  #-1,D0
03:00003DC4 584F            	   105:     addq.w  #4,A7           ; clean up stack
03:00003DC6 4E75            	   106:     rts
                            	   107: 
                            	   108: ; Check if door can be passed
                            	   109: ; D0 = current room id
                            	   110: ; D1 = direction (0=up,1=right,2=down,3=left)
                            	   111: ; Returns: D0 = door type (or -1 if no door)
                            	   112: Room_GetDungeonDoorType:
03:00003DC8 3400            	   113:     move.w  D0,D2
03:00003DCA 0242003F        	   114:     andi.w  #$003F,D2        ; room within level
03:00003DCE 3601            	   115:     move.w  D1,D3
                            	   116:     ; Load room attributes to check door type
03:00003DD0 303900FF0062    	   117:     move.w  (CURRENT_LEVEL_ID).l,D0
03:00003DD6 0C400006        	   118:     cmpi.w  #6,D0
03:00003DDA 6506            	   119:     bcs.s   .q1_attrs
                            	   120: .q2_attrs:
03:00003DDC 41FAE378        	   121:     lea     RoomAttrsUW2Q1_B(pc),A0
03:00003DE0 6004            	   122:     bra.s   .check_door
                            	   123: .q1_attrs:
03:00003DE2 41FADD72        	   124:     lea     RoomAttrsUW1Q1_B(pc),A0
                            	   125: .check_door:
03:00003DE6 7000            	   126:     moveq   #0,D0
03:00003DE8 10302000        	   127:     move.b  0(A0,D2.w),D0
                            	   128:     ; Extract door type based on direction
03:00003DEC E668            	   129:     lsr.w   D3,D0
03:00003DEE 02400003        	   130:     andi.w  #$0003,D0
03:00003DF2 4E75            	   131:     rts
                            	   132: 
                            	   133: ; Initialize dungeon for a level
                            	   134: ; D0 = level id (0-8)
                            	   135: Room_InitDungeonLevel:
03:00003DF4 33C000FF0062    	   136:     move.w  D0,(CURRENT_LEVEL_ID).l
03:00003DFA 33FC000000FF003C	   137:     move.w  #0,(CURRENT_ROOM_ID).l
                            	   138:     ; Load starting room for this level
03:00003E02 7200            	   139:     moveq   #0,D1
03:00003E04 6100CDD6        	   140:     bsr     Room_LoadUnderworldById
03:00003E08 4E75            	   141:     rts
                            	   142: 
                            	   143: ; Handle dungeon room interactions
                            	   144: Room_HandleDungeonInteractions:
                            	   145:     ; Check for secrets
03:00003E0A 6104            	   146:     bsr     Room_CheckDungeonSecrets
                            	   147:     ; Check for stairs/warps
03:00003E0C 6130            	   148:     bsr     Room_CheckDungeonWarps
03:00003E0E 4E75            	   149:     rts
                            	   150: 
                            	   151: ; Check and trigger dungeon secrets
                            	   152: Room_CheckDungeonSecrets:
03:00003E10 303900FF003C    	   153:     move.w  (CURRENT_ROOM_ID).l,D0
03:00003E16 0240003F        	   154:     andi.w  #$003F,D0
03:00003E1A 323900FF0062    	   155:     move.w  (CURRENT_LEVEL_ID).l,D1
03:00003E20 0C410006        	   156:     cmpi.w  #6,D1
03:00003E24 6506            	   157:     bcs.s   .q1_secrets
                            	   158: .q2_secrets:
03:00003E26 41FAE3AE        	   159:     lea     RoomAttrsUW2Q1_C(pc),A0
03:00003E2A 6004            	   160:     bra.s   .check_flags
                            	   161: .q1_secrets:
03:00003E2C 41FADDA8        	   162:     lea     RoomAttrsUW1Q1_C(pc),A0
                            	   163: .check_flags:
03:00003E30 7200            	   164:     moveq   #0,D1
03:00003E32 12300000        	   165:     move.b  0(A0,D0.w),D1
                            	   166:     ; Check for secret walls (bomb walls)
03:00003E36 4A01            	   167:     tst.b   D1
03:00003E38 6B02            	   168:     bmi.s   .has_secret_wall
                            	   169:     ; Check for other secrets based on flags
03:00003E3A 4E75            	   170:     rts
                            	   171:     
                            	   172: .has_secret_wall:
                            	   173:     ; TODO: Implement bomb wall detection
03:00003E3C 4E75            	   174:     rts
                            	   175: 
                            	   176: ; Check for dungeon stairs and warps
                            	   177: Room_CheckDungeonWarps:
03:00003E3E 303900FF003C    	   178:     move.w  (CURRENT_ROOM_ID).l,D0
03:00003E44 0240003F        	   179:     andi.w  #$003F,D0
03:00003E48 323900FF0062    	   180:     move.w  (CURRENT_LEVEL_ID).l,D1
03:00003E4E 0C410006        	   181:     cmpi.w  #6,D1
03:00003E52 6506            	   182:     bcs.s   .q1_warps
                            	   183: .q2_warps:
03:00003E54 41FAE380        	   184:     lea     RoomAttrsUW2Q1_C(pc),A0
03:00003E58 6004            	   185:     bra.s   .check_warp_flags
                            	   186: .q1_warps:
03:00003E5A 41FADD7A        	   187:     lea     RoomAttrsUW1Q1_C(pc),A0
                            	   188: .check_warp_flags:
03:00003E5E 7200            	   189:     moveq   #0,D1
03:00003E60 12300000        	   190:     move.b  0(A0,D0.w),D1
                            	   191:     ; Check stair flags
03:00003E64 02410018        	   192:     andi.w  #$0018,D1
03:00003E68 670C            	   193:     beq.s   .no_stairs
03:00003E6A 0C410008        	   194:     cmpi.w  #$0008,D1
03:00003E6E 670E            	   195:     beq.s   .stair_down
03:00003E70 0C410010        	   196:     cmpi.w  #$0010,D1
03:00003E74 670A            	   197:     beq.s   .stair_up
                            	   198: .no_stairs:
                            	   199:     ; Check warp flag
03:00003E76 02410020        	   200:     andi.w  #$0020,D1
03:00003E7A 4DD6            	   201:     beq.s   .no_warp
                            	   202:     ; TODO: Implement warp handling
                            	   203: .no_warp:
03:00003E7C 4E75            	   204:     rts
                            	   205:     
                            	   206: .stair_down:
                            	   207:     ; TODO: Implement stair down transition
03:00003E7E 4E75            	   208:     rts
                            	   209:     
                            	   210: .stair_up:
                            	   211:     ; TODO: Implement stair up transition
03:00003E80 4E75            	   212:     rts
                            	   213: 

