Source: "player.asm"
                            	     9: 
                            	    10: ; Player state constants (from NES)
                            	    11: PLAYER_STATE_WALKING      equ $00
                            	    12: PLAYER_STATE_ATTACKING    equ $01
                            	    13: PLAYER_STATE_HURT         equ $02
                            	    14: PLAYER_STATE_STUNNED      equ $03
                            	    15: PLAYER_STATE_ENTER_CAVE   equ $04
                            	    16: PLAYER_STATE_USING_ITEM   equ $05
                            	    17: PLAYER_STATE_DEATH        equ $06
                            	    18: 
                            	    19: ; Player RAM variables
                            	    20: LINK_X                equ LINK_PLACEHOLDER_X
                            	    21: LINK_Y                equ LINK_PLACEHOLDER_Y
                            	    22: LINK_SPEED_Q          equ $00FF0E00
                            	    23: LINK_DIRECTION        equ $00FF0E02
                            	    24: LINK_STATE            equ $00FF0E04
                            	    25: LINK_TIMER            equ $00FF0E06
                            	    26: LINK_HP               equ $00FF0E08
                            	    27: LINK_MAX_HP           equ $00FF0E0A
                            	    28: LINK_INVINCIBLE_TIMER equ $00FF0E0C
                            	    29: 
                            	    30: ; Sub-pixel position tracking (NES-accurate)
                            	    31: LINK_POS_FRAC_X       equ $00FF0E0E
                            	    32: LINK_POS_FRAC_Y       equ $00FF0E10
                            	    33: LINK_GRID_OFFSET_X    equ $00FF0E12
                            	    34: LINK_GRID_OFFSET_Y    equ $00FF0E14
                            	    35: 
                            	    36: ; =============================================================================
                            	    37: ; Player Initialization
                            	    38: ; =============================================================================
                            	    39: 
                            	    40: Player_Init:
                            	    41:     ; Initialize Link at overworld starting position
03:00003E8A 33FC004000FF0048	    42:     move.w  #64,(LINK_X).l           ; X = 64 (center of screen)
03:00003E92 33FC004D00FF004A	    43:     move.w  #77,(LINK_Y).l           ; Y = 77 (overworld starting room)
03:00003E9A 33FC006000FF0E00	    44:     move.w  #LinkQSpeedDefault,(LINK_SPEED_Q).l
03:00003EA2 33FC000000FF0E02	    45:     move.w  #0,(LINK_DIRECTION).l   ; facing down
03:00003EAA 33FC000000FF0E04	    46:     move.w  #PLAYER_STATE_WALKING,(LINK_STATE).l
03:00003EB2 33FC000000FF0E06	    47:     move.w  #0,(LINK_TIMER).l
03:00003EBA 33FC000300FF0E08	    48:     move.w  #3,(LINK_HP).l           ; start with 3 hearts
03:00003EC2 33FC000300FF0E0A	    49:     move.w  #3,(LINK_MAX_HP).l
03:00003ECA 33FC000000FF0E0C	    50:     move.w  #0,(LINK_INVINCIBLE_TIMER).l
                            	    51:     
                            	    52:     ; Clear sub-pixel position
03:00003ED2 33FC000000FF0E0E	    53:     move.w  #0,(LINK_POS_FRAC_X).l
03:00003EDA 33FC000000FF0E10	    54:     move.w  #0,(LINK_POS_FRAC_Y).l
03:00003EE2 33FC000000FF0E12	    55:     move.w  #0,(LINK_GRID_OFFSET_X).l
03:00003EEA 33FC000000FF0E14	    56:     move.w  #0,(LINK_GRID_OFFSET_Y).l
03:00003EF2 4E75            	    57:     rts
