                            	    59: ; =============================================================================
                            	    60: ; Player Update - Main Entry Point
                            	    61: ; =============================================================================
                            	    62: 
                            	    63: Player_Update:
                            	    64:     ; Handle state-specific updates
03:00003EF4 303900FF0E04    	    65:     move.w  (LINK_STATE).l,D0
03:00003EFA 4A40            	    66:     cmpi.w  #PLAYER_STATE_WALKING,D0
03:00003EFC 6726            	    67:     beq.s   .update_walking
03:00003EFE 0C400001        	    68:     cmpi.w  #PLAYER_STATE_ATTACKING,D0
03:00003F02 672C            	    69:     beq.s   .update_attacking
03:00003F04 0C400002        	    70:     cmpi.w  #PLAYER_STATE_HURT,D0
03:00003F08 672C            	    71:     beq.s   .update_hurt
03:00003F0A 0C400003        	    72:     cmpi.w  #PLAYER_STATE_STUNNED,D0
03:00003F0E 672C            	    73:     beq.s   .update_stunned
03:00003F10 0C400004        	    74:     cmpi.w  #PLAYER_STATE_ENTER_CAVE,D0
03:00003F14 672C            	    75:     beq.s   .update_enter_cave
03:00003F16 0C400005        	    76:     cmpi.w  #PLAYER_STATE_USING_ITEM,D0
03:00003F1A 672C            	    77:     beq.s   .update_using_item
03:00003F1C 0C400006        	    78:     cmpi.w  #PLAYER_STATE_DEATH,D0
03:00003F20 672C            	    79:     beq.s   .update_death
03:00003F22 4E75            	    80:     rts
                            	    81: 
                            	    82: .update_walking:
03:00003F24 612E            	    83:     bsr     Player_HandleInput
03:00003F26 610000AC        	    84:     bsr     Player_UpdateMovement
03:00003F2A 61000168        	    85:     bsr     Player_UpdateCollision
03:00003F2E 4E75            	    86:     rts
                            	    87: 
                            	    88: .update_attacking:
03:00003F30 61000178        	    89:     bsr     Player_UpdateAttack
03:00003F34 4E75            	    90:     rts
                            	    91: 
                            	    92: .update_hurt:
03:00003F36 61000192        	    93:     bsr     Player_UpdateHurt
03:00003F3A 4E75            	    94:     rts
                            	    95: 
                            	    96: .update_stunned:
03:00003F3C 6100018E        	    97:     bsr     Player_UpdateStunned
03:00003F40 4E75            	    98:     rts
                            	    99: 
                            	   100: .update_enter_cave:
03:00003F42 6100018A        	   101:     bsr     Player_UpdateEnterCave
03:00003F46 4E75            	   102:     rts
                            	   103: 
                            	   104: .update_using_item:
03:00003F48 61000186        	   105:     bsr     Player_UpdateUseItem
03:00003F4C 4E75            	   106:     rts
                            	   107: 
                            	   108: .update_death:
03:00003F4E 61000182        	   109:     bsr     Player_UpdateDeath
03:00003F52 4E75            	   110:     rts
                            	   111: 
                            	   112: ; =============================================================================
                            	   113: ; Input Handling (NES-accurate)
                            	   114: ; =============================================================================
                            	   115: 
                            	   116: Player_HandleInput:
                            	   117:     ; Read joypad state
03:00003F54 6100C470        	   118:     bsr     READ_JOYPAD
                            	   119:     
                            	   120:     ; Check for sword button
03:00003F58 08000006        	   121:     btst    #PAD_B,D0
03:00003F5C 6602            	   122:     bne.s   .check_sword
03:00003F5E 6012            	   123:     bra.s   .check_movement
                            	   124:     
                            	   125: .check_sword:
                            	   126:     ; Initiate sword attack if not already attacking
03:00003F60 323900FF0E04    	   127:     move.w  (LINK_STATE).l,D1
03:00003F66 0C410001        	   128:     cmpi.w  #PLAYER_STATE_ATTACKING,D1
03:00003F6A 6706            	   129:     beq.s   .check_movement
03:00003F6C 6100012A        	   130:     bsr     Player_StartSwordAttack
03:00003F70 601E            	   131:     bra.s   .done_input
                            	   132:     
                            	   133: .check_movement:
                            	   134:     ; Handle directional input for movement
03:00003F72 7200            	   135:     moveq   #0,D1
03:00003F74 08000003        	   136:     btst    #PAD_UP,D0
03:00003F78 6614            	   137:     bne.s   .has_dir
03:00003F7A 08000002        	   138:     btst    #PAD_DOWN,D0
03:00003F7E 660E            	   139:     bne.s   .has_dir
03:00003F80 08000001        	   140:     btst    #PAD_LEFT,D0
03:00003F84 6608            	   141:     bne.s   .has_dir
03:00003F86 08000000        	   142:     btst    #PAD_RIGHT,D0
03:00003F8A 6602            	   143:     bne.s   .has_dir
03:00003F8C 6002            	   144:     bra.s   .done_input
                            	   145: 
                            	   146: .has_dir:
                            	   147:     
                            	   148:     ; Set direction based on input
03:00003F8E 6102            	   149:     bsr     Player_SetDirectionFromInput
                            	   150:     
                            	   151: .done_input:
03:00003F90 4E75            	   152:     rts
                            	   153: 
                            	   154: Player_SetDirectionFromInput:
03:00003F92 08000003        	   155:     btst    #PAD_UP,D0
03:00003F96 6614            	   156:     bne.s   .set_up
03:00003F98 08000002        	   157:     btst    #PAD_DOWN,D0
03:00003F9C 6618            	   158:     bne.s   .set_down
03:00003F9E 08000001        	   159:     btst    #PAD_LEFT,D0
03:00003FA2 661C            	   160:     bne.s   .set_left
03:00003FA4 08000000        	   161:     btst    #PAD_RIGHT,D0
03:00003FA8 6620            	   162:     bne.s   .set_right
03:00003FAA 4E75            	   163:     rts
                            	   164:     
                            	   165: .set_up:
03:00003FAC 33FC000000FF0E02	   166:     move.w  #0,(LINK_DIRECTION).l
03:00003FB4 4E75            	   167:     rts
                            	   168: .set_down:
03:00003FB6 33FC000200FF0E02	   169:     move.w  #2,(LINK_DIRECTION).l
03:00003FBE 4E75            	   170:     rts
                            	   171: .set_left:
03:00003FC0 33FC000300FF0E02	   172:     move.w  #3,(LINK_DIRECTION).l
03:00003FC8 4E75            	   173:     rts
                            	   174: .set_right:
03:00003FCA 33FC000100FF0E02	   175:     move.w  #1,(LINK_DIRECTION).l
03:00003FD2 4E75            	   176:     rts
                            	   177: 
                            	   178: ; =============================================================================
                            	   179: ; Movement System (NES-accurate sub-pixel tracking)
                            	   180: ; =============================================================================
                            	   181: 
                            	   182: Player_UpdateMovement:
                            	   183:     ; Only move if directional input is held
03:00003FD4 6100C3F0        	   184:     bsr     READ_JOYPAD
03:00003FD8 7E00            	   185:     moveq   #0,D7
03:00003FDA 08000003        	   186:     btst    #PAD_UP,D0
03:00003FDE 6616            	   187:     bne.s   .has_movement
03:00003FE0 08000002        	   188:     btst    #PAD_DOWN,D0
03:00003FE4 6610            	   189:     bne.s   .has_movement
03:00003FE6 08000001        	   190:     btst    #PAD_LEFT,D0
03:00003FEA 660A            	   191:     bne.s   .has_movement
03:00003FEC 08000000        	   192:     btst    #PAD_RIGHT,D0
03:00003FF0 6604            	   193:     bne.s   .has_movement
03:00003FF2 6000009E        	   194:     bra     .no_movement
                            	   195: 
                            	   196: .has_movement:
                            	   197:     
                            	   198:     ; Apply NES-accurate movement speed
03:00003FF6 323900FF0E00    	   199:     move.w  (LINK_SPEED_Q).l,D1
03:00003FFC 343900FF0E02    	   200:     move.w  (LINK_DIRECTION).l,D2
                            	   201:     ; NES applies q-speed four times per frame.
03:00004002 7C03            	   202:     moveq   #3,D6
                            	   203: .apply_qspeed_loop:
03:00004004 4A42            	   204:     cmpi.w  #0,D2
03:00004006 676A            	   205:     beq.s   .move_up_once
03:00004008 0C420001        	   206:     cmpi.w  #1,D2
03:0000400C 6708            	   207:     beq.s   .move_right_once
03:0000400E 0C420002        	   208:     cmpi.w  #2,D2
03:00004012 673E            	   209:     beq.s   .move_down_once
03:00004014 6020            	   210:     bra.s   .move_left_once
                            	   211: 
                            	   212: .move_right_once:
03:00004016 363900FF0E0E    	   213:     move.w  (LINK_POS_FRAC_X).l,D3
03:0000401C D641            	   214:     add.w   D1,D3
03:0000401E 0C430100        	   215:     cmpi.w  #$100,D3
03:00004022 650A            	   216:     bcs.s   .store_right_once
03:00004024 04430100        	   217:     subi.w  #$100,D3
03:00004028 527900FF0048    	   218:     addq.w  #1,(LINK_X).l
                            	   219: .store_right_once:
03:0000402E 33C300FF0E0E    	   220:     move.w  D3,(LINK_POS_FRAC_X).l
03:00004034 6056            	   221:     bra.s   .apply_next_qspeed
                            	   222: 
                            	   223: .move_left_once:
03:00004036 363900FF0E0E    	   224:     move.w  (LINK_POS_FRAC_X).l,D3
03:0000403C 9641            	   225:     sub.w   D1,D3
03:0000403E 6A0A            	   226:     bpl.s   .store_left_once
03:00004040 06430100        	   227:     addi.w  #$0100,D3
03:00004044 537900FF0048    	   228:     subq.w  #1,(LINK_X).l
                            	   229: .store_left_once:
03:0000404A 33C300FF0E0E    	   230:     move.w  D3,(LINK_POS_FRAC_X).l
03:00004050 603A            	   231:     bra.s   .apply_next_qspeed
                            	   232: 
                            	   233: .move_down_once:
03:00004052 363900FF0E10    	   234:     move.w  (LINK_POS_FRAC_Y).l,D3
03:00004058 D641            	   235:     add.w   D1,D3
03:0000405A 0C430100        	   236:     cmpi.w  #$100,D3
03:0000405E 650A            	   237:     bcs.s   .store_down_once
03:00004060 04430100        	   238:     subi.w  #$100,D3
03:00004064 527900FF004A    	   239:     addq.w  #1,(LINK_Y).l
                            	   240: .store_down_once:
03:0000406A 33C300FF0E10    	   241:     move.w  D3,(LINK_POS_FRAC_Y).l
03:00004070 601A            	   242:     bra.s   .apply_next_qspeed
                            	   243: 
                            	   244: .move_up_once:
03:00004072 363900FF0E10    	   245:     move.w  (LINK_POS_FRAC_Y).l,D3
03:00004078 9641            	   246:     sub.w   D1,D3
03:0000407A 6A0A            	   247:     bpl.s   .store_up_once
03:0000407C 06430100        	   248:     addi.w  #$0100,D3
03:00004080 537900FF004A    	   249:     subq.w  #1,(LINK_Y).l
                            	   250: .store_up_once:
03:00004086 33C300FF0E10    	   251:     move.w  D3,(LINK_POS_FRAC_Y).l
                            	   252: 
                            	   253: .apply_next_qspeed:
03:0000408C 51CEFF76        	   254:     dbra    D6,.apply_qspeed_loop
                            	   255:     
                            	   256: .movement_done:
03:00004090 4E75            	   257:     rts
                            	   258:     
                            	   259: .no_movement:
03:00004092 4E75            	   260:     rts
                            	   261: 
                            	   262: ; =============================================================================
                            	   263: ; Collision Detection (NES-accurate)
                            	   264: ; =============================================================================
                            	   265: 
                            	   266: Player_UpdateCollision:
                            	   267:     ; Transition edges are handled by scene logic.
                            	   268:     ; Tile collision will be implemented here in Phase 4A.
03:00004094 4E75            	   269:     rts
                            	   270: 
                            	   271: Player_CheckWallCollision:
                            	   272:     ; Reserved for tile-based collision implementation.
03:00004096 4E75            	   273:     rts
                            	   274: 
                            	   275: ; =============================================================================
                            	   276: ; Combat System (NES-accurate)
                            	   277: ; =============================================================================
                            	   278: 
                            	   279: Player_StartSwordAttack:
03:00004098 33FC000100FF0E04	   280:     move.w  #PLAYER_STATE_ATTACKING,(LINK_STATE).l
03:000040A0 33FC000000FF0E06	   281:     move.w  #0,(LINK_TIMER).l
03:000040A8 4E75            	   282:     rts
                            	   283: 
                            	   284: Player_UpdateAttack:
                            	   285:     ; NES sword attack lasts 16 frames
03:000040AA 303900FF0E06    	   286:     move.w  (LINK_TIMER).l,D0
03:000040B0 5240            	   287:     addq.w  #1,D0
03:000040B2 33C000FF0E06    	   288:     move.w  D0,(LINK_TIMER).l
03:000040B8 0C400010        	   289:     cmpi.w  #16,D0
03:000040BC 650A            	   290:     bcs.s   .attack_continue
                            	   291:     ; Attack finished, return to walking
03:000040BE 33FC000000FF0E04	   292:     move.w  #PLAYER_STATE_WALKING,(LINK_STATE).l
03:000040C6 4E75            	   293:     rts
                            	   294:     
                            	   295: .attack_continue:
                            	   296:     ; TODO: Update sword hitbox position
03:000040C8 4E75            	   297:     rts
                            	   298: 
                            	   299: ; =============================================================================
                            	   300: ; State Machine Updates
                            	   301: ; =============================================================================
                            	   302: 
                            	   303: Player_UpdateHurt:
                            	   304:     ; TODO: Implement hurt state with knockback
03:000040CA 4E75            	   305:     rts
                            	   306: 
                            	   307: Player_UpdateStunned:
                            	   308:     ; TODO: Implement stunned state
03:000040CC 4E75            	   309:     rts
                            	   310: 
                            	   311: Player_UpdateEnterCave:
                            	   312:     ; TODO: Implement cave entry animation
03:000040CE 4E75            	   313:     rts
                            	   314: 
                            	   315: Player_UpdateUseItem:
                            	   316:     ; TODO: Implement item usage
03:000040D0 4E75            	   317:     rts
                            	   318: 
                            	   319: Player_UpdateDeath:
                            	   320:     ; TODO: Implement death sequence
03:000040D2 4E75            	   321:     rts
