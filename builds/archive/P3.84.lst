                            	   143: Room_ConvertOverworldPalette:
03:00000CC8 33FC021000FF0042	   144:     move.w  #$0210,(BOOT_DETAIL).l
                            	   145: 
                            	   146:     ; Genesis CRAM is organized as 4 palette lines of 16 colors each.
                            	   147:     ; The NES overworld BG data gives us 4 sub-palettes of 4 colors each, so
                            	   148:     ; spread them into color slots 0-3 of Genesis palette lines 0-3 and leave
                            	   149:     ; the remaining entries clear.
03:00000CD0 43F900FF0C00    	   150:     lea     (ROOM_PALETTE_BUFFER).l,A1
03:00000CD6 7000            	   151:     moveq   #0,D0
03:00000CD8 3E3C003F        	   152:     move.w  #63,D7
                            	   153: .clear_loop:
03:00000CDC 32C0            	   154:     move.w  D0,(A1)+
03:00000CDE 51CFFFFC        	   155:     dbra    D7,.clear_loop
                            	   156: 
                            	   157:     ; LevelInfoOW begins with an NES palette transfer header:
                            	   158:     ;   $3F,$00,$20,<16 BG palette bytes>...
                            	   159:     ; Skip the 3-byte header and load the 4 BG sub-palettes.
03:00000CE2 41FA265D        	   160:     lea     LevelInfoOW+3(pc),A0
03:00000CE6 43F900FF0C00    	   161:     lea     (ROOM_PALETTE_BUFFER).l,A1
03:00000CEC 45FA0630        	   162:     lea     NesColorToGenesisCRAM(pc),A2
03:00000CF0 7C00            	   163:     moveq   #0,D6               ; palette line index
                            	   164: .palette_loop:
03:00000CF2 3A06            	   165:     move.w  D6,D5
03:00000CF4 EB4D            	   166:     lsl.w   #5,D5               ; 16 colors x 2 bytes
03:00000CF6 47F15000        	   167:     lea     0(A1,D5.w),A3
03:00000CFA 7E03            	   168:     moveq   #3,D7
                            	   169: .color_loop:
03:00000CFC 7000            	   170:     moveq   #0,D0
03:00000CFE 1018            	   171:     move.b  (A0)+,D0
03:00000D00 D040            	   172:     add.w   D0,D0
03:00000D02 36F20000        	   173:     move.w  0(A2,D0.w),(A3)+
03:00000D06 51CFFFF4        	   174:     dbra    D7,.color_loop
03:00000D0A 5246            	   175:     addq.w  #1,D6
03:00000D0C 0C460004        	   176:     cmpi.w  #4,D6
03:00000D10 65E0            	   177:     bcs.s   .palette_loop
                            	   178: 
