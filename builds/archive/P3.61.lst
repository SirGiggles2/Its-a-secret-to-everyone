03:00000C3E 0C400001        	    97:     cmpi.w  #$0001,D0
03:00000C42 670C            	    98:     beq.s   .cave1
03:00000C44 0C400002        	    99:     cmpi.w  #$0002,D0
03:00000C48 670C            	   100:     beq.s   .cave2
