                            	   123: Room_ConvertOverworldPalette:
03:00000C76 33FC021000FF0042	   124:     move.w  #$0210,(BOOT_DETAIL).l
                            	   125: 
                            	   126:     ; Genesis CRAM is organized as 4 palette lines of 16 colors each.
                            	   127:     ; The NES overworld BG data gives us 4 sub-palettes of 4 colors each, so
                            	   128:     ; spread them into color slots 0-3 of Genesis palette lines 0-3 and leave
                            	   129:     ; the remaining entries clear.
03:00000C7E 43F900FF0C00    	   130:     lea     (ROOM_PALETTE_BUFFER).l,A1
03:00000C84 7000            	   131:     moveq   #0,D0
03:00000C86 3E3C003F        	   132:     move.w  #63,D7
                            	   133: .clear_loop:
03:00000C8A 32C0            	   134:     move.w  D0,(A1)+
03:00000C8C 51CFFFFC        	   135:     dbra    D7,.clear_loop
                            	   136: 
                            	   137:     ; LevelInfoOW begins with an NES palette transfer header:
                            	   138:     ;   $3F,$00,$20,<16 BG palette bytes>...
                            	   139:     ; Skip the 3-byte header and load the 4 BG sub-palettes.
03:00000C90 41FA17C3        	   140:     lea     LevelInfoOW+3(pc),A0
03:00000C94 43F900FF0C00    	   141:     lea     (ROOM_PALETTE_BUFFER).l,A1
03:00000C9A 45FA0406        	   142:     lea     NesColorToGenesisCRAM(pc),A2
03:00000C9E 7C00            	   143:     moveq   #0,D6               ; palette line index
                            	   144: .palette_loop:
03:00000CA0 3A06            	   145:     move.w  D6,D5
03:00000CA2 EB4D            	   146:     lsl.w   #5,D5               ; 16 colors x 2 bytes
03:00000CA4 47F15000        	   147:     lea     0(A1,D5.w),A3
