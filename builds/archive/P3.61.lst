03:00002E5A 6100D62C        	    11:     bsr     Renderer_LoadCRAM
03:00002E5E 6104            	    12:     bsr     .LoadDiagnosticTiles
03:00002E60 6120            	    13:     bsr     .FillPlaneAWithGradient
03:00002E62 4E75            	    14:     rts
                            	    15: 
