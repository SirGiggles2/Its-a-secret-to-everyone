03:00000C0E 3E3C0009        	   111:     move.w  #$0009,D7
                            	   112: .fill_inner:
03:00000C12 3007            	   113:     move.w  D7,D0
03:00000C14 02400007        	   114:     andi.w  #$0007,D0
03:00000C18 6728            	   115:     beq.s   .next_inner
03:00000C1A 0C400007        	   116:     cmpi.w  #$0007,D0
03:00000C1E 6722            	   117:     beq.s   .next_inner
03:00000C20 0C470021        	   118:     cmpi.w  #$0021,D7
03:00000C24 6406            	   119:     bcc.s   .combine_inner_outer
03:00000C26 11827000        	   120:     move.b  D2,0(A0,D7.w)
03:00000C2A 6016            	   121:     bra.s   .next_inner
                            	   122: .combine_inner_outer:
03:00000C2C 7000            	   123:     moveq   #0,D0
03:00000C2E 10307000        	   124:     move.b  0(A0,D7.w),D0
03:00000C32 024000F0        	   125:     andi.w  #$00F0,D0
03:00000C36 3202            	   126:     move.w  D2,D1
03:00000C38 0241000F        	   127:     andi.w  #$000F,D1
03:00000C3C 8041            	   128:     or.w    D1,D0
03:00000C3E 11807000        	   129:     move.b  D0,0(A0,D7.w)
                            	   130: .next_inner:
