03:00000BFA 02410003        	   105:     andi.w  #$0003,D1
03:00000BFE 43FA02D6        	   106:     lea     RoomPaletteSelectorToNTAttr(pc),A1
03:00000C02 7400            	   107:     moveq   #0,D2
03:00000C04 14311000        	   108:     move.b  0(A1,D1.w),D2
                            	   109: 
