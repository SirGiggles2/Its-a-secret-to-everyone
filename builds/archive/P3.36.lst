                            	   174:     include "rooms.asm"

Source: "rooms.asm"
                            	     1: ; =============================================================================
                            	     2: ; Room Loader
                            	     3: ; =============================================================================
                            	     4: ; Phase 3 bootstrap:
                            	     5: ; - load the real overworld start room ($77)
                            	     6: ; - decode the original compressed column format at runtime
                            	     7: ; - convert extracted NES palette bytes to Genesis CRAM words
                            	     8: ; - queue a 32x22 room tilemap onto Plane A
                            	     9: ; =============================================================================
                            	    10: 
                            	    11: ROOM_SQUARE_COLS         equ 16
                            	    12: ROOM_SQUARE_ROWS         equ 11
                            	    13: ROOM_TILE_COLS           equ 32
                            	    14: ROOM_TILE_ROWS           equ 22
                            	    15: ROOM_TILE_ROW_STRIDE     equ ROOM_TILE_COLS*2
                            	    16: ROOM_PLAYAREA_ATTR_COLS  equ 8
                            	    17: ROOM_PLAYAREA_ATTR_ROWS  equ 6
                            	    18: ROOM_PLAYAREA_ATTR_COUNT equ ROOM_PLAYAREA_ATTR_COLS*ROOM_PLAYAREA_ATTR_ROWS
                            	    19: ROOM_START_ROOM_OFFSET   equ $002F
                            	    20: ROOM_SHORTCUT_POS_OFFSET equ $0029
                            	    21: 
                            	    22: Room_LoadStartingOverworld:
03:00000B4A 7000            	    23:     moveq   #0,D0
03:00000B4C 103A18AB        	    24:     move.b  LevelInfoOW+ROOM_START_ROOM_OFFSET(pc),D0
                            	    25:     bra     Room_LoadOverworldById
                            	    26: 
                            	    27: ; D0 = overworld room id
                            	    28: Room_LoadOverworldById:
03:00000B50 33FC020000FF0040	    29:     move.w  #$0200,(BOOT_STAGE).l
03:00000B58 33C000FF003C    	    30:     move.w  D0,(CURRENT_ROOM_ID).l
03:00000B5E 6132            	    31:     bsr     Room_ConvertOverworldPalette
03:00000B60 33FC020100FF0040	    32:     move.w  #$0201,(BOOT_STAGE).l
03:00000B68 6100008A        	    33:     bsr     Room_BuildOverworldPlayAreaAttrs
03:00000B6C 33FC020200FF0040	    34:     move.w  #$0202,(BOOT_STAGE).l
03:00000B74 6100012C        	    35:     bsr     Room_BuildOverworldTilemap
03:00000B78 61000390        	    36:     bsr     Room_ApplyOverworldShortcutVisibility
03:00000B7C 33FC020300FF0040	    37:     move.w  #$0203,(BOOT_STAGE).l
03:00000B84 61000332        	    38:     bsr     Room_QueueOverworldTilemap
03:00000B88 33FC020400FF0040	    39:     move.w  #$0204,(BOOT_STAGE).l
03:00000B90 4E75            	    40:     rts
                            	    41: 
                            	    42: Room_ConvertOverworldPalette:
03:00000B92 33FC021000FF0042	    43:     move.w  #$0210,(BOOT_DETAIL).l
                            	    44: 
                            	    45:     ; Genesis CRAM is organized as 4 palette lines of 16 colors each.
                            	    46:     ; The NES overworld BG data gives us 4 sub-palettes of 4 colors each, so
                            	    47:     ; spread them into color slots 0-3 of Genesis palette lines 0-3 and leave
                            	    48:     ; the remaining entries clear.
03:00000B9A 43F900FF0C00    	    49:     lea     (ROOM_PALETTE_BUFFER).l,A1
03:00000BA0 7000            	    50:     moveq   #0,D0
03:00000BA2 3E3C003F        	    51:     move.w  #63,D7
                            	    52: .clear_loop:
03:00000BA6 32C0            	    53:     move.w  D0,(A1)+
03:00000BA8 51CFFFFC        	    54:     dbra    D7,.clear_loop
                            	    55: 
                            	    56:     ; LevelInfoOW begins with an NES palette transfer header:
                            	    57:     ;   $3F,$00,$20,<16 BG palette bytes>...
                            	    58:     ; Skip the 3-byte header and load the 4 BG sub-palettes.
03:00000BAC 41FA181F        	    59:     lea     LevelInfoOW+3(pc),A0
03:00000BB0 43F900FF0C00    	    60:     lea     (ROOM_PALETTE_BUFFER).l,A1
03:00000BB6 45FA0462        	    61:     lea     NesColorToGenesisCRAM(pc),A2
03:00000BBA 7C00            	    62:     moveq   #0,D6               ; palette line index
                            	    63: .palette_loop:
03:00000BBC 3A06            	    64:     move.w  D6,D5
03:00000BBE EB4D            	    65:     lsl.w   #5,D5               ; 16 colors x 2 bytes
03:00000BC0 47F15000        	    66:     lea     0(A1,D5.w),A3
03:00000BC4 7E03            	    67:     moveq   #3,D7
                            	    68: .color_loop:
03:00000BC6 7000            	    69:     moveq   #0,D0
03:00000BC8 1018            	    70:     move.b  (A0)+,D0
03:00000BCA D040            	    71:     add.w   D0,D0
03:00000BCC 36F20000        	    72:     move.w  0(A2,D0.w),(A3)+
03:00000BD0 51CFFFF4        	    73:     dbra    D7,.color_loop
03:00000BD4 5246            	    74:     addq.w  #1,D6
03:00000BD6 0C460004        	    75:     cmpi.w  #4,D6
03:00000BDA 65E0            	    76:     bcs.s   .palette_loop
                            	    77: 
                            	    78:     ; Queue the full CRAM image so palette lines 0-3 land in their correct
                            	    79:     ; 16-color slots.
03:00000BDC 41F900FF0C00    	    80:     lea     (ROOM_PALETTE_BUFFER).l,A0
03:00000BE2 3E3C003F        	    81:     move.w  #63,D7
03:00000BE6 6100FB20        	    82:     bsr     Renderer_QueueCRAMWords
03:00000BEA 33FC021100FF0042	    83:     move.w  #$0211,(BOOT_DETAIL).l
03:00000BF2 4E75            	    84:     rts
                            	    85: 
