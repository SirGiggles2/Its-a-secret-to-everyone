03:00000BF4 33FC021200FF0042	    87:     move.w  #$0212,(BOOT_DETAIL).l
03:00000BFC 303900FF003C    	    88:     move.w  (CURRENT_ROOM_ID).l,D0
                            	    89: 
03:00000C02 41FA08CE        	    90:     lea     RoomAttrsOW_A(pc),A0
03:00000C06 7200            	    91:     moveq   #0,D1
03:00000C08 12300000        	    92:     move.b  0(A0,D0.w),D1
03:00000C0C 02410003        	    93:     andi.w  #$0003,D1
03:00000C10 43FA038C        	    94:     lea     RoomPaletteSelectorToNTAttr(pc),A1
03:00000C14 7400            	    95:     moveq   #0,D2
03:00000C16 14311000        	    96:     move.b  0(A1,D1.w),D2
                            	    97: 
03:00000C1A 41F900FF0B80    	    98:     lea     (ROOM_PLAYAREA_ATTR_BUFFER).l,A0
03:00000C20 3E3C002F        	    99:     move.w  #ROOM_PLAYAREA_ATTR_COUNT-1,D7
                            	   100: .fill_outer:
03:00000C24 10C2            	   101:     move.b  D2,(A0)+
03:00000C26 51CFFFFC        	   102:     dbra    D7,.fill_outer
                            	   103: 
03:00000C2A 41FA0926        	   104:     lea     RoomAttrsOW_B(pc),A0
03:00000C2E 7200            	   105:     moveq   #0,D1
03:00000C30 12300000        	   106:     move.b  0(A0,D0.w),D1
03:00000C34 02410003        	   107:     andi.w  #$0003,D1
03:00000C38 43FA0364        	   108:     lea     RoomPaletteSelectorToNTAttr(pc),A1
03:00000C3C 7400            	   109:     moveq   #0,D2
03:00000C3E 14311000        	   110:     move.b  0(A1,D1.w),D2
                            	   111: 
03:00000C42 41F900FF0B80    	   112:     lea     (ROOM_PLAYAREA_ATTR_BUFFER).l,A0
03:00000C48 3E3C0009        	   113:     move.w  #$0009,D7
                            	   114: .fill_inner:
03:00000C4C 3007            	   115:     move.w  D7,D0
03:00000C4E 02400007        	   116:     andi.w  #$0007,D0
03:00000C52 6728            	   117:     beq.s   .next_inner
03:00000C54 0C400007        	   118:     cmpi.w  #$0007,D0
03:00000C58 6722            	   119:     beq.s   .next_inner
03:00000C5A 0C470021        	   120:     cmpi.w  #$0021,D7
03:00000C5E 6406            	   121:     bcc.s   .combine_inner_outer
03:00000C60 11827000        	   122:     move.b  D2,0(A0,D7.w)
03:00000C64 6016            	   123:     bra.s   .next_inner
                            	   124: .combine_inner_outer:
03:00000C66 7000            	   125:     moveq   #0,D0
03:00000C68 10307000        	   126:     move.b  0(A0,D7.w),D0
03:00000C6C 024000F0        	   127:     andi.w  #$00F0,D0
03:00000C70 3202            	   128:     move.w  D2,D1
03:00000C72 0241000F        	   129:     andi.w  #$000F,D1
03:00000C76 8041            	   130:     or.w    D1,D0
03:00000C78 11807000        	   131:     move.b  D0,0(A0,D7.w)
                            	   132: .next_inner:
03:00000C7C 5247            	   133:     addq.w  #1,D7
03:00000C7E 0C470027        	   134:     cmpi.w  #$0027,D7
03:00000C82 65C8            	   135:     bcs.s   .fill_inner
03:00000C84 33FC021300FF0042	   136:     move.w  #$0213,(BOOT_DETAIL).l
03:00000C8C 4E75            	   137:     rts
