                            	     1: ; =============================================================================
                            	     2: ; Renderer - Genesis VDP primitives
                            	     3: ; =============================================================================
                            	     4: ; Core VRAM/CRAM/tilemap operations. No game-specific rendering here.
                            	     5: ; Game systems will call these primitives to draw their scenes.
                            	     6: ;
                            	     7: ; Phase 2 will extend this with:
                            	     8: ;   - Sprite table manager (80-slot RAM table, DMA to VRAM)
                            	     9: ;   - DMA-based VBlank transfer queue
                            	    10: ;   - Room scrolling (column/row tilemap updates)
                            	    11: ; =============================================================================
                            	    12: 
