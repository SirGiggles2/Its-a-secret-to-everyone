03:0000045A 7000            	    18:     moveq   #0,D0
03:0000045C 3E3C7FFF        	    19:     move.w  #32767,D7
                            	    20: .clear_loop:
03:00000460 33C000C00000    	    21:     move.w  D0,(VDP_DATA).l
