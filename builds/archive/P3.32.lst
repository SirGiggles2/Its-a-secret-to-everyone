                            	   173:     include "rooms.asm"

Source: "rooms.asm"
                            	     1: ; =============================================================================
                            	     2: ; Room Loader
                            	     3: ; =============================================================================
                            	     4: ; Phase 3 bootstrap:
                            	     5: ; - load the real overworld start room ($77)
                            	     6: ; - decode the original compressed column format at runtime
                            	     7: ; - convert extracted NES palette bytes to Genesis CRAM words
                            	     8: ; - queue a 32x22 room tilemap onto Plane A
                            	     9: ; =============================================================================
                            	    10: 
                            	    11: ROOM_SQUARE_COLS         equ 16
                            	    12: ROOM_SQUARE_ROWS         equ 11
                            	    13: ROOM_TILE_COLS           equ 32
                            	    14: ROOM_TILE_ROWS           equ 22
                            	    15: ROOM_TILE_ROW_STRIDE     equ ROOM_TILE_COLS*2
                            	    16: ROOM_PLAYAREA_ATTR_COLS  equ 8
                            	    17: ROOM_PLAYAREA_ATTR_ROWS  equ 6
                            	    18: ROOM_PLAYAREA_ATTR_COUNT equ ROOM_PLAYAREA_ATTR_COLS*ROOM_PLAYAREA_ATTR_ROWS
                            	    19: ROOM_START_ROOM_OFFSET   equ $002F
                            	    20: 
                            	    21: Room_LoadStartingOverworld:
03:00000B14 7000            	    22:     moveq   #0,D0
03:00000B16 103A1819        	    23:     move.b  LevelInfoOW+ROOM_START_ROOM_OFFSET(pc),D0
                            	    24:     bra     Room_LoadOverworldById
                            	    25: 
                            	    26: ; D0 = overworld room id
                            	    27: Room_LoadOverworldById:
03:00000B1A 33FC020000FF0040	    28:     move.w  #$0200,(BOOT_STAGE).l
03:00000B22 33C000FF003C    	    29:     move.w  D0,(CURRENT_ROOM_ID).l
03:00000B28 612E            	    30:     bsr     Room_ConvertOverworldPalette
03:00000B2A 33FC020100FF0040	    31:     move.w  #$0201,(BOOT_STAGE).l
03:00000B32 61000086        	    32:     bsr     Room_BuildOverworldPlayAreaAttrs
03:00000B36 33FC020200FF0040	    33:     move.w  #$0202,(BOOT_STAGE).l
03:00000B3E 61000128        	    34:     bsr     Room_BuildOverworldTilemap
03:00000B42 33FC020300FF0040	    35:     move.w  #$0203,(BOOT_STAGE).l
03:00000B4A 61000332        	    36:     bsr     Room_QueueOverworldTilemap
03:00000B4E 33FC020400FF0040	    37:     move.w  #$0204,(BOOT_STAGE).l
03:00000B56 4E75            	    38:     rts
                            	    39: 
                            	    40: Room_ConvertOverworldPalette:
03:00000B58 33FC021000FF0042	    41:     move.w  #$0210,(BOOT_DETAIL).l
                            	    42: 
                            	    43:     ; Genesis CRAM is organized as 4 palette lines of 16 colors each.
                            	    44:     ; The NES overworld BG data gives us 4 sub-palettes of 4 colors each, so
                            	    45:     ; spread them into color slots 0-3 of Genesis palette lines 0-3 and leave
                            	    46:     ; the remaining entries clear.
03:00000B60 43F900FF0C00    	    47:     lea     (ROOM_PALETTE_BUFFER).l,A1
03:00000B66 7000            	    48:     moveq   #0,D0
03:00000B68 3E3C003F        	    49:     move.w  #63,D7
                            	    50: .clear_loop:
03:00000B6C 32C0            	    51:     move.w  D0,(A1)+
03:00000B6E 51CFFFFC        	    52:     dbra    D7,.clear_loop
                            	    53: 
                            	    54:     ; LevelInfoOW begins with an NES palette transfer header:
                            	    55:     ;   $3F,$00,$20,<16 BG palette bytes>...
                            	    56:     ; Skip the 3-byte header and load the 4 BG sub-palettes.
03:00000B72 41FA1791        	    57:     lea     LevelInfoOW+3(pc),A0
03:00000B76 43F900FF0C00    	    58:     lea     (ROOM_PALETTE_BUFFER).l,A1
03:00000B7C 45FA03D4        	    59:     lea     NesColorToGenesisCRAM(pc),A2
03:00000B80 7C00            	    60:     moveq   #0,D6               ; palette line index
                            	    61: .palette_loop:
03:00000B82 3A06            	    62:     move.w  D6,D5
03:00000B84 EB4D            	    63:     lsl.w   #5,D5               ; 16 colors x 2 bytes
03:00000B86 47F15000        	    64:     lea     0(A1,D5.w),A3
03:00000B8A 7E03            	    65:     moveq   #3,D7
                            	    66: .color_loop:
03:00000B8C 7000            	    67:     moveq   #0,D0
03:00000B8E 1018            	    68:     move.b  (A0)+,D0
03:00000B90 D040            	    69:     add.w   D0,D0
03:00000B92 36F20000        	    70:     move.w  0(A2,D0.w),(A3)+
03:00000B96 51CFFFF4        	    71:     dbra    D7,.color_loop
03:00000B9A 5246            	    72:     addq.w  #1,D6
03:00000B9C 0C460004        	    73:     cmpi.w  #4,D6
03:00000BA0 65E0            	    74:     bcs.s   .palette_loop
                            	    75: 
                            	    76:     ; Queue the full CRAM image so palette lines 0-3 land in their correct
                            	    77:     ; 16-color slots.
03:00000BA2 41F900FF0C00    	    78:     lea     (ROOM_PALETTE_BUFFER).l,A0
03:00000BA8 3E3C003F        	    79:     move.w  #63,D7
03:00000BAC 6100FB5A        	    80:     bsr     Renderer_QueueCRAMWords
03:00000BB0 33FC021100FF0042	    81:     move.w  #$0211,(BOOT_DETAIL).l
03:00000BB8 4E75            	    82:     rts
                            	    83: 
