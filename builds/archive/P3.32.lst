03:00000BCE 12300000        	    90:     move.b  0(A0,D0.w),D1
03:00000BD2 02410003        	    91:     andi.w  #$0003,D1
03:00000BD6 43FA02FE        	    92:     lea     RoomPaletteSelectorToNTAttr(pc),A1
