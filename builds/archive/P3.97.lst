03:00000E14 1811            	   276:     move.b  (A1),D4
                            	   277: 
                            	   278:     ; Column data contains packed 6-bit tile codes
                            	   279:     ; Each byte contains two 6-bit tile codes (bits 7-2 and bits 5-0)
                            	   280:     ; Use row position to determine which tile code to extract
