                            	   112: ; =============================================================================
                            	   113: ; Input Handling (NES-accurate)
                            	   114: ; =============================================================================
                            	   115: 
                            	   116: Player_HandleInput:
                            	   117:     ; Read joypad state
03:00003F7C 6100C448        	   118:     bsr     READ_JOYPAD
                            	   119:     
                            	   120:     ; Check for sword button
03:00003F80 08000006        	   121:     btst    #PAD_B,D0
03:00003F84 6602            	   122:     bne.s   .check_sword
03:00003F86 6012            	   123:     bra.s   .check_movement
                            	   124:     
                            	   125: .check_sword:
                            	   126:     ; Initiate sword attack if not already attacking
03:00003F88 323900FF0E04    	   127:     move.w  (LINK_STATE).l,D1
03:00003F8E 0C410001        	   128:     cmpi.w  #PLAYER_STATE_ATTACKING,D1
03:00003F92 6706            	   129:     beq.s   .check_movement
03:00003F94 6100012A        	   130:     bsr     Player_StartSwordAttack
03:00003F98 601E            	   131:     bra.s   .done_input
                            	   132:     
                            	   133: .check_movement:
                            	   134:     ; Handle directional input for movement
03:00003F9A 7200            	   135:     moveq   #0,D1
03:00003F9C 08000003        	   136:     btst    #PAD_UP,D0
03:00003FA0 6614            	   137:     bne.s   .has_dir
03:00003FA2 08000002        	   138:     btst    #PAD_DOWN,D0
03:00003FA6 660E            	   139:     bne.s   .has_dir
03:00003FA8 08000001        	   140:     btst    #PAD_LEFT,D0
03:00003FAC 6608            	   141:     bne.s   .has_dir
03:00003FAE 08000000        	   142:     btst    #PAD_RIGHT,D0
03:00003FB2 6602            	   143:     bne.s   .has_dir
03:00003FB4 6002            	   144:     bra.s   .done_input
                            	   145: 
                            	   146: .has_dir:
                            	   147:     
                            	   148:     ; Set direction based on input
03:00003FB6 6102            	   149:     bsr     Player_SetDirectionFromInput
                            	   150:     
                            	   151: .done_input:
03:00003FB8 4E75            	   152:     rts
                            	   153: 
                            	   154: Player_SetDirectionFromInput:
03:00003FBA 08000003        	   155:     btst    #PAD_UP,D0
03:00003FBE 6614            	   156:     bne.s   .set_up
03:00003FC0 08000002        	   157:     btst    #PAD_DOWN,D0
03:00003FC4 6618            	   158:     bne.s   .set_down
03:00003FC6 08000001        	   159:     btst    #PAD_LEFT,D0
03:00003FCA 661C            	   160:     bne.s   .set_left
03:00003FCC 08000000        	   161:     btst    #PAD_RIGHT,D0
03:00003FD0 6620            	   162:     bne.s   .set_right
03:00003FD2 4E75            	   163:     rts
                            	   164:     
                            	   165: .set_up:
03:00003FD4 33FC000000FF0E02	   166:     move.w  #0,(LINK_DIRECTION).l
03:00003FDC 4E75            	   167:     rts
                            	   168: .set_down:
03:00003FDE 33FC000200FF0E02	   169:     move.w  #2,(LINK_DIRECTION).l
03:00003FE6 4E75            	   170:     rts
                            	   171: .set_left:
03:00003FE8 33FC000300FF0E02	   172:     move.w  #3,(LINK_DIRECTION).l
03:00003FF0 4E75            	   173:     rts
                            	   174: .set_right:
03:00003FF2 33FC000100FF0E02	   175:     move.w  #1,(LINK_DIRECTION).l
03:00003FFA 4E75            	   176:     rts
                            	   177: 
                            	   178: ; =============================================================================
                            	   179: ; Movement System (NES-accurate sub-pixel tracking)
                            	   180: ; =============================================================================
                            	   181: 
                            	   182: Player_UpdateMovement:
                            	   183:     ; Only move if directional input is held
03:00003FFC 6100C3C8        	   184:     bsr     READ_JOYPAD
03:00004000 7E00            	   185:     moveq   #0,D7
03:00004002 08000003        	   186:     btst    #PAD_UP,D0
03:00004006 6616            	   187:     bne.s   .has_movement
03:00004008 08000002        	   188:     btst    #PAD_DOWN,D0
03:0000400C 6610            	   189:     bne.s   .has_movement
03:0000400E 08000001        	   190:     btst    #PAD_LEFT,D0
03:00004012 660A            	   191:     bne.s   .has_movement
03:00004014 08000000        	   192:     btst    #PAD_RIGHT,D0
03:00004018 6604            	   193:     bne.s   .has_movement
03:0000401A 6000009E        	   194:     bra     .no_movement
                            	   195: 
                            	   196: .has_movement:
                            	   197:     
                            	   198:     ; Apply NES-accurate movement speed
03:0000401E 323900FF0E00    	   199:     move.w  (LINK_SPEED_Q).l,D1
03:00004024 343900FF0E02    	   200:     move.w  (LINK_DIRECTION).l,D2
                            	   201:     ; NES applies q-speed four times per frame.
03:0000402A 7C03            	   202:     moveq   #3,D6
                            	   203: .apply_qspeed_loop:
03:0000402C 4A42            	   204:     cmpi.w  #0,D2
03:0000402E 676A            	   205:     beq.s   .move_up_once
03:00004030 0C420001        	   206:     cmpi.w  #1,D2
03:00004034 6708            	   207:     beq.s   .move_right_once
03:00004036 0C420002        	   208:     cmpi.w  #2,D2
03:0000403A 673E            	   209:     beq.s   .move_down_once
03:0000403C 6020            	   210:     bra.s   .move_left_once
                            	   211: 
                            	   212: .move_right_once:
03:0000403E 363900FF0E0E    	   213:     move.w  (LINK_POS_FRAC_X).l,D3
03:00004044 D641            	   214:     add.w   D1,D3
03:00004046 0C430100        	   215:     cmpi.w  #$100,D3
03:0000404A 650A            	   216:     bcs.s   .store_right_once
03:0000404C 04430100        	   217:     subi.w  #$100,D3
03:00004050 527900FF0048    	   218:     addq.w  #1,(LINK_X).l
                            	   219: .store_right_once:
03:00004056 33C300FF0E0E    	   220:     move.w  D3,(LINK_POS_FRAC_X).l
03:0000405C 6056            	   221:     bra.s   .apply_next_qspeed
                            	   222: 
                            	   223: .move_left_once:
03:0000405E 363900FF0E0E    	   224:     move.w  (LINK_POS_FRAC_X).l,D3
03:00004064 9641            	   225:     sub.w   D1,D3
03:00004066 6A0A            	   226:     bpl.s   .store_left_once
03:00004068 06430100        	   227:     addi.w  #$0100,D3
03:0000406C 537900FF0048    	   228:     subq.w  #1,(LINK_X).l
                            	   229: .store_left_once:
03:00004072 33C300FF0E0E    	   230:     move.w  D3,(LINK_POS_FRAC_X).l
03:00004078 603A            	   231:     bra.s   .apply_next_qspeed
                            	   232: 
                            	   233: .move_down_once:
03:0000407A 363900FF0E10    	   234:     move.w  (LINK_POS_FRAC_Y).l,D3
03:00004080 D641            	   235:     add.w   D1,D3
03:00004082 0C430100        	   236:     cmpi.w  #$100,D3
03:00004086 650A            	   237:     bcs.s   .store_down_once
03:00004088 04430100        	   238:     subi.w  #$100,D3
03:0000408C 527900FF004A    	   239:     addq.w  #1,(LINK_Y).l
                            	   240: .store_down_once:
03:00004092 33C300FF0E10    	   241:     move.w  D3,(LINK_POS_FRAC_Y).l
03:00004098 601A            	   242:     bra.s   .apply_next_qspeed
                            	   243: 
                            	   244: .move_up_once:
03:0000409A 363900FF0E10    	   245:     move.w  (LINK_POS_FRAC_Y).l,D3
03:000040A0 9641            	   246:     sub.w   D1,D3
03:000040A2 6A0A            	   247:     bpl.s   .store_up_once
03:000040A4 06430100        	   248:     addi.w  #$0100,D3
03:000040A8 537900FF004A    	   249:     subq.w  #1,(LINK_Y).l
                            	   250: .store_up_once:
03:000040AE 33C300FF0E10    	   251:     move.w  D3,(LINK_POS_FRAC_Y).l
                            	   252: 
                            	   253: .apply_next_qspeed:
03:000040B4 51CEFF76        	   254:     dbra    D6,.apply_qspeed_loop
                            	   255:     
                            	   256: .movement_done:
03:000040B8 4E75            	   257:     rts
                            	   258:     
                            	   259: .no_movement:
03:000040BA 4E75            	   260:     rts
