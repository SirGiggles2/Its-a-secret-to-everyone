03:00000CF4 EB4D            	   166:     lsl.w   #5,D5               ; 16 colors x 2 bytes
03:00000CF6 47F15000        	   167:     lea     0(A1,D5.w),A3
03:00000CFA 7E03            	   168:     moveq   #3,D7
                            	   169: .color_loop:
03:00000CFC 7000            	   170:     moveq   #0,D0
03:00000CFE 1018            	   171:     move.b  (A0)+,D0
03:00000D00 D040            	   172:     add.w   D0,D0
03:00000D02 36F20000        	   173:     move.w  0(A2,D0.w),(A3)+
03:00000D06 51CFFFF4        	   174:     dbra    D7,.color_loop
03:00000D0A 5246            	   175:     addq.w  #1,D6
03:00000D0C 0C460004        	   176:     cmpi.w  #4,D6
03:00000D10 65E0            	   177:     bcs.s   .palette_loop
