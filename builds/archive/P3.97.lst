                            	    40: Player_Init:
                            	    41:     ; Initialize Link at overworld starting position
03:00003EB2 33FC004000FF0048	    42:     move.w  #64,(LINK_X).l           ; X = 64 (center of screen)
03:00003EBA 33FC004D00FF004A	    43:     move.w  #77,(LINK_Y).l           ; Y = 77 (overworld starting room)
03:00003EC2 33FC006000FF0E00	    44:     move.w  #LinkQSpeedDefault,(LINK_SPEED_Q).l
03:00003ECA 33FC000000FF0E02	    45:     move.w  #0,(LINK_DIRECTION).l   ; facing down
03:00003ED2 33FC000000FF0E04	    46:     move.w  #PLAYER_STATE_WALKING,(LINK_STATE).l
03:00003EDA 33FC000000FF0E06	    47:     move.w  #0,(LINK_TIMER).l
03:00003EE2 33FC000300FF0E08	    48:     move.w  #3,(LINK_HP).l           ; start with 3 hearts
03:00003EEA 33FC000300FF0E0A	    49:     move.w  #3,(LINK_MAX_HP).l
03:00003EF2 33FC000000FF0E0C	    50:     move.w  #0,(LINK_INVINCIBLE_TIMER).l
                            	    51:     
                            	    52:     ; Clear sub-pixel position
03:00003EFA 33FC000000FF0E0E	    53:     move.w  #0,(LINK_POS_FRAC_X).l
03:00003F02 33FC000000FF0E10	    54:     move.w  #0,(LINK_POS_FRAC_Y).l
03:00003F0A 33FC000000FF0E12	    55:     move.w  #0,(LINK_GRID_OFFSET_X).l
03:00003F12 33FC000000FF0E14	    56:     move.w  #0,(LINK_GRID_OFFSET_Y).l
03:00003F1A 4E75            	    57:     rts
                            	    58: 
                            	    59: ; =============================================================================
                            	    60: ; Player Update - Main Entry Point
                            	    61: ; =============================================================================
                            	    62: 
                            	    63: Player_Update:
                            	    64:     ; Handle state-specific updates
03:00003F1C 303900FF0E04    	    65:     move.w  (LINK_STATE).l,D0
03:00003F22 4A40            	    66:     cmpi.w  #PLAYER_STATE_WALKING,D0
03:00003F24 6726            	    67:     beq.s   .update_walking
03:00003F26 0C400001        	    68:     cmpi.w  #PLAYER_STATE_ATTACKING,D0
03:00003F2A 672C            	    69:     beq.s   .update_attacking
03:00003F2C 0C400002        	    70:     cmpi.w  #PLAYER_STATE_HURT,D0
03:00003F30 672C            	    71:     beq.s   .update_hurt
03:00003F32 0C400003        	    72:     cmpi.w  #PLAYER_STATE_STUNNED,D0
03:00003F36 672C            	    73:     beq.s   .update_stunned
03:00003F38 0C400004        	    74:     cmpi.w  #PLAYER_STATE_ENTER_CAVE,D0
03:00003F3C 672C            	    75:     beq.s   .update_enter_cave
03:00003F3E 0C400005        	    76:     cmpi.w  #PLAYER_STATE_USING_ITEM,D0
03:00003F42 672C            	    77:     beq.s   .update_using_item
03:00003F44 0C400006        	    78:     cmpi.w  #PLAYER_STATE_DEATH,D0
03:00003F48 672C            	    79:     beq.s   .update_death
03:00003F4A 4E75            	    80:     rts
                            	    81: 
                            	    82: .update_walking:
03:00003F4C 612E            	    83:     bsr     Player_HandleInput
03:00003F4E 610000AC        	    84:     bsr     Player_UpdateMovement
03:00003F52 61000168        	    85:     bsr     Player_UpdateCollision
03:00003F56 4E75            	    86:     rts
                            	    87: 
                            	    88: .update_attacking:
03:00003F58 61000178        	    89:     bsr     Player_UpdateAttack
03:00003F5C 4E75            	    90:     rts
                            	    91: 
                            	    92: .update_hurt:
03:00003F5E 61000192        	    93:     bsr     Player_UpdateHurt
03:00003F62 4E75            	    94:     rts
                            	    95: 
                            	    96: .update_stunned:
03:00003F64 6100018E        	    97:     bsr     Player_UpdateStunned
03:00003F68 4E75            	    98:     rts
                            	    99: 
                            	   100: .update_enter_cave:
03:00003F6A 6100018A        	   101:     bsr     Player_UpdateEnterCave
03:00003F6E 4E75            	   102:     rts
                            	   103: 
                            	   104: .update_using_item:
03:00003F70 61000186        	   105:     bsr     Player_UpdateUseItem
03:00003F74 4E75            	   106:     rts
                            	   107: 
                            	   108: .update_death:
03:00003F76 61000182        	   109:     bsr     Player_UpdateDeath
03:00003F7A 4E75            	   110:     rts
