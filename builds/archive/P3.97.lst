Source: "scenes\palette_diagnostic.asm"
                            	     1: ; =============================================================================
                            	     2: ; Palette Diagnostic Scene - Hardware regression test
                            	     3: ; =============================================================================
                            	     4: ; Renders gradient palette bars to verify VDP color output.
                            	     5: ; Keep this scene intact as a baseline sanity check.
                            	     6: ; =============================================================================
                            	     7: 
                            	     8: Scene_PaletteDiagnostic_Init:
03:000040FC 41FA0052        	     9:     lea     PaletteDiagnosticCRAM(pc),A0
03:00004100 3E3C000F        	    10:     move.w  #15,D7
03:00004104 6100C382        	    11:     bsr     Renderer_LoadCRAM
03:00004108 6104            	    12:     bsr     .LoadDiagnosticTiles
03:0000410A 6120            	    13:     bsr     .FillPlaneAWithGradient
03:0000410C 4E75            	    14:     rts
                            	    15: 
                            	    16: .LoadDiagnosticTiles:
03:0000410E 23FC4020000000C0	    17:     move.l  #VRAM_WRITE_TILE1,(VDP_CTRL).l
03:00004116 0004
03:00004118 41FA0056        	    18:     lea     PaletteDiagnosticTileWords(pc),A0
03:0000411C 3E3C000F        	    19:     move.w  #15,D7
                            	    20: .tile_loop:
03:00004120 33D800C00000    	    21:     move.w  (A0)+,(VDP_DATA).l
03:00004126 51CFFFF8        	    22:     dbra    D7,.tile_loop
03:0000412A 4E75            	    23:     rts
                            	    24: 
                            	    25: .FillPlaneAWithGradient:
03:0000412C 23FC4000000200C0	    26:     move.l  #VRAM_WRITE_PLANE_A,(VDP_CTRL).l
03:00004134 0004
03:00004136 3E3C001B        	    27:     move.w  #27,D7
                            	    28: .row_loop:
03:0000413A 3C3C003F        	    29:     move.w  #63,D6
                            	    30: .cell_loop:
03:0000413E 33FC000100C00000	    31:     move.w  #1,(VDP_DATA).l
03:00004146 51CEFFF6        	    32:     dbra    D6,.cell_loop
03:0000414A 51CFFFEE        	    33:     dbra    D7,.row_loop
03:0000414E 4E75            	    34:     rts
                            	    35: 
                            	    36: PaletteDiagnosticCRAM:
03:00004150 0000            	    37:     dc.w $0000
03:00004152 0EEE            	    38:     dc.w $0EEE
03:00004154 000E            	    39:     dc.w $000E
03:00004156 0E00            	    40:     dc.w $0E00
03:00004158 00E0            	    41:     dc.w $00E0
03:0000415A 00EE            	    42:     dc.w $00EE
03:0000415C 0E0E            	    43:     dc.w $0E0E
03:0000415E 0EE0            	    44:     dc.w $0EE0
03:00004160 0888            	    45:     dc.w $0888
03:00004162 0008            	    46:     dc.w $0008
03:00004164 0800            	    47:     dc.w $0800
03:00004166 0080            	    48:     dc.w $0080
03:00004168 0088            	    49:     dc.w $0088
03:0000416A 0808            	    50:     dc.w $0808
03:0000416C 0880            	    51:     dc.w $0880
03:0000416E 0444            	    52:     dc.w $0444
                            	    53: 
                            	    54: PaletteDiagnosticTileWords:
03:00004170 0000            	    55:     dc.w $0000,$0000
03:00004172 0000
03:00004174 1111            	    56:     dc.w $1111,$1111
03:00004176 1111
