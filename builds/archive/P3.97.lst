03:00000E2A 024300F0        	   289:     andi.w  #$00F0,D3          ; Get high 4 bits
03:00000E2E E84B            	   290:     lsr.w   #4,D3              ; Shift to low position
03:00000E30 8443            	   291:     or.w    D3,D2              ; Combine
03:00000E32 0242003F        	   292:     andi.w  #$003F,D2          ; Mask to 6 bits
03:00000E36 6008            	   293:     bra.s   .tile_code_ready
