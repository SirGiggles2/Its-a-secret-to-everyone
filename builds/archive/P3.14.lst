Source: "rooms.asm"
                            	     1: ; =============================================================================
                            	     2: ; Room Loader
                            	     3: ; =============================================================================
                            	     4: ; Phase 3 bootstrap:
                            	     5: ; - load the real overworld start room ($77)
                            	     6: ; - decode the original compressed column format at runtime
                            	     7: ; - convert extracted NES palette bytes to Genesis CRAM words
                            	     8: ; - queue a 32x22 room tilemap onto Plane A
                            	     9: ; =============================================================================
                            	    10: 
                            	    11: ROOM_START_SCREEN         equ $0077
                            	    12: ROOM_SQUARE_COLS         equ 16
                            	    13: ROOM_SQUARE_ROWS         equ 11
                            	    14: ROOM_TILE_COLS           equ 32
                            	    15: ROOM_TILE_ROWS           equ 22
                            	    16: ROOM_TILE_ROW_STRIDE     equ ROOM_TILE_COLS*2
                            	    17: 
                            	    18: Room_LoadStartingOverworld:
03:00000B06 303C0077        	    19:     move.w  #ROOM_START_SCREEN,D0
                            	    20:     bra     Room_LoadOverworldById
                            	    21: 
                            	    22: ; D0 = overworld room id
                            	    23: Room_LoadOverworldById:
03:00000B0A 33FC020000FF0040	    24:     move.w  #$0200,(BOOT_STAGE).l
03:00000B12 33C000FF003C    	    25:     move.w  D0,(CURRENT_ROOM_ID).l
03:00000B18 6120            	    26:     bsr     Room_ConvertOverworldPalette
03:00000B1A 33FC020100FF0040	    27:     move.w  #$0201,(BOOT_STAGE).l
03:00000B22 616A            	    28:     bsr     Room_BuildOverworldTilemap
03:00000B24 33FC020200FF0040	    29:     move.w  #$0202,(BOOT_STAGE).l
03:00000B2C 61000204        	    30:     bsr     Room_QueueOverworldTilemap
03:00000B30 33FC020300FF0040	    31:     move.w  #$0203,(BOOT_STAGE).l
03:00000B38 4E75            	    32:     rts
                            	    33: 
                            	    34: Room_ConvertOverworldPalette:
03:00000B3A 33FC021000FF0042	    35:     move.w  #$0210,(BOOT_DETAIL).l
                            	    36: 
                            	    37:     ; LevelInfoOW begins with an NES palette transfer header:
                            	    38:     ;   $3F,$00,$20,<16 BG palette bytes>...
                            	    39:     ; Skip the 3-byte header and load the 4 BG sub-palettes.
03:00000B42 41FA16C1        	    40:     lea     LevelInfoOW+3(pc),A0
03:00000B46 43F900FF0C00    	    41:     lea     (ROOM_PALETTE_BUFFER).l,A1
03:00000B4C 45FA02B4        	    42:     lea     NesColorToGenesisCRAM(pc),A2
03:00000B50 3E3C000F        	    43:     move.w  #15,D7              ; 4 BG sub-palettes x 4 colors
                            	    44: .convert_loop:
03:00000B54 7000            	    45:     moveq   #0,D0
03:00000B56 1018            	    46:     move.b  (A0)+,D0
03:00000B58 D040            	    47:     add.w   D0,D0
03:00000B5A 32F20000        	    48:     move.w  0(A2,D0.w),(A1)+
03:00000B5E 51CFFFF4        	    49:     dbra    D7,.convert_loop
                            	    50: 
                            	    51:     ; Queue 16 CRAM words -> palette lines 0-3 colors 0-3
03:00000B62 41F900FF0C00    	    52:     lea     (ROOM_PALETTE_BUFFER).l,A0
03:00000B68 3E3C000F        	    53:     move.w  #15,D7
03:00000B6C 6100FB8C        	    54:     bsr     Renderer_QueueCRAMWords
03:00000B70 33FC021100FF0042	    55:     move.w  #$0211,(BOOT_DETAIL).l
03:00000B78 4E75            	    56:     rts
                            	    57: 
