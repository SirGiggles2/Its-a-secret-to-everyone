                            	   286: 
                            	   287: ; --- Upload tile data to arbitrary VRAM byte address: D0 = VRAM address ---
                            	   288: 
                            	   289: Renderer_UploadWordsToVRAM:
03:0000068E 6100FEA4        	   290:     bsr     Renderer_SetVRAMWriteAddress
                            	   291: .word_loop:
03:00000692 33D800C00000    	   292:     move.w  (A0)+,(VDP_DATA).l
03:00000698 51CFFFF8        	   293:     dbra    D7,.word_loop
03:0000069C 4E75            	   294:     rts
                            	   295: 
                            	   296: ; --- Queued VDP writes ---
                            	   297: 
                            	   298: ; Fixed-size queue entry format:
                            	   299: ;   +0  word type
                            	   300: ;   +2  word flags
                            	   301: ;   +4  word row / command high word
                            	   302: ;   +6  word col / command low word
                            	   303: ;   +8  word count - 1
                            	   304: ;   +10 word repeat tile / reserved
                            	   305: ;   +12 long source pointer
                            	   306: 
                            	   307: ; D4 = entry type, D5 = flags, D0 = row/cmd hi, D1 = col/cmd lo
                            	   308: ; D2 = count - 1, D3 = repeat value/reserved, A0 = source pointer
                            	   309: Renderer_QueueTransferEntry:
03:0000069E 3C3900FF000E    	   310:     move.w  (TRANSFER_QUEUE_COUNT).l,D6
03:000006A4 0C460020        	   311:     cmpi.w  #TRANSFER_QUEUE_MAX,D6
03:000006A8 642E            	   312:     bcc.s   .full
                            	   313: 
03:000006AA CCFC0010        	   314:     mulu.w  #TRANSFER_ENTRY_BYTES,D6
03:000006AE 43F900FF0400    	   315:     lea     (TRANSFER_QUEUE_BUFFER).l,A1
03:000006B4 D2C6            	   316:     adda.w  D6,A1
03:000006B6 32C4            	   317:     move.w  D4,(A1)+
03:000006B8 32C5            	   318:     move.w  D5,(A1)+
03:000006BA 32C0            	   319:     move.w  D0,(A1)+
03:000006BC 32C1            	   320:     move.w  D1,(A1)+
