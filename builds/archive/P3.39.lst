03:00000BF8 303900FF003C    	    86:     move.w  (CURRENT_ROOM_ID).l,D0
                            	    87: 
03:00000BFE 41FA0840        	    88:     lea     RoomAttrsOW_A(pc),A0
03:00000C02 7200            	    89:     moveq   #0,D1
03:00000C04 12300000        	    90:     move.b  0(A0,D0.w),D1
03:00000C08 02410003        	    91:     andi.w  #$0003,D1
03:00000C0C 43FA02FE        	    92:     lea     RoomPaletteSelectorToNTAttr(pc),A1
03:00000C10 7400            	    93:     moveq   #0,D2
03:00000C12 14311000        	    94:     move.b  0(A1,D1.w),D2
                            	    95: 
03:00000C16 41F900FF0B80    	    96:     lea     (ROOM_PLAYAREA_ATTR_BUFFER).l,A0
03:00000C1C 3E3C002F        	    97:     move.w  #ROOM_PLAYAREA_ATTR_COUNT-1,D7
                            	    98: .fill_outer:
03:00000C20 10C2            	    99:     move.b  D2,(A0)+
03:00000C22 51CFFFFC        	   100:     dbra    D7,.fill_outer
                            	   101: 
03:00000C26 41FA0898        	   102:     lea     RoomAttrsOW_B(pc),A0
03:00000C2A 7200            	   103:     moveq   #0,D1
03:00000C2C 12300000        	   104:     move.b  0(A0,D0.w),D1
03:00000C30 02410003        	   105:     andi.w  #$0003,D1
03:00000C34 43FA02D6        	   106:     lea     RoomPaletteSelectorToNTAttr(pc),A1
03:00000C38 7400            	   107:     moveq   #0,D2
03:00000C3A 14311000        	   108:     move.b  0(A1,D1.w),D2
                            	   109: 
03:00000C3E 41F900FF0B80    	   110:     lea     (ROOM_PLAYAREA_ATTR_BUFFER).l,A0
03:00000C44 3E3C0009        	   111:     move.w  #$0009,D7
                            	   112: .fill_inner:
03:00000C48 3007            	   113:     move.w  D7,D0
03:00000C4A 02400007        	   114:     andi.w  #$0007,D0
03:00000C4E 6728            	   115:     beq.s   .next_inner
03:00000C50 0C400007        	   116:     cmpi.w  #$0007,D0
03:00000C54 6722            	   117:     beq.s   .next_inner
03:00000C56 0C470021        	   118:     cmpi.w  #$0021,D7
03:00000C5A 6406            	   119:     bcc.s   .combine_inner_outer
03:00000C5C 11827000        	   120:     move.b  D2,0(A0,D7.w)
03:00000C60 6016            	   121:     bra.s   .next_inner
                            	   122: .combine_inner_outer:
03:00000C62 7000            	   123:     moveq   #0,D0
03:00000C64 10307000        	   124:     move.b  0(A0,D7.w),D0
03:00000C68 024000F0        	   125:     andi.w  #$00F0,D0
03:00000C6C 3202            	   126:     move.w  D2,D1
03:00000C6E 0241000F        	   127:     andi.w  #$000F,D1
03:00000C72 8041            	   128:     or.w    D1,D0
03:00000C74 11807000        	   129:     move.b  D0,0(A0,D7.w)
                            	   130: .next_inner:
03:00000C78 5247            	   131:     addq.w  #1,D7
03:00000C7A 0C470027        	   132:     cmpi.w  #$0027,D7
03:00000C7E 65C8            	   133:     bcs.s   .fill_inner
03:00000C80 33FC021300FF0042	   134:     move.w  #$0213,(BOOT_DETAIL).l
03:00000C88 4E75            	   135:     rts
