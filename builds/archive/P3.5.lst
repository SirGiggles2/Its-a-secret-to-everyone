03:00002BD2 3E3C001B        	    27:     move.w  #27,D7
                            	    28: .row_loop:
03:00002BD6 3C3C003F        	    29:     move.w  #63,D6
                            	    30: .cell_loop:
03:00002BDA 33FC000100C00000	    31:     move.w  #1,(VDP_DATA).l
03:00002BE2 51CEFFF6        	    32:     dbra    D6,.cell_loop
03:00002BE6 51CFFFEE        	    33:     dbra    D7,.row_loop
03:00002BEA 4E75            	    34:     rts
