                            	     1: ; =============================================================================
                            	     2: ; Palette Diagnostic Scene - Hardware regression test
                            	     3: ; =============================================================================
                            	     4: ; Renders gradient palette bars to verify VDP color output.
                            	     5: ; Keep this scene intact as a baseline sanity check.
                            	     6: ; =============================================================================
                            	     7: 
                            	     8: Scene_PaletteDiagnostic_Init:
03:00002B98 41FA0052        	     9:     lea     PaletteDiagnosticCRAM(pc),A0
03:00002B9C 3E3C000F        	    10:     move.w  #15,D7
03:00002BA0 6100D8D8        	    11:     bsr     Renderer_LoadCRAM
03:00002BA4 6104            	    12:     bsr     .LoadDiagnosticTiles
03:00002BA6 6120            	    13:     bsr     .FillPlaneAWithGradient
03:00002BA8 4E75            	    14:     rts
                            	    15: 
                            	    16: .LoadDiagnosticTiles:
03:00002BAA 23FC4020000000C0	    17:     move.l  #VRAM_WRITE_TILE1,(VDP_CTRL).l
03:00002BB2 0004
03:00002BB4 41FA0056        	    18:     lea     PaletteDiagnosticTileWords(pc),A0
03:00002BB8 3E3C000F        	    19:     move.w  #15,D7
                            	    20: .tile_loop:
03:00002BBC 33D800C00000    	    21:     move.w  (A0)+,(VDP_DATA).l
03:00002BC2 51CFFFF8        	    22:     dbra    D7,.tile_loop
03:00002BC6 4E75            	    23:     rts
                            	    24: 
