                            	  4561: HandleShotBlocked:
02:000021B2 41EC00AC        	  4562:     lea     ($00AC,A4),A0
02:000021B6 10302000        	  4563:     move.b  (A0,D2.W),D0
02:000021BA E308            	  4564:     lsl.b  #1,D0   ; ASL A
02:000021BC 6474            	  4565:     bcc  SetShotSpreadingState
                            	  4566:     ; This is a magic shot.
                            	  4567:     ;
                            	  4568:     ; If missing the magic book, go deactivate the shot object.
                            	  4569:     ;
02:000021BE 102C0661        	  4570:     move.b  ($0661,A4),D0
02:000021C2 676A            	  4571:     beq  DeactivateShot
                            	  4572:     ; Try to activate a fire object. Temporarily mark the candle
                            	  4573:     ; unused, so it only has to depend on having an empty slot.
                            	  4574:     ;
                            	  4575:     ; If successful, Link's state will have been changed to "using item".
                            	  4576:     ; But we don't want that in this case.
                            	  4577:     ;
                            	  4578:     ; For both these reasons, save state and restore it afterward.
                            	  4579:     ;
02:000021C4 102C00AC        	  4580:     move.b  ($00AC,A4),D0
02:000021C8 1B00            	  4581:     move.b  D0,-(A5)  ; PHA
02:000021CA 102C0513        	  4582:     move.b  ($0513,A4),D0
02:000021CE 1B00            	  4583:     move.b  D0,-(A5)  ; PHA
02:000021D0 7000            	  4584:     moveq   #0,D0
02:000021D2 19400513        	  4585:     move.b  D0,($0513,A4)
02:000021D6 610015B0        	  4586:     bsr     WieldCandle
02:000021DA 101D            	  4587:     move.b  (A5)+,D0  ; PLA
02:000021DC 19400513        	  4588:     move.b  D0,($0513,A4)
02:000021E0 101D            	  4589:     move.b  (A5)+,D0  ; PLA
02:000021E2 194000AC        	  4590:     move.b  D0,($00AC,A4)
                            	  4591:     ; State $21 means that a moving fire was just made.
                            	  4592:     ;
                            	  4593:     ; If it's any another value, then we didn't find an empty slot
                            	  4594:     ; to make a fire. In this case, all that's left to do is to go
                            	  4595:     ; deactivate the shot object.
                            	  4596:     ;
02:000021E6 41EC00AC        	  4597:     lea     ($00AC,A4),A0
02:000021EA 10302000        	  4598:     move.b  (A0,D2.W),D0
02:000021EE 0C000021        	  4599:     cmpi.b  #$21,D0
02:000021F2 6638            	  4600:     bne  DeactivateLinkShot
                            	  4601:     ; Make state $22 for a standing fire.
