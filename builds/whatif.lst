                            	  4809: UpdateBoomerangOrFood:
                            	  4810:     ; If state = 0, then not active. So, return.
                            	  4811:     ;
02:00002348 41EC00AC        	  4812:     lea     ($00AC,A4),A0
02:0000234C 10302000        	  4813:     move.b  (A0,D2.W),D0
02:00002350 67F4            	  4814:     beq  L1F49F_Exit
                            	  4815:     ; If the high bit of state is clear, then go update the boomerang.
                            	  4816:     ;
02:00002352 E308            	  4817:     lsl.b  #1,D0   ; ASL A
02:00002354 640000A8        	  4818:     bcc  UpdateArrowOrBoomerang
                            	  4819:     ; The object is food.
                            	  4820:     ;
                            	  4821:     ; Once the timer has expired, increment the state and set timer to $FF.
                            	  4822:     ; If we reach state $83, then go deactivate the object.
                            	  4823:     ;
                            	  4824:     ; Nothing changes between the states. So, they are used as
                            	  4825:     ; a way to extend the timer. $2FD screen frames in total.
                            	  4826:     ;
02:00002358 10342028        	  4827:     move.b  ($28,A4,D2.W),D0
02:0000235C 6622            	  4828:     bne  _L_z07_UpdateBoomerangOrFood_CheckMonsterType
02:0000235E 41EC00AC        	  4829:     lea     ($00AC,A4),A0
02:00002362 52302000        	  4830:     addq.b  #1,(A0,D2.W)
02:00002366 41EC00AC        	  4831:     lea     ($00AC,A4),A0
02:0000236A 10302000        	  4832:     move.b  (A0,D2.W),D0
02:0000236E 0200000F        	  4833:     andi.b #$0F,D0
02:00002372 0C000003        	  4834:     cmpi.b  #$03,D0
