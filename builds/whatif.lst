                            	  1780: ChangeTileObjTiles:
02:00000E4C 19400005        	  1781:     move.b  D0,($0005,A4)
02:00000E50 1002            	  1782:     move.b  D2,D0
02:00000E52 1B00            	  1783:     move.b  D0,-(A5)  ; PHA
02:00000E54 10342070        	  1784:     move.b  ($70,A4,D2.W),D0
02:00000E58 19400003        	  1785:     move.b  D0,($0003,A4)
02:00000E5C 41EC0084        	  1786:     lea     ($0084,A4),A0
02:00000E60 10302000        	  1787:     move.b  (A0,D2.W),D0
02:00000E64 19400002        	  1788:     move.b  D0,($0002,A4)
02:00000E68 61002900        	  1789:     bsr     MapScreenPosToPpuAddr
02:00000E6C 142C0301        	  1790:     move.b  ($0301,A4),D2
                            	  1791:     ; Two transfer records will be written to the buffer and an end marker.
                            	  1792:     ;
                            	  1793:     ; Each record is 5 bytes and will transfer 2 tiles arranged vertically.
                            	  1794:     ; In total, 11 bytes will be written.
                            	  1795:     ;
                            	  1796:     ; First, write the high byte of PPU address in each record.
                            	  1797:     ;
02:00000E70 1014            	  1798:     move.b  ($0000,A4),D0
02:00000E72 41EC0302        	  1799:     lea     ($0302,A4),A0
02:00000E76 11802000        	  1800:     move.b  D0,(A0,D2.W)
02:00000E7A 41EC0307        	  1801:     lea     ($0307,A4),A0
02:00000E7E 11802000        	  1802:     move.b  D0,(A0,D2.W)
                            	  1803:     ; Write the low address in the first record. In the second record,
                            	  1804:     ; write (low address + 1).
                            	  1805:     ;
02:00000E82 102C0001        	  1806:     move.b  ($0001,A4),D0
02:00000E86 41EC0303        	  1807:     lea     ($0303,A4),A0
02:00000E8A 11802000        	  1808:     move.b  D0,(A0,D2.W)
02:00000E8E 41EC0308        	  1809:     lea     ($0308,A4),A0
02:00000E92 11802000        	  1810:     move.b  D0,(A0,D2.W)
02:00000E96 41EC0308        	  1811:     lea     ($0308,A4),A0
02:00000E9A 52302000        	  1812:     addq.b  #1,(A0,D2.W)
                            	  1813:     ; Write the first tile twice in each record. Patch them later.
                            	  1814:     ;
02:00000E9E 102C0005        	  1815:     move.b  ($0005,A4),D0
02:00000EA2 41EC0305        	  1816:     lea     ($0305,A4),A0
02:00000EA6 11802000        	  1817:     move.b  D0,(A0,D2.W)
02:00000EAA 41EC0306        	  1818:     lea     ($0306,A4),A0
02:00000EAE 11802000        	  1819:     move.b  D0,(A0,D2.W)
02:00000EB2 41EC030A        	  1820:     lea     ($030A,A4),A0
02:00000EB6 11802000        	  1821:     move.b  D0,(A0,D2.W)
02:00000EBA 41EC030B        	  1822:     lea     ($030B,A4),A0
02:00000EBE 11802000        	  1823:     move.b  D0,(A0,D2.W)
                            	  1824:     ; If tile >= $46 and < $F3, add 2 to the tile bytes in the second record.
                            	  1825:     ; Add 1 more to the second byte in each record.
                            	  1826:     ; Here is an example result of this manipulation:
                            	  1827:     ;   record 1: $70, $71
                            	  1828:     ;   record 2: $72, $73
                            	  1829:     ;
02:00000EC2 0C000046        	  1830:     cmpi.b  #$46,D0
02:00000EC6 6530            	  1831:     bcs  _L_z07_ChangeTileObjTiles_SetCountBytes
02:00000EC8 0C0000F3        	  1832:     cmpi.b  #$F3,D0
02:00000ECC 642A            	  1833:     bcc  _L_z07_ChangeTileObjTiles_SetCountBytes
02:00000ECE 023C00EE        	  1834:     andi.b  #$EE,CCR  ; CLC: clear C+X
02:00000ED2 123C0002        	  1835:     move.b  #$02,D1
02:00000ED6 D101            	  1836:     addx.b  D1,D0   ; ADC #$02 (X flag = 6502 C)
02:00000ED8 41EC030A        	  1837:     lea     ($030A,A4),A0
02:00000EDC 11802000        	  1838:     move.b  D0,(A0,D2.W)
02:00000EE0 41EC030B        	  1839:     lea     ($030B,A4),A0
02:00000EE4 11802000        	  1840:     move.b  D0,(A0,D2.W)
02:00000EE8 41EC0306        	  1841:     lea     ($0306,A4),A0
02:00000EEC 52302000        	  1842:     addq.b  #1,(A0,D2.W)
02:00000EF0 41EC030B        	  1843:     lea     ($030B,A4),A0
02:00000EF4 52302000        	  1844:     addq.b  #1,(A0,D2.W)
