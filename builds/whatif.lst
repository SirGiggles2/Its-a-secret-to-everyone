02:00002324 1600            	  4784:     move.b  D0,D3
02:00002326 5303            	  4785:     subq.b  #1,D3
02:00002328 6A00FF36        	  4786:     bpl  _L_z07_SpreadShot_DrawShotCorner
                            	  4787:     ; MULTI: ObjDir -> ObjSwordShotNegativeOffset
