Source: "genesis_shell.asm"
                            	     1: ;==============================================================================
                            	     2: ; genesis_shell.asm — Genesis boot shell (T1 milestone)
                            	     3: ;
                            	     4: ; No Zelda code. Boots, inits VDP with verified H32 register set, clears
                            	     5: ; VRAM, writes a green test color to CRAM[0], turns on the display.
                            	     6: ; Screen should be solid green — use this to confirm VDP init is correct
                            	     7: ; before attaching any NES I/O or translated Zelda code.
                            	     8: ;
                            	     9: ; COLORFIX: VDP register 0 is ALWAYS $8004 (NOT $8000).
                            	    10: ;   bit 2 is reserved and must be 1. Writing $8000 produces dingy/dark
                            	    11: ;   colors on real hardware even when CRAM data is correct.
                            	    12: ;
                            	    13: ; H32 mode: confirmed by Reg 12 = $00 (RS0=bit0=0, RS1=bit7=0).
                            	    14: ;   256 pixels wide, 32 tiles per row.
                            	    15: ;==============================================================================
                            	    16: 
                            	    17: ;==============================================================================
                            	    18: ; Hardware addresses
                            	    19: ;==============================================================================
                            	    20: 
                            	    21: STACK_TOP       equ $00FFFFFE
                            	    22: VDP_DATA        equ $00C00000
                            	    23: VDP_CTRL        equ $00C00004
                            	    24: VERSION_PORT    equ $00A10001
                            	    25: TMSS_PORT       equ $00A14000
                            	    26: Z80_BUSREQ      equ $00A11100
                            	    27: Z80_RESET       equ $00A11200
                            	    28: 
                            	    29: ;==============================================================================
                            	    30: ; NES emulation constants
                            	    31: ;==============================================================================
                            	    32: NES_RAM_BASE    equ $00FF0000   ; Maps NES $0000-$07FF (8 pages × 256 bytes)
                            	    33: NES_RAM_SIZE    equ $0800       ; 2KB NES work RAM
                            	    34: NES_STACK_INIT  equ $00FF0200   ; NES SP=$FF → A5 = NES_RAM+$0100+$FF+1 = $FF0200
                            	    35: PPU_STATE_SIZE  equ $40         ; 64 bytes: PPU ($FF0800-$FF080F) + MMC1 ($FF0810-$FF081F) + CHR buf ($FF0820-$FF083F)
                            	    36: 
                            	    37: ;==============================================================================
                            	    38: ; VDP command long-words (written to VDP_CTRL to set VRAM/CRAM address)
                            	    39: ;==============================================================================
                            	    40: 
                            	    41: VRAM_WRITE_0000 equ $40000000       ; VRAM write to address $0000 (CD=%0100)
                            	    42: CRAM_WRITE_0000 equ $C0000000       ; CRAM write to address $0000 (CD=%1100)
                            	    43: 
                            	    44: ;==============================================================================
                            	    45: ; Genesis CRAM color: ---BBB-GGG-RRR
                            	    46: ;   Bits [11:9]=Blue, [7:5]=Green, [3:1]=Red  (3 bits each)
                            	    47: ;==============================================================================
                            	    48: 
                            	    49: COLOR_GREEN     equ $00E0           ; pure green (G=7 → bits[7:5]=111)
                            	    50: COLOR_BLACK     equ $0000
                            	    51: 
                            	    52: ;==============================================================================
                            	    53: ; VRAM layout
                            	    54: ;
                            	    55: ;   $0000–$AFFF   Tiles (CHR-RAM fills dynamically, space for 1408 tiles)
                            	    56: ;   $B000–$B7FF   Window plane   32×32 × 2 bytes = $800  (HUD strip)
                            	    57: ;   $C000–$CFFF   Plane A        64×32 × 2 bytes = $1000 (main playfield)
                            	    58: ;   $D800–$DA7F   Sprite attr    80 × 8 bytes = $280
                            	    59: ;   $DC00–$DF7F   H-scroll tbl   224 × 4 bytes = $380 (line-scroll mode)
                            	    60: ;   $E000–$EFFF   Plane B        64×32 × 2 bytes = $1000 (transition staging)
                            	    61: ;   $F000–$FFFF   Free / reserved
                            	    62: ;==============================================================================
                            	    63: 
                            	    64: ;==============================================================================
                            	    65: ; $000000 — 68000 Exception Vector Table (64 vectors × 4 bytes = $100 bytes)
                            	    66: ;
                            	    67: ; Vector layout:
                            	    68: ;   0:  Initial SSP
                            	    69: ;   1:  Initial PC (Reset)
                            	    70: ;   2–11: exception handlers
                            	    71: ;   12–23: reserved
                            	    72: ;   24: spurious interrupt
                            	    73: ;   25–27: IRQ level 1–3 auto-vectors
                            	    74: ;   28: IRQ level 4 auto-vector (H-int / HBlank)
                            	    75: ;   29: IRQ level 5 auto-vector
                            	    76: ;   30: IRQ level 6 auto-vector (V-int / VBlank) ← at $000078
                            	    77: ;   31: IRQ level 7 auto-vector
                            	    78: ;   32–63: TRAP + user-defined
                            	    79: ;==============================================================================
                            	    80: 
                            	    81:     org     $000000
                            	    82: 
00:00000000 00FFFFFE        	    83:     dc.l    STACK_TOP           ; vec  0: initial SSP
00:00000004 00000200        	    84:     dc.l    EntryPoint          ; vec  1: initial PC → boot code
00:00000008 00000362        	    85:     dc.l    ExcBusError         ; vec  2: bus error
00:0000000C 00000384        	    86:     dc.l    ExcAddrError        ; vec  3: address error
                            	    87:     rept    20
                            	    88:         dc.l    DefaultException    ; vec 4–23: exceptions + reserved
                            	    89:     endr
