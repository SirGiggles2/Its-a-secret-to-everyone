                            	  4797:     ;
02:00002334 41EC0098        	  4798:     lea     ($0098,A4),A0
02:00002338 10302000        	  4799:     move.b  (A0,D2.W),D0
02:0000233C 0C0000E8        	  4800:     cmpi.b  #$E8,D0
02:00002340 6604            	  4801:     bne  L1F49F_Exit
02:00002342 4EF8222C        	  4802:     jmp     DeactivateLinkShot
