                            	  3476: _L_z07_Walker_Move_ChooseObjDirOrInputDir:
                            	  3477:     ; Summary: Choose object direction or input direction for movement as appropriate.
                            	  3478:     ;
                            	  3479:     ; Player: If there's input, then use input direction when grid offset = 0,
                            	  3480:     ;         or object direction when <> 0.
                            	  3481:     ;
                            	  3482:     ; Other objects: Move in input direction, unless stunned or magic clock is active.
                            	  3483:     ;
                            	  3484:     ; if slot = 0 and grid offset <> 0 then
                            	  3485:     ;   if input dir = 0 then
                            	  3486:     ;     use 0
                            	  3487:     ;   else
                            	  3488:     ;     use object direction
                            	  3489:     ; else
                            	  3490:     ;   if slot <> 0 and (has clock or stunned) then
                            	  3491:     ;     return
                            	  3492:     ;   else
                            	  3493:     ;     if input dir = 0
                            	  3494:     ;       use 0
                            	  3495:     ;     else
                            	  3496:     ;       use input direction
                            	  3497:     ;
