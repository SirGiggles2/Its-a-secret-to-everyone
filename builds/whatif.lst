02:0000232C 41EC0098        	  4792:     lea     ($0098,A4),A0
02:00002330 53302000        	  4793:     subq.b  #1,(A0,D2.W)
                            	  4794:     ; MULTI: ObjDir -> ObjSwordShotNegativeOffset
