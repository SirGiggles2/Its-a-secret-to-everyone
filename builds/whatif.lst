                            	  4751: _L_z07_SpreadShot_NextCorner:
                            	  4752:     ; Prepare to process the next corner.
                            	  4753:     ;
                            	  4754:     ; First, restore X offset [02] and Y offset [03].
                            	  4755:     ;
02:000022F4 101D            	  4756:     move.b  (A5)+,D0  ; PLA
02:000022F6 19400003        	  4757:     move.b  D0,($0003,A4)
02:000022FA 101D            	  4758:     move.b  (A5)+,D0  ; PLA
02:000022FC 19400002        	  4759:     move.b  D0,($0002,A4)
                            	  4760:     ; Take turns negating X offset or Y offset for the next round.
                            	  4761:     ; - First turn:  loop index = 3, negate Y offset [03]
                            	  4762:     ; - Second turn: loop index = 2, negate X offset [02]
                            	  4763:     ; - Third turn:  loop index = 1, negate Y offset [03]
                            	  4764:     ; - Fourth turn: doesn't matter
                            	  4765:     ;
                            	  4766:     ;
                            	  4767:     ; Get the loop index.
02:00002300 101D            	  4768:     move.b  (A5)+,D0  ; PLA
02:00002302 1B00            	  4769:     move.b  D0,-(A5)  ; PHA
02:00002304 1600            	  4770:     move.b  D0,D3
02:00002306 0C030001        	  4771:     cmpi.b  #$01,D3
02:0000230A 6602            	  4772:     bne  _anon_z07_25
02:0000230C 7603            	  4773:     moveq   #3,D3
                            	  4774: _anon_z07_25:
02:0000230E 10343000        	  4775:     move.b  ($00,A4,D3.W),D0
02:00002312 4600            	  4776:     eori.b #$FF,D0
02:00002314 023C00EE        	  4777:     andi.b  #$EE,CCR  ; CLC: clear C+X
02:00002318 123C0001        	  4778:     move.b  #$01,D1
02:0000231C D101            	  4779:     addx.b  D1,D0   ; ADC #$01 (X flag = 6502 C)
02:0000231E 19803000        	  4780:     move.b  D0,($00,A4,D3.W)
                            	  4781:     ; Restore the loop index, decrement it, and loop again if >= 0.
                            	  4782:     ;
