                            	  6517: _L_z07_AnimateLinkObjState_SetMovementFrame1:
                            	  6518:     ; To animate the state, the animation counter had to have
                            	  6519:     ; reached 0. Right after this routine, the counter will be
                            	  6520:     ; rolled over, and the movement frame will be switched.
                            	  6521:     ;
                            	  6522:     ; So, set movement frame to 1 (legs together) at the end of
                            	  6523:     ; the animation here, in order to immediately change it to
                            	  6524:     ; 0 (legs apart) after this.
                            	  6525:     ;
02:00002EC0 7001            	  6526:     moveq   #1,D0
02:00002EC2 194003E4        	  6527:     move.b  D0,($03E4,A4)
02:00002EC6 4E75            	  6528:     rts
                            	  6529: 
                            	  6530:     even
