02:00000CE0 122C0004        	  1573:     move.b  ($0004,A4),D1
02:00000CE4 D101            	  1574:     addx.b  D1,D0   ; ADC $04
02:00000CE6 4A02            	  1575:     cmpi.b  #$00,D2
02:00000CE8 66E6            	  1576:     bne  _L_z07_DrawItemBySlot_WriteSprites
02:00000CEA 0C000002        	  1577:     cmpi.b  #$02,D0
02:00000CEE 66E0            	  1578:     bne  _L_z07_DrawItemBySlot_WriteSprites
02:00000CF0 7620            	  1579:     moveq   #32,D3
