                            	  1546: _L_z07_DrawItemBySlot_WriteSprites:
                            	  1547:     ; We got here in one of three ways:
                            	  1548:     ;
                            	  1549:     ; A. The item flashes. Attribute value 1 or 2 was chosen
                            	  1550:     ;    explicitly.
                            	  1551:     ; B. The item color varies. ItemSlotToPaletteOffsetsOrValues
                            	  1552:     ;    held an offset that was added to base palette attribute
                            	  1553:     ;    passed in [$04]. This corresponds to class 2 items.
                            	  1554:     ; C. Item doesn't change color. ItemSlotToPaletteOffsetsOrValues
                            	  1555:     ;    held absolute attributes.
                            	  1556:     ;
                            	  1557:     ; At this point, A holds the final sprite attributes.
02:00000CD0 7400            	  1558:     moveq   #0,D2
02:00000CD2 1942000C        	  1559:     move.b  D2,($000C,A4)
02:00000CD6 740F            	  1560:     moveq   #15,D2
                            	  1561:     ; Write sprites.
