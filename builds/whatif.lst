02:000027B0 19400004        	  5450:     move.b  D0,($0004,A4)
                            	  5451:     ; TODO: ?
                            	  5452:     ; If base sprite attribute in [04] = 8, then leave [04] as it is.
                            	  5453:     ; Else add the item value of the magic boomerang.
                            	  5454:     ;
                            	  5455:     ; But none of the values in the base sprite attributes array is 8.
                            	  5456:     ;
                            	  5457:     ; As far I can tell, the magic boomerang's item value (0 or 1) in
                            	  5458:     ; the inventory will always be added to the base sprite attribute.
