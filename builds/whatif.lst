                            	  5093: CheckState20:
                            	  5094:     ; If major state <> $20, go check other states.
                            	  5095:     ;
02:0000253A 0C000020        	  5096:     cmpi.b  #$20,D0
02:0000253E 660000AA        	  5097:     bne  CheckState30
                            	  5098:     ; State $2x. Spark.
                            	  5099:     ;
                            	  5100:     ; Change the state to $28, and decrement animation counter.
                            	  5101:     ; If it hasn't reached 0, then go draw and check for collision
                            	  5102:     ; (with Link, if this is a monster's boomerang).
                            	  5103:     ;
                            	  5104:     ; TODO: Why state $28?
                            	  5105:     ; I thought that it was set to $28, so that the animation frame cycle will
                            	  5106:     ; start over again when spinning.
                            	  5107:     ; But when animation counter reaches 0, state will be set to $40.
                            	  5108:     ; If the counter hasn't reached 0, then I don't *think* that
                            	  5109:     ; any drawing code depends on the minor state.
                            	  5110:     ;
02:00002542 7028            	  5111:     moveq   #40,D0
02:00002544 41EC00AC        	  5112:     lea     ($00AC,A4),A0
02:00002548 11802000        	  5113:     move.b  D0,(A0,D2.W)
02:0000254C 41EC03D0        	  5114:     lea     ($03D0,A4),A0
02:00002550 53302000        	  5115:     subq.b  #1,(A0,D2.W)
