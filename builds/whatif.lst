02:00002264 102C0002        	  4675:     move.b  ($0002,A4),D0
02:00002268 1B00            	  4676:     move.b  D0,-(A5)  ; PHA
02:0000226A 102C0003        	  4677:     move.b  ($0003,A4),D0
02:0000226E 1B00            	  4678:     move.b  D0,-(A5)  ; PHA
                            	  4679:     ; Calculate and set sprite attributes for this corner:
                            	  4680:     ;   base attribute OR (frame counter AND 3)
                            	  4681:     ;
                            	  4682:     ; The base attribute defines how to flip the sprite.
                            	  4683:     ; The frame counter makes the shot flash by cycling each
                            	  4684:     ; palette row.
                            	  4685:     ;
02:00002270 102C0015        	  4686:     move.b  ($0015,A4),D0
02:00002274 02000003        	  4687:     andi.b #$03,D0
02:00002278 41F9000020E4    	  4688:     lea     (SwordShotSpreadBaseAttr).l,A0
02:0000227E 12303000        	  4689:     move.b  (A0,D3.W),D1
02:00002282 8001            	  4690:     or.b  D1,D0
02:00002284 610014B2        	  4691:     bsr     Anim_SetSpriteDescriptorAttributes
                            	  4692:     ; Add the object's X (the center of the spread) and the
                            	  4693:     ; current offset in [02] to set sprite X in [00].
                            	  4694:     ;
02:00002288 10342070        	  4695:     move.b  ($70,A4,D2.W),D0
02:0000228C 023C00EE        	  4696:     andi.b  #$EE,CCR  ; CLC: clear C+X
02:00002290 122C0002        	  4697:     move.b  ($0002,A4),D1
02:00002294 D101            	  4698:     addx.b  D1,D0   ; ADC $02
02:00002296 1880            	  4699:     move.b  D0,($0000,A4)
                            	  4700:     ; If sprite X >= object X and sprite X >= $FC, skip this corner.
                            	  4701:     ; Else calculate the distance from object X to sprite X.
