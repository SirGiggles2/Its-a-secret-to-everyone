                            	   526: ;------------------------------------------------------------------------------
                            	   527: ; _oam_dma — $4014 write: OAM DMA transfer.
                            	   528: ;
                            	   529: ; On NES, writing page number P to $4014 copies 256 bytes from CPU page P
                            	   530: ; ($PP00–$PPFF) to OAM.  Zelda writes #$02, meaning copy from $0200–$02FF.
                            	   531: ; NES $0200–$02FF maps to Genesis RAM $FF0200–$FF02FF (NES_RAM_BASE + $0200).
                            	   532: ;
                            	   533: ; T5: Stub — no sprite output yet.  In T7 we'll DMA the data into VDP OAM
                            	   534: ; via the sprite attribute table at VRAM $D800.
                            	   535: ;------------------------------------------------------------------------------
                            	   536: _oam_dma:
02:000005D6 4E75            	   537:     rts
                            	   538: 
                            	   539: ;==============================================================================
                            	   540: ; MMC1 mapper writes ($8000 / $A000 / $C000 / $E000)
                            	   541: ;==============================================================================
                            	   542: ;
                            	   543: ; T11b: real MMC1 shift-register decoder.
                            	   544: ;
                            	   545: ; Protocol: five consecutive writes to a register address.  Each write
                            	   546: ; contributes bit 0 (LSB first) to the 5-bit shift accumulator.  Writing
                            	   547: ; any byte with bit 7 set resets the shift register immediately.  On the
                            	   548: ; 5th valid write the accumulated 5-bit value is stored in the corresponding
                            	   549: ; MMC1 state register and the accumulator resets.
                            	   550: ;
                            	   551: ; MMC1 register map (Genesis RAM, $FF0812–$FF0815):
                            	   552: ;   $8000 writes → MMC1_CTRL  (mirroring, PRG mode, CHR mode)
                            	   553: ;   $A000 writes → MMC1_CHR0  (CHR bank 0)
                            	   554: ;   $C000 writes → MMC1_CHR1  (CHR bank 1)
                            	   555: ;   $E000 writes → MMC1_PRG   (PRG bank + RAM enable)
                            	   556: ;
                            	   557: ; Register contract:
                            	   558: ;   D0.b = write value (NES accumulator, from transpiler)
                            	   559: ;   D1-D3 saved/restored  (D3 = NES Y index — MUST be preserved)
                            	   560: ;   D3 repurposed internally as target register offset (0-3 from MMC1_CTRL)
                            	   561: ;   D1 = bit count (work), D2 = bit value (work)
                            	   562: ;
                            	   563: ; Expected state at LoopForever (T11b probe):
                            	   564: ;   MMC1_CTRL = $0F  (IsrReset → SetMMC1Control($0F))
                            	   565: ;   MMC1_PRG  = $05  (RunGame  → SwitchBank(5))
                            	   566: ;   MMC1_SHIFT = $00, MMC1_COUNT = $00  (reset after each 5th write)
                            	   567: ;==============================================================================
                            	   568: 
                            	   569: _mmc1_write_8000:
02:000005D8 48E77000        	   570:     movem.l D1-D3,-(SP)
02:000005DC 7600            	   571:     moveq   #0,D3                   ; CTRL is at offset 0 from MMC1_CTRL
02:000005DE 6016            	   572:     bra.s   _mmc1_common
                            	   573: 
                            	   574: _mmc1_write_a000:
02:000005E0 48E77000        	   575:     movem.l D1-D3,-(SP)
02:000005E4 7601            	   576:     moveq   #1,D3                   ; CHR0 is at offset 1
02:000005E6 600E            	   577:     bra.s   _mmc1_common
                            	   578: 
                            	   579: _mmc1_write_c000:
02:000005E8 48E77000        	   580:     movem.l D1-D3,-(SP)
02:000005EC 7602            	   581:     moveq   #2,D3                   ; CHR1 is at offset 2
02:000005EE 6006            	   582:     bra.s   _mmc1_common
                            	   583: 
                            	   584: _mmc1_write_e000:
02:000005F0 48E77000        	   585:     movem.l D1-D3,-(SP)
02:000005F4 7603            	   586:     moveq   #3,D3                   ; PRG is at offset 3
                            	   587:     ; fall through to _mmc1_common
                            	   588: 
                            	   589: _mmc1_common:
                            	   590:     ; Check bit 7 — reset strobe
02:000005F6 08000007        	   591:     btst    #7,D0
02:000005FA 6712            	   592:     beq.s   .no_reset
02:000005FC 423900FF0810    	   593:     clr.b   (MMC1_SHIFT).l
02:00000602 423900FF0811    	   594:     clr.b   (MMC1_COUNT).l
02:00000608 4CDF000E        	   595:     movem.l (SP)+,D1-D3
02:0000060C 4E75            	   596:     rts
                            	   597: 
                            	   598: .no_reset:
                            	   599:     ; Shift bit 0 of D0 into position MMC1_COUNT of the accumulator
02:0000060E 123900FF0811    	   600:     move.b  (MMC1_COUNT).l,D1      ; D1.b = current count (0–4)
02:00000614 1400            	   601:     move.b  D0,D2
02:00000616 02020001        	   602:     andi.b  #1,D2                   ; D2.b = bit 0 of write value
02:0000061A E32A            	   603:     lsl.b   D1,D2                   ; D2.b = bit shifted to correct position
02:0000061C 853900FF0810    	   604:     or.b    D2,(MMC1_SHIFT).l       ; accumulate into shift register
                            	   605: 
                            	   606:     ; Increment count; check for completion
02:00000622 523900FF0811    	   607:     addq.b  #1,(MMC1_COUNT).l
02:00000628 0C39000500FF0811	   608:     cmpi.b  #5,(MMC1_COUNT).l
02:00000630 6620            	   609:     bne.s   .mmc1_done              ; not yet 5 bits — wait for more writes
                            	   610: 
                            	   611:     ; 5th write: copy 5-bit shift value to the target state register
02:00000632 143900FF0810    	   612:     move.b  (MMC1_SHIFT).l,D2
02:00000638 0202001F        	   613:     andi.b  #$1F,D2                 ; mask to 5 bits
02:0000063C 41F900FF0812    	   614:     lea     (MMC1_CTRL).l,A0        ; A0 = base of MMC1_CTRL ($FF0812)
02:00000642 11823000        	   615:     move.b  D2,(A0,D3.w)            ; store at MMC1_CTRL + D3 offset
                            	   616: 
                            	   617:     ; Reset accumulator
02:00000646 423900FF0810    	   618:     clr.b   (MMC1_SHIFT).l
02:0000064C 423900FF0811    	   619:     clr.b   (MMC1_COUNT).l
                            	   620: 
                            	   621: .mmc1_done:
02:00000652 4CDF000E        	   622:     movem.l (SP)+,D1-D3
02:00000656 4E75            	   623:     rts
                            	   624: 
