                            	  4649: SpreadShot:
                            	  4650:     ; MULTI: ObjDir -> ObjSwordShotNegativeOffset
                            	  4651:     ;
                            	  4652:     ; The shot is spreading out.
                            	  4653:     ;
                            	  4654:     ; Copy base negative offset in [98][X] to [02] and [03].
                            	  4655:     ; These will be negated appropriately for each corner.
                            	  4656:     ;
02:00002248 41EC0098        	  4657:     lea     ($0098,A4),A0
