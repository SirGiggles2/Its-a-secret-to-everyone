                            	  5388:     ; 2. advance the minor state within a cycle of 8
                            	  5389:     ; 3. see if it's time to play the sound effect, if the boomerang belongs to Link
                            	  5390:     ;
02:0000271E 41EC03D0        	  5391:     lea     ($03D0,A4),A0
