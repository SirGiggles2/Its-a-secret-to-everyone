02:0000229E 650E            	  4705:     bcs  _L_z07_SpreadShot_ReverseSub
02:000022A0 0C0000FC        	  4706:     cmpi.b  #$FC,D0
02:000022A4 644E            	  4707:     bcc  _L_z07_SpreadShot_NextCorner
02:000022A6 003C0011        	  4708:     ori.b   #$11,CCR  ; SEC: set C+X
                            	  4709: ; [SBC unhandled mode=ABS_X] SBC ObjX, X
02:000022AA 4EF822BA        	  4710:     jmp     _L_z07_SpreadShot_CheckDistance
                            	  4711: 
