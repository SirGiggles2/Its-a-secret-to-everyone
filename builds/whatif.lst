                            	  5427: CalcBoomerangFrame:
                            	  5428:     ; The minor state (low 3 bits of state) is used to
                            	  5429:     ; set the right frame in [0C] for this point in the spinning cycle.
                            	  5430:     ;
                            	  5431:     ; Reset [00] and [01]. These are the offsets for boomerang's position.
                            	  5432:     ; In other words, don't offset the coordinate below.
                            	  5433:     ;
02:0000277E 7000            	  5434:     moveq   #0,D0
02:00002780 1880            	  5435:     move.b  D0,($0000,A4)
02:00002782 41EC00AC        	  5436:     lea     ($00AC,A4),A0
02:00002786 10302000        	  5437:     move.b  (A0,D2.W),D0
02:0000278A 0200000F        	  5438:     andi.b #$0F,D0
02:0000278E 1600            	  5439:     move.b  D0,D3
02:00002790 7000            	  5440:     moveq   #0,D0
02:00002792 19400001        	  5441:     move.b  D0,($0001,A4)
02:00002796 41F9000023C6    	  5442:     lea     (BoomerangFrameCycle).l,A0
