00:00000060 000003A6        	    90:     dc.l    DefaultException    ; vec 24: spurious interrupt
00:00000064 000003A6        	    91:     dc.l    DefaultException    ; vec 25: IRQ level 1 (auto)
00:00000068 000003A6        	    92:     dc.l    DefaultException    ; vec 26: IRQ level 2 (EXT)
00:0000006C 000003A6        	    93:     dc.l    DefaultException    ; vec 27: IRQ level 3 (auto)
00:00000070 000003A6        	    94:     dc.l    DefaultException    ; vec 28: IRQ level 4 (H-int)
00:00000074 000003A6        	    95:     dc.l    DefaultException    ; vec 29: IRQ level 5 (auto)
00:00000078 00000352        	    96:     dc.l    VBlankISR           ; vec 30: IRQ level 6 (V-int / VBlank) ←
00:0000007C 000003A6        	    97:     dc.l    DefaultException    ; vec 31: IRQ level 7 (NMI)
