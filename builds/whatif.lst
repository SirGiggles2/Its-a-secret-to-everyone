                            	  1773: ; [F7]: not 0 to switch to bank 4 before returning
                            	  1774: ;
                            	  1775: ;
                            	  1776: ; First, cue the transfer of the 4 tiles to nametable 0.
                            	  1777: ;
                            	  1778: ; [05] holds the first tile.
