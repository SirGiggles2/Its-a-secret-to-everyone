02:000022BA 0C000020        	  4722:     cmpi.b  #$20,D0
02:000022BE 6434            	  4723:     bcc  _L_z07_SpreadShot_NextCorner
                            	  4724:     ; Add the object's Y (the center of the spread) and the
                            	  4725:     ; current offset in [03] to set sprite Y in [01].
                            	  4726:     ;
02:000022C0 41EC0084        	  4727:     lea     ($0084,A4),A0
02:000022C4 10302000        	  4728:     move.b  (A0,D2.W),D0
