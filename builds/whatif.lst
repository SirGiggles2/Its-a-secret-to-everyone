02:00002254 19400003        	  4660:     move.b  D0,($0003,A4)
                            	  4661:     ; Reset [0F] to not flip horizontally.
                            	  4662:     ;
02:00002258 7000            	  4663:     moveq   #0,D0
02:0000225A 1940000F        	  4664:     move.b  D0,($000F,A4)
                            	  4665:     ; Loop 4 times to draw each corner of the spreading sword shot.
                            	  4666:     ; The corners are: top-left, bottom-left, bottom-right, top-right
                            	  4667:     ;
02:0000225E 7603            	  4668:     moveq   #3,D3
                            	  4669:     even
                            	  4670: _L_z07_SpreadShot_DrawShotCorner:
02:00002260 1003            	  4671:     move.b  D3,D0
02:00002262 1B00            	  4672:     move.b  D0,-(A5)  ; PHA
                            	  4673:     ; Save offset X [02] and Y offset [03].
