                            	  4742: _L_z07_SpreadShot_Draw:
                            	  4743:     ; Draw the corner.
                            	  4744:     ; Pass [0C] = frame 2 (spread shot), Y = $23 (sword 2).
                            	  4745:     ;
02:000022E8 7002            	  4746:     moveq   #2,D0
