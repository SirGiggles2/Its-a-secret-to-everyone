02:000022B2 003C0011        	  4715:     ori.b   #$11,CCR  ; SEC: set C+X
02:000022B6 1214            	  4716:     move.b  ($0000,A4),D1
02:000022B8 9101            	  4717:     subx.b  D1,D0   ; SBC $00
                            	  4718:     even
                            	  4719: _L_z07_SpreadShot_CheckDistance:
                            	  4720:     ; If distance >= $20, skip this corner.
