                            	  4631: SetShotSpreadingState:
                            	  4632:     ; MULTI: ObjDir -> ObjSwordShotNegativeOffset
                            	  4633:     ;
                            	  4634:     ; Set the state to spreading out (low bit is set).
                            	  4635:     ;
                            	  4636:     ; Set [98][X] to base negative offset -2. This is how far the left
                            	  4637:     ; corners will be shown relative to the center point at object X, Y.
                            	  4638:     ; The right corners will be shown 2 pixels in the opposite direction
                            	  4639:     ; of the center point.
                            	  4640:     ;
02:00002232 41EC00AC        	  4641:     lea     ($00AC,A4),A0
02:00002236 52302000        	  4642:     addq.b  #1,(A0,D2.W)
02:0000223A 103C00FE        	  4643:     move.b  #$FE,D0
02:0000223E 41EC0098        	  4644:     lea     ($0098,A4),A0
02:00002242 11802000        	  4645:     move.b  D0,(A0,D2.W)
02:00002246 4E75            	  4646:     rts
