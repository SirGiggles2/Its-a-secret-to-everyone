                            	   652: ; _indirect_stub — JMP (abs) indirect placeholder.
                            	   653: ; Called when the transpiler can't resolve an indirect jump target at
                            	   654: ; translate-time.  Halts via an infinite bra so BizHawk shows PC stuck here.
                            	   655: ; In T9+ these will be replaced by computed dispatch tables.
                            	   656: ;==============================================================================
                            	   657: _indirect_stub:
02:0000065A 60FE            	   658:     bra.s   _indirect_stub          ; spin — caught as deliberate halt in T9+
                            	   659: 
                            	   660: ;==============================================================================
                            	   661: ; _m68k_tablejump — M68K-native replacement for the NES JSR-trick TableJump.
                            	   662: ;
                            	   663: ; On NES, "JSR TableJump" is a JSR-trick: the bytes after the JSR are a
                            	   664: ; table of 16-bit vectors.  TableJump pops the return address from the 6502
                            	   665: ; stack to find the table base, then jumps through it using the value in A.
                            	   666: ;
                            	   667: ; In M68K, BSR pushes the return address (= table base) onto A7 (M68K stack),
                            	   668: ; not A5 (our NES stack).  The original TableJump pulled from A5 (zeros),
                            	   669: ; constructing a bogus NES address and jumping into garbage.
                            	   670: ;
                            	   671: ; This replacement correctly pops the M68K return address as the dc.l table
                            	   672: ; base, indexes by D0.b × 4, and dispatches.
                            	   673: ;
                            	   674: ; Calling convention:
                            	   675: ;   D0.b = mode index
                            	   676: ;   (A7)  = base address of the dc.l jump table (pushed by BSR)
                            	   677: ;   Jumps directly to the selected target (does not RTS).
                            	   678: ;==============================================================================
                            	   679: _m68k_tablejump:
02:0000065C 205F            	   680:     movea.l (SP)+,A0        ; pop M68K return address = dc.l table base
02:0000065E C07C00FF        	   681:     and.w   #$00FF,D0       ; zero-extend mode byte → word
02:00000662 E548            	   682:     lsl.w   #2,D0           ; D0.w = index × 4  (each dc.l = 4 bytes)
02:00000664 20700000        	   683:     movea.l (A0,D0.W),A0   ; load 32-bit target address from table
02:00000668 4ED0            	   684:     jmp     (A0)            ; dispatch (no return)
                            	   685: 

