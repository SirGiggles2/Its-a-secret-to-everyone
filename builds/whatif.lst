                            	   640: _apu_write_400e:
                            	   641: _apu_write_400f:
                            	   642: _apu_write_4010:
                            	   643: _apu_write_4011:
                            	   644: _apu_write_4012:
                            	   645: _apu_write_4013:
                            	   646: _apu_write_4015:
