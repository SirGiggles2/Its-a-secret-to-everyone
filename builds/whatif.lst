                            	  3727: PlayerScreenEdgeBounds:
02:00001C82 3D              	  3728:     dc.b    $3D, $DD, $00, $F0
02:00001C83 DD
02:00001C84 00
02:00001C85 F0
                            	  3729: 
                            	  3730: ; Params:
                            	  3731: ; [0E]: $FF, if blocked by a door
                            	  3732: ; [0F]: movement direction
                            	  3733: ;
                            	  3734: ; Returns:
                            	  3735: ; [0F]: untouched, or changed if blocked or need to change
                            	  3736: ;
                            	  3737: ; Summary:
                            	  3738: ;
                            	  3739: ; For the player: if at a doorway or walkable tile, check the screen edge.
                            	  3740: ; Then allow movement or go to the next room. Otherwise,
                            	  3741: ; check passive tile objects and stop moving.
                            	  3742: ;
                            	  3743: ; For other objects: First, if moving, test the colliding tile for
                            	  3744: ; walkability. Otherwise search for a walkable direction starting
                            	  3745: ; from input direction.
                            	  3746: ;
                            	  3747: ; When you find a walkable direction, see if it makes the object
                            	  3748: ; cross a boundary. If it doesn't, then make this direction
                            	  3749: ; the objection direction. Otherwise, keep looping.
                            	  3750: ;
                            	  3751: ; If no walkable direction is found, then stop moving.
                            	  3752: ;
                            	  3753: ;
                            	  3754: ; if is player
                            	  3755: ;   if at doorway
                            	  3756: ;     go handle a walkable direction
                            	  3757: ;   if blocked by door
                            	  3758: ;     return
                            	  3759: ;
                            	  3760:     even
                            	  3761: Walker_CheckTileCollision:
02:00001C86 4A02            	  3762:     cmpi.b  #$00,D2
02:00001C88 6612            	  3763:     bne  _L_z07_Walker_CheckTileCollision_CheckGridOffset
02:00001C8A 102C0053        	  3764:     move.b  ($0053,A4),D0
02:00001C8E 6704            	  3765:     beq  _anon_z07_16
02:00001C90 4EF81D2E        	  3766:     jmp     GoWalkableDir
                            	  3767: 
                            	  3768: _anon_z07_16:
02:00001C94 102C000E        	  3769:     move.b  ($000E,A4),D0
02:00001C98 6B00008A        	  3770:     bmi  L1F148_Exit
                            	  3771:     even
                            	  3772: _L_z07_Walker_CheckTileCollision_CheckGridOffset:
                            	  3773:     ; If grid offset <> 0, return.
                            	  3774:     ;
02:00001C9C 41EC0394        	  3775:     lea     ($0394,A4),A0
02:00001CA0 10302000        	  3776:     move.b  (A0,D2.W),D0
02:00001CA4 667E            	  3777:     bne  L1F148_Exit
                            	  3778:     ; Grid offset = 0.
                            	  3779:     ; The object is at a point between cells in the grid.
                            	  3780:     ; So, we can check tiles for collision.
                            	  3781:     ;
                            	  3782:     ; Reset [0E] alternate direction search step.
                            	  3783:     ;
02:00001CA6 1940000E        	  3784:     move.b  D0,($000E,A4)
                            	  3785:     ; If there's a movement direction, go check tile collision.
                            	  3786:     ;
02:00001CAA 102C000F        	  3787:     move.b  ($000F,A4),D0
02:00001CAE 662A            	  3788:     bne  CheckTiles
                            	  3789:     ; Moving direction = 0.
                            	  3790:     ; If object is the player, return.
                            	  3791:     ;
02:00001CB0 4A02            	  3792:     cmpi.b  #$00,D2
02:00001CB2 6770            	  3793:     beq  L1F148_Exit
                            	  3794:     ; Moving direction = 0.
                            	  3795:     ; The object is not the player.
                            	  3796:     ;
                            	  3797:     ; If object does not have attribute $10, then
                            	  3798:     ; set movement direction to input direction,
                            	  3799:     ; and go try to turn to an unblocked direction in order to move.
                            	  3800:     ;
02:00001CB4 41EC04BF        	  3801:     lea     ($04BF,A4),A0
02:00001CB8 10302000        	  3802:     move.b  (A0,D2.W),D0
02:00001CBC 02000010        	  3803:     andi.b #$10,D0
02:00001CC0 6610            	  3804:     bne  Reverse
02:00001CC2 41EC03F8        	  3805:     lea     ($03F8,A4),A0
02:00001CC6 10302000        	  3806:     move.b  (A0,D2.W),D0
02:00001CCA 1940000F        	  3807:     move.b  D0,($000F,A4)
02:00001CCE 4EF81CF8        	  3808:     jmp     TryNextDir
                            	  3809: 
                            	  3810:     even
                            	  3811: Reverse:
                            	  3812:     ; UNKNOWN:
                            	  3813:     ; This seems to be unused code triggered by object attribute $10.
                            	  3814:     ; But $10 is not used in the object attribute array at 07:FAEF.
                            	  3815:     ;
02:00001CD2 6100014C        	  3816:     bsr     ReverseObjDir
02:00001CD6 4EF81DB0        	  3817:     jmp     CheckBoundary
                            	  3818: 
                            	  3819:     even
                            	  3820: CheckTiles:
                            	  3821:     ; The code below applies to Link and other objects.
                            	  3822:     ;
                            	  3823:     ; Test the moving direction's walkability.
                            	  3824:     ;
                            	  3825:     ; For the player, this is enough. For other objects, this 
                            	  3826:     ; becomes a loop looking for an unblocked direction to move in.
                            	  3827:     ;
                            	  3828:     ; If the colliding tile is walkable, go handle a walkable direction.
                            	  3829:     ;
02:00001CDA 6100FA52        	  3830:     bsr     GetCollidingTileMoving
02:00001CDE 122C034A        	  3831:     move.b  ($034A,A4),D1
02:00001CE2 B001            	  3832:     cmp.b   D1,D0
02:00001CE4 6548            	  3833:     bcs  GoWalkableDir
