                            	   131: ;==============================================================================
                            	   132: ; $000200 — Boot code
                            	   133: ;==============================================================================
                            	   134: 
                            	   135:     org     $000200
                            	   136: 
                            	   137: ;------------------------------------------------------------------------------
                            	   138: ; EntryPoint — 68000 reset vector lands here.
                            	   139: ; The 68000 boots with SR = $2700 (supervisor, all IRQs masked). We leave
                            	   140: ; interrupts masked through the entire init sequence and lower the mask at
                            	   141: ; the end of MainLoop via the STOP instruction.
                            	   142: ;------------------------------------------------------------------------------
                            	   143: EntryPoint:
                            	   144:     ;--------------------------------------------------------------------------
                            	   145:     ; TMSS handshake — check VERSION_PORT bit[0]; if set, this is a TMSS
                            	   146:     ; hardware revision that requires writing 'SEGA' ($53454741) to $A14000
                            	   147:     ; before VDP access is allowed. Safe to skip on pre-TMSS hardware.
                            	   148:     ;--------------------------------------------------------------------------
02:00000200 103900A10001    	   149:     move.b  (VERSION_PORT).l,D0
02:00000206 0200000F        	   150:     andi.b  #$0F,D0
02:0000020A 670A            	   151:     beq.s   .skip_tmss
02:0000020C 23FC5345474100A1	   152:     move.l  #$53454741,(TMSS_PORT).l   ; 'S','E','G','A'
02:00000214 4000
                            	   153: .skip_tmss:
                            	   154: 
                            	   155:     ;--------------------------------------------------------------------------
                            	   156:     ; Stop Z80 — hold it in reset to prevent bus contention during init.
                            	   157:     ;--------------------------------------------------------------------------
02:00000216 33FC010000A11100	   158:     move.w  #$0100,(Z80_BUSREQ).l
02:0000021E 33FC010000A11200	   159:     move.w  #$0100,(Z80_RESET).l
                            	   160: .z80wait:
02:00000226 0839000000A11100	   161:     btst    #0,(Z80_BUSREQ).l            ; BUSACK = bit 0 of high byte $A11100;
02:0000022E 66F6            	   162:     bne.s   .z80wait                    ; wait until Z80 releases the bus
                            	   163: 
                            	   164:     ;--------------------------------------------------------------------------
                            	   165:     ; VDP register init — H32 mode, display OFF during init.
                            	   166:     ;
                            	   167:     ; COLORFIX: Reg 0 = $8004. bit 2 MUST BE 1.
                            	   168:     ;   $8000 (bit2=0) → dingy/dark colors on hardware despite correct CRAM.
                            	   169:     ;   $8004 (bit2=1) → correct colors.
                            	   170:     ;--------------------------------------------------------------------------
02:00000230 33FC800400C00004	   171:     move.w  #$8004,(VDP_CTRL).l  ; Reg  0: bit2=1 (colorfix), no H-int, no left-blank
02:00000238 33FC813400C00004	   172:     move.w  #$8134,(VDP_CTRL).l  ; Reg  1: display OFF, VBlank IRQ, DMA, M5 (Genesis)
02:00000240 33FC823000C00004	   173:     move.w  #$8230,(VDP_CTRL).l  ; Reg  2: Plane A @ $C000  ($C000/$2000=6 → $30)
02:00000248 33FC832C00C00004	   174:     move.w  #$832C,(VDP_CTRL).l  ; Reg  3: Window  @ $B000  (bits[5:1]=22 → $2C)
02:00000250 33FC840700C00004	   175:     move.w  #$8407,(VDP_CTRL).l  ; Reg  4: Plane B @ $E000  ($E000/$2000=7 → $07)
02:00000258 33FC856C00C00004	   176:     move.w  #$856C,(VDP_CTRL).l  ; Reg  5: Sprite table @ $D800 ($D800/$200=108 → $6C)
02:00000260 33FC860000C00004	   177:     move.w  #$8600,(VDP_CTRL).l  ; Reg  6: sprite table high bit = 0
02:00000268 33FC870000C00004	   178:     move.w  #$8700,(VDP_CTRL).l  ; Reg  7: BG color = palette 0, color 0
02:00000270 33FC880000C00004	   179:     move.w  #$8800,(VDP_CTRL).l  ; Reg  8: SMS compat = 0 (unused in M5)
02:00000278 33FC890000C00004	   180:     move.w  #$8900,(VDP_CTRL).l  ; Reg  9: SMS compat = 0 (unused in M5)
02:00000280 33FC8AFF00C00004	   181:     move.w  #$8AFF,(VDP_CTRL).l  ; Reg 10: H-int counter = $FF (effectively disabled)
02:00000288 33FC8B0000C00004	   182:     move.w  #$8B00,(VDP_CTRL).l  ; Reg 11: full-screen V-scroll, full H-scroll
02:00000290 33FC8C0000C00004	   183:     move.w  #$8C00,(VDP_CTRL).l  ; Reg 12: H32 (bits7,0=0), no interlace, no shadow/hl
02:00000298 33FC8D3700C00004	   184:     move.w  #$8D37,(VDP_CTRL).l  ; Reg 13: H-scroll table @ $DC00 ($DC00/$400=55 → $37)
02:000002A0 33FC8E0000C00004	   185:     move.w  #$8E00,(VDP_CTRL).l  ; Reg 14: pattern gen base = 0 (SMS compat, unused M5)
02:000002A8 33FC8F0200C00004	   186:     move.w  #$8F02,(VDP_CTRL).l  ; Reg 15: auto-increment = 2 (word per VRAM access)
02:000002B0 33FC900100C00004	   187:     move.w  #$9001,(VDP_CTRL).l  ; Reg 16: scroll size 64H × 32V → $01
02:000002B8 33FC910000C00004	   188:     move.w  #$9100,(VDP_CTRL).l  ; Reg 17: window H position = 0
02:000002C0 33FC920000C00004	   189:     move.w  #$9200,(VDP_CTRL).l  ; Reg 18: window V position = 0
02:000002C8 33FC930000C00004	   190:     move.w  #$9300,(VDP_CTRL).l  ; Reg 19: DMA length low = 0
02:000002D0 33FC940000C00004	   191:     move.w  #$9400,(VDP_CTRL).l  ; Reg 20: DMA length high = 0
02:000002D8 33FC950000C00004	   192:     move.w  #$9500,(VDP_CTRL).l  ; Reg 21: DMA source low = 0
02:000002E0 33FC960000C00004	   193:     move.w  #$9600,(VDP_CTRL).l  ; Reg 22: DMA source mid = 0
02:000002E8 33FC970000C00004	   194:     move.w  #$9700,(VDP_CTRL).l  ; Reg 23: DMA source high/type = 0 (ROM→VRAM)
                            	   195: 
                            	   196:     ;--------------------------------------------------------------------------
                            	   197:     ; Clear VRAM — write 0 to all 32768 words (64KB) via CPU loop.
                            	   198:     ; Auto-increment = 2 is set by Reg 15 above.
                            	   199:     ;--------------------------------------------------------------------------
02:000002F0 23FC4000000000C0	   200:     move.l  #VRAM_WRITE_0000,(VDP_CTRL).l
02:000002F8 0004
02:000002FA 303C7FFF        	   201:     move.w  #32767,D0
                            	   202: .vramclear:
02:000002FE 33FC000000C00000	   203:     move.w  #0,(VDP_DATA).l
02:00000306 51C8FFF6        	   204:     dbra    D0,.vramclear
                            	   205: 
                            	   206:     ;--------------------------------------------------------------------------
                            	   207:     ; Write test palette — pure green to CRAM[0] (background color slot).
                            	   208:     ; Reg 7 above set background = palette 0, color 0 → CRAM entry 0.
                            	   209:     ;
                            	   210:     ; Result on screen: solid green = VDP init correct (colorfix working).
                            	   211:     ; Dingy/dark green = check that Reg 0 is $8004, NOT $8000.
                            	   212:     ;--------------------------------------------------------------------------
02:0000030A 23FCC000000000C0	   213:     move.l  #CRAM_WRITE_0000,(VDP_CTRL).l
02:00000312 0004
02:00000314 33FC00E000C00000	   214:     move.w  #COLOR_GREEN,(VDP_DATA).l
                            	   215: 
                            	   216:     ;--------------------------------------------------------------------------
                            	   217:     ; Display on
                            	   218:     ;--------------------------------------------------------------------------
02:0000031C 33FC817400C00004	   219:     move.w  #$8174,(VDP_CTRL).l  ; Reg 1: DISP=1, VBlank IRQ, DMA, M5
                            	   220: 
                            	   221:     ;--------------------------------------------------------------------------
                            	   222:     ; Clear NES RAM ($FF0000–$FF07FF) — 2KB of NES work RAM mapped into
                            	   223:     ; Genesis RAM at the top of the address space.
                            	   224:     ; Also clears PPU state block ($FF0800–$FF080F) in the same pass.
                            	   225:     ;--------------------------------------------------------------------------
02:00000324 207C00FF0000    	   226:     movea.l #NES_RAM_BASE,A0
02:0000032A 303C041F        	   227:     move.w  #(NES_RAM_SIZE+PPU_STATE_SIZE)/2-1,D0  ; 1031 words
                            	   228: .nesramclear:
02:0000032E 30FC0000        	   229:     move.w  #0,(A0)+
02:00000332 51C8FFFA        	   230:     dbra    D0,.nesramclear
                            	   231: 
                            	   232:     ;--------------------------------------------------------------------------
                            	   233:     ; T4: Initialize NES register equivalents before handing off to Zelda code.
                            	   234:     ;
                            	   235:     ;   A4 = NES_RAM_BASE ($FF0000) — base for all (offset,A4) NES RAM accesses
                            	   236:     ;   A5 = NES_STACK_INIT ($FF0200) — NES stack starts at SP=$FF, so the
                            	   237:     ;        first PHA decrements to $FF01FF.  A5 points one-past the top.
                            	   238:     ;   D7 = $FF — 6502 SP shadow (used by TSX/TXS and stack bound checks)
                            	   239:     ;--------------------------------------------------------------------------
02:00000336 287C00FF0000    	   240:     movea.l #NES_RAM_BASE,A4
02:0000033C 2A7C00FF0200    	   241:     movea.l #NES_STACK_INIT,A5
02:00000342 7EFF            	   242:     moveq   #-1,D7                  ; D7 = $FF (NES SP shadow)
                            	   243: 
                            	   244:     ;--------------------------------------------------------------------------
                            	   245:     ; Lower interrupt mask so VBlank (level 6) can fire.
                            	   246:     ; A4/A5/D7 are initialised above — IsrNmi is now safe to execute.
                            	   247:     ; IPL=0: all interrupt levels pass (VBlank=6, NMI-like=7).
                            	   248:     ;--------------------------------------------------------------------------
02:00000344 027CF8FF        	   249:     andi.w  #$F8FF,SR               ; IPL → 0: enable VBlank
                            	   250: 
                            	   251:     ;--------------------------------------------------------------------------
                            	   252:     ; Hand off to Zelda — jump to IsrReset (the NES Reset vector handler).
                            	   253:     ; IsrReset polls PPU $2002 (VBlank) twice, initialises MMC1, then jumps
                            	   254:     ; to RunGame which spins in LoopForever waiting for VBlank NMI.
                            	   255:     ;
                            	   256:     ; NOTE: VBlankISR below is wired to IsrNmi once T4 is validated.
                            	   257:     ; For T4, VBlank is masked by genesis boot SR ($2700) and IsrReset's SEI
                            	   258:     ; (now a NOP), so LoopForever just spins — that is the expected T4 state.
                            	   259:     ;--------------------------------------------------------------------------
02:00000348 4EB83650        	   260:     jsr     IsrReset                ; never returns (RunGame → LoopForever)
                            	   261: 
                            	   262:     ;--------------------------------------------------------------------------
                            	   263:     ; Safety net — should never be reached.
                            	   264:     ;--------------------------------------------------------------------------
                            	   265: HaltForever:
02:0000034C 4E722700        	   266:     stop    #$2700
02:00000350 60FA            	   267:     bra.s   HaltForever
                            	   268: 
                            	   269: ;==============================================================================
                            	   270: ; VBlankISR — T4: call IsrNmi (Zelda's NMI handler) then return.
                            	   271: ; IsrNmi is defined in zelda_translated/z_07.asm (included below).
                            	   272: ;
                            	   273: ; T4 note: during boot, SR=$2700 so this ISR never fires while IsrReset runs.
                            	   274: ; Once RunGame hits LoopForever and we lower SR (T5+), this fires every frame.
                            	   275: ;==============================================================================
                            	   276: VBlankISR:
                            	   277:     ; Only call IsrNmi if PPUCTRL bit 7 = 1 (NMI enable).
                            	   278:     ; On NES, VBlank NMI fires only when PPUCTRL.$80 is set.
                            	   279:     ; During IsrReset warmup PPUCTRL=0, so IsrNmi is suppressed
                            	   280:     ; until RunGame writes $A0 to $2000.
02:00000352 0839000700FF0804	   281:     btst    #7,($00FF0804).l        ; PPU_CTRL = $FF0804, bit 7 = NMI enable
02:0000035A 6704            	   282:     beq.s   .nmi_off
02:0000035C 4EB80780        	   283:     jsr     IsrNmi
                            	   284: .nmi_off:
02:00000360 4E73            	   285:     rte
                            	   286: 
                            	   287: ;==============================================================================
                            	   288: ; Exception forensics handlers
                            	   289: ;
                            	   290: ; On any exception: save type, stacked SR, faulting PC, and all data/address
                            	   291: ; registers to a known RAM block at $FF0900 before spinning.  The T5 probe
                            	   292: ; (and BizHawk debugger) can then read this block to identify the fault.
                            	   293: ;
                            	   294: ; 68000 stack frames:
                            	   295: ;   Bus Error (vec 2) / Address Error (vec 3):
                            	   296: ;     SP+0  function code / misc (word)
                            	   297: ;     SP+2  access address (long)
                            	   298: ;     SP+6  instruction register (word)
                            	   299: ;     SP+8  SR at exception time
                            	   300: ;     SP+10 PC of faulting instruction (long)
                            	   301: ;   All other exceptions:
                            	   302: ;     SP+0  SR at exception time
                            	   303: ;     SP+2  PC of faulting instruction (long)
                            	   304: ;
                            	   305: ; Forensics RAM layout ($FF0900):
                            	   306: ;   $FF0900: exception type byte (2=bus error, 3=addr error, 0=other)
                            	   307: ;   $FF0901: (pad)
                            	   308: ;   $FF0902: stacked SR (word)
                            	   309: ;   $FF0904: faulting PC (long)
                            	   310: ;   $FF0908: D0–D7, A0–A6 saved by MOVEM.L (15 longs = 60 bytes, ends $FF0943)
                            	   311: ;==============================================================================
                            	   312: 
                            	   313: ExcBusError:
02:00000362 13FC000200FF0900	   314:     move.b  #2,($FF0900).l
02:0000036A 33EF000800FF0902	   315:     move.w  8(SP),($FF0902).l
02:00000372 23EF000A00FF0904	   316:     move.l  10(SP),($FF0904).l
02:0000037A 48F97FFF00FF0908	   317:     movem.l D0-D7/A0-A6,($FF0908).l
                            	   318: .spin:
02:00000382 60FE            	   319:     bra.s   .spin
                            	   320: 
                            	   321: ExcAddrError:
02:00000384 13FC000300FF0900	   322:     move.b  #3,($FF0900).l
02:0000038C 33EF000800FF0902	   323:     move.w  8(SP),($FF0902).l
02:00000394 23EF000A00FF0904	   324:     move.l  10(SP),($FF0904).l
02:0000039C 48F97FFF00FF0908	   325:     movem.l D0-D7/A0-A6,($FF0908).l
                            	   326: .spin:
02:000003A4 60FE            	   327:     bra.s   .spin
                            	   328: 
                            	   329: DefaultException:
02:000003A6 13FC000000FF0900	   330:     move.b  #0,($FF0900).l
02:000003AE 33D700FF0902    	   331:     move.w  (SP),($FF0902).l
02:000003B4 23EF000200FF0904	   332:     move.l  2(SP),($FF0904).l
02:000003BC 48F97FFF00FF0908	   333:     movem.l D0-D7/A0-A6,($FF0908).l
                            	   334: .spin:
02:000003C4 60FE            	   335:     bra.s   .spin
                            	   336: 
                            	   337: ;==============================================================================
                            	   338: ; NES I/O emulation layer — real implementations of _ppu_*, _apu_*, _ctrl_*,
                            	   339: ; _oam_dma, _mmc1_*, _indirect_stub.  Must be included BEFORE any bank file
                            	   340: ; so all helpers are defined when z_XX.asm code references them.
                            	   341: ; (With --no-stubs the bank files no longer emit these labels themselves.)
                            	   342: ;==============================================================================
                            	   343:     include "nes_io.asm"

Source: "nes_io.asm"
                            	     1: ;==============================================================================
                            	     2: ; nes_io.asm — NES I/O emulation layer
                            	     3: ;
                            	     4: ; Included by genesis_shell.asm BEFORE z_07.asm (and all other bank files).
                            	     5: ; Provides real implementations of all _ppu_*, _apu_*, _ctrl_*, _oam_*,
                            	     6: ; _mmc1_* helpers that the transpiled Zelda code calls via BSR/JSR.
                            	     7: ;
                            	     8: ; T5 milestone: PPUADDR two-write latch + PPUDATA → Genesis VDP VRAM byte writes.
                            	     9: ;
                            	    10: ; Register contract (must match transpiler mapping):
                            	    11: ;   D0  = NES accumulator A
                            	    12: ;   D2  = NES X index
                            	    13: ;   D3  = NES Y index
                            	    14: ;   D7  = NES SP shadow
                            	    15: ;   A4  = NES RAM base ($FF0000)
                            	    16: ;   A5  = NES stack pointer (NES_RAM + $0100 region)
                            	    17: ;
                            	    18: ; All NES I/O functions must preserve D1–D7, A0–A6 except as documented.
                            	    19: ; They receive their argument in D0.b and return results in D0.b.
                            	    20: ;==============================================================================
                            	    21: 
                            	    22: ;------------------------------------------------------------------------------
                            	    23: ; PPU state RAM — placed at $FF0800 (immediately after 2KB NES work RAM).
                            	    24: ; Initialised to zero by genesis_shell before jsr IsrReset.
                            	    25: ;
                            	    26: ; Layout (12 bytes):
                            	    27: ;   +0  PPU_LATCH   (byte) write-toggle shared by $2005/$2006 (0=1st, 1=2nd)
                            	    28: ;   +1  (pad)
                            	    29: ;   +2  PPU_VADDR   (word) assembled 16-bit VRAM address
                            	    30: ;   +4  PPU_CTRL    (byte) PPUCTRL  ($2000) shadow
                            	    31: ;   +5  PPU_MASK    (byte) PPUMASK  ($2001) shadow
                            	    32: ;   +6  PPU_SCRL_X  (byte) scroll X (from first  $2005 write)
                            	    33: ;   +7  PPU_SCRL_Y  (byte) scroll Y (from second $2005 write)
                            	    34: ;   +8  PPU_DBUF    (byte) PPUDATA even-address byte buffer
                            	    35: ;   +9  PPU_DHALF   (byte) 1 when an even-address byte is buffered
                            	    36: ;   +10 (pad × 2)
                            	    37: ;------------------------------------------------------------------------------
                            	    38: PPU_STATE_BASE  equ $00FF0800
                            	    39: 
                            	    40: PPU_LATCH       equ PPU_STATE_BASE+0    ; byte: w register (0=first write)
                            	    41: PPU_VADDR       equ PPU_STATE_BASE+2    ; word: current VRAM address
                            	    42: PPU_CTRL        equ PPU_STATE_BASE+4    ; byte: PPUCTRL shadow
                            	    43: PPU_MASK        equ PPU_STATE_BASE+5    ; byte: PPUMASK shadow
                            	    44: PPU_SCRL_X      equ PPU_STATE_BASE+6    ; byte: horizontal scroll value
                            	    45: PPU_SCRL_Y      equ PPU_STATE_BASE+7    ; byte: vertical scroll value
                            	    46: PPU_DBUF        equ PPU_STATE_BASE+8    ; byte: buffered even-addr byte
                            	    47: PPU_DHALF       equ PPU_STATE_BASE+9    ; byte: 1 if even-addr byte pending
                            	    48: 
                            	    49: ;------------------------------------------------------------------------------
                            	    50: ; MMC1 state RAM — placed at $FF0810 (immediately after 16-byte PPU block).
                            	    51: ; Initialised to zero by genesis_shell before jsr IsrReset.
                            	    52: ;
                            	    53: ; Layout (6 bytes):
                            	    54: ;   +0  MMC1_SHIFT  (byte) shift register accumulator (LSB-first)
                            	    55: ;   +1  MMC1_COUNT  (byte) number of bits accumulated (0–4)
                            	    56: ;   +2  MMC1_CTRL   (byte) MMC1 control register ($8000 target)
                            	    57: ;   +3  MMC1_CHR0   (byte) CHR bank 0 register   ($A000 target)
                            	    58: ;   +4  MMC1_CHR1   (byte) CHR bank 1 register   ($C000 target)
                            	    59: ;   +5  MMC1_PRG    (byte) PRG bank register      ($E000 target)
                            	    60: ;------------------------------------------------------------------------------
                            	    61: MMC1_STATE_BASE equ PPU_STATE_BASE+$10  ; $FF0810
                            	    62: 
                            	    63: MMC1_SHIFT      equ MMC1_STATE_BASE+0   ; byte: shift accumulator
                            	    64: MMC1_COUNT      equ MMC1_STATE_BASE+1   ; byte: bits accumulated (0-4)
                            	    65: MMC1_CTRL       equ MMC1_STATE_BASE+2   ; byte: control reg ($8000)
                            	    66: MMC1_CHR0       equ MMC1_STATE_BASE+3   ; byte: CHR bank 0 ($A000)
                            	    67: MMC1_CHR1       equ MMC1_STATE_BASE+4   ; byte: CHR bank 1 ($C000)
                            	    68: MMC1_PRG        equ MMC1_STATE_BASE+5   ; byte: PRG bank ($E000)
                            	    69: 
                            	    70: ;------------------------------------------------------------------------------
                            	    71: ; CHR tile upload buffer — placed at $FF0820.
                            	    72: ; Accumulates one 16-byte NES 2BPP tile then converts it to Genesis 4BPP (32 bytes)
                            	    73: ; and DMA-writes the result to VDP VRAM.
                            	    74: ;
                            	    75: ; Layout (19 bytes):
                            	    76: ;   +0…+15  CHR_TILE_BUF  (16 bytes) raw NES 2BPP tile data
                            	    77: ;              bytes 0–7  = plane 0 (bit 0 of each pixel, row 0 first)
                            	    78: ;              bytes 8–15 = plane 1 (bit 1 of each pixel, row 0 first)
                            	    79: ;   +16     CHR_BUF_CNT   (byte) number of bytes accumulated (0–15)
                            	    80: ;   +17–18  CHR_BUF_VADDR (word) NES PPU address at start of this tile
                            	    81: ;------------------------------------------------------------------------------
                            	    82: CHR_STATE_BASE  equ PPU_STATE_BASE+$20  ; $FF0820
                            	    83: 
                            	    84: CHR_TILE_BUF    equ CHR_STATE_BASE+0    ; 16 bytes: raw NES tile bytes
                            	    85: CHR_BUF_CNT     equ CHR_STATE_BASE+16   ; byte: bytes accumulated
                            	    86: CHR_BUF_VADDR   equ CHR_STATE_BASE+17   ; word: tile's NES base address
                            	    87: 
                            	    88: ;==============================================================================
                            	    89: ; PPU register reads ($2000–$2007 → _ppu_read_0 … _ppu_read_7)
                            	    90: ;==============================================================================
                            	    91: 
                            	    92: ;------------------------------------------------------------------------------
                            	    93: ; _ppu_read_0 — PPUCTRL ($2000) — write-only on real NES, reads return open bus.
                            	    94: ; Return 0 so caller's AND/BEQ tests see nothing set.
                            	    95: ;------------------------------------------------------------------------------
                            	    96: _ppu_read_0:
02:000003C6 7000            	    97:     moveq   #0,D0
02:000003C8 4E75            	    98:     rts
                            	    99: 
                            	   100: ;------------------------------------------------------------------------------
                            	   101: ; _ppu_read_1 — PPUMASK ($2001) — write-only, open bus.
                            	   102: ;------------------------------------------------------------------------------
                            	   103: _ppu_read_1:
02:000003CA 7000            	   104:     moveq   #0,D0
02:000003CC 4E75            	   105:     rts
                            	   106: 
                            	   107: ;------------------------------------------------------------------------------
                            	   108: ; _ppu_read_2 — PPUSTATUS ($2002)
                            	   109: ;
                            	   110: ; Bit 7 = VBlank flag.  Cleared on read.  The shared write-latch (w) is also
                            	   111: ; reset on any $2002 read.
                            	   112: ;
                            	   113: ; T5 implementation: always returns $80 (VBlank always set) so IsrReset's
                            	   114: ; two warmup polling loops exit immediately.  A real VBlank flag will be
                            	   115: ; wired in T6 (software flag toggled by VBlankISR).
                            	   116: ;
                            	   117: ; IMPORTANT: must reset the PPU write-latch (PPU_LATCH).
                            	   118: ;------------------------------------------------------------------------------
                            	   119: _ppu_read_2:
02:000003CE 423900FF0800    	   120:     clr.b   (PPU_LATCH).l          ; reading $2002 resets the w register
02:000003D4 103C0080        	   121:     move.b  #$80,D0                ; VBlank flag set (warmup loops will exit)
02:000003D8 4E75            	   122:     rts
                            	   123: 
                            	   124: ;------------------------------------------------------------------------------
                            	   125: ; _ppu_read_3 — OAM addr ($2003) — write-only.
                            	   126: ; _ppu_read_4 — OAM data ($2004) — return 0 for now.
                            	   127: ; _ppu_read_5 — PPUSCROLL ($2005) — write-only.
                            	   128: ; _ppu_read_6 — PPUADDR  ($2006) — write-only.
                            	   129: ;------------------------------------------------------------------------------
                            	   130: _ppu_read_3:
                            	   131: _ppu_read_4:
                            	   132: _ppu_read_5:
                            	   133: _ppu_read_6:
02:000003DA 7000            	   134:     moveq   #0,D0
02:000003DC 4E75            	   135:     rts
                            	   136: 
                            	   137: ;------------------------------------------------------------------------------
                            	   138: ; _ppu_read_7 — PPUDATA ($2007) read
                            	   139: ;
                            	   140: ; T5: return 0.  Palette reads have a special one-cycle-delay buffer on real
                            	   141: ; NES hardware.  No reads of $2007 in Zelda's critical path; defer to T8+.
                            	   142: ;------------------------------------------------------------------------------
                            	   143: _ppu_read_7:
02:000003DE 7000            	   144:     moveq   #0,D0
02:000003E0 4E75            	   145:     rts
                            	   146: 
                            	   147: ;==============================================================================
                            	   148: ; PPU register writes ($2000–$2007 → _ppu_write_0 … _ppu_write_7)
                            	   149: ;==============================================================================
                            	   150: 
                            	   151: ;------------------------------------------------------------------------------
                            	   152: ; _ppu_write_0 — PPUCTRL ($2000)
                            	   153: ;
                            	   154: ; D0.b = value to write.
                            	   155: ; Bits of interest:
                            	   156: ;   bit 2 = VRAM address increment (0 → +1 horizontal, 1 → +32 vertical)
                            	   157: ;   bit 7 = NMI enable (0 = disable, 1 = enable on VBlank)
                            	   158: ;
                            	   159: ; We store the value so _ppu_write_7 can read the increment flag.
                            	   160: ; NMI enable is handled at the hardware level (VBlank ISR always fires);
                            	   161: ; Zelda controls this register to gate per-frame updates.
                            	   162: ;------------------------------------------------------------------------------
                            	   163: _ppu_write_0:
02:000003E2 13C000FF0804    	   164:     move.b  D0,(PPU_CTRL).l
02:000003E8 4E75            	   165:     rts
                            	   166: 
                            	   167: ;------------------------------------------------------------------------------
                            	   168: ; _ppu_write_1 — PPUMASK ($2001)
                            	   169: ; Store shadow for potential video-enable logic in T6+.
                            	   170: ;------------------------------------------------------------------------------
                            	   171: _ppu_write_1:
02:000003EA 13C000FF0805    	   172:     move.b  D0,(PPU_MASK).l
02:000003F0 4E75            	   173:     rts
                            	   174: 
                            	   175: ;------------------------------------------------------------------------------
                            	   176: ; _ppu_write_2 — PPUSTATUS ($2002) — write-only on real NES (no effect).
                            	   177: ;------------------------------------------------------------------------------
                            	   178: _ppu_write_2:
02:000003F2 4E75            	   179:     rts
                            	   180: 
                            	   181: ;------------------------------------------------------------------------------
                            	   182: ; _ppu_write_3 — OAM address ($2003) — store for future OAM DMA logic.
                            	   183: ;------------------------------------------------------------------------------
                            	   184: _ppu_write_3:
02:000003F4 4E75            	   185:     rts
                            	   186: 
                            	   187: ;------------------------------------------------------------------------------
                            	   188: ; _ppu_write_4 — OAM data ($2004) — T5: stub (OAM DMA via $4014 covers Zelda).
                            	   189: ;------------------------------------------------------------------------------
                            	   190: _ppu_write_4:
02:000003F6 4E75            	   191:     rts
                            	   192: 
                            	   193: ;------------------------------------------------------------------------------
                            	   194: ; _ppu_write_5 — PPUSCROLL ($2005)
                            	   195: ;
                            	   196: ; First  write (PPU_LATCH=0): horizontal scroll → PPU_SCRL_X, latch → 1.
                            	   197: ; Second write (PPU_LATCH=1): vertical   scroll → PPU_SCRL_Y, latch → 0.
                            	   198: ;
                            	   199: ; Writing to VDP scroll registers is deferred to T6 (visual output pass).
                            	   200: ; For T5 we just store the values so they're available when needed.
                            	   201: ;------------------------------------------------------------------------------
                            	   202: _ppu_write_5:
02:000003F8 48E74000        	   203:     movem.l D1,-(SP)
02:000003FC 123900FF0800    	   204:     move.b  (PPU_LATCH).l,D1
02:00000402 4A01            	   205:     tst.b   D1
02:00000404 6614            	   206:     bne.s   .second_write_5
                            	   207:     ; First write — horizontal scroll
02:00000406 13C000FF0806    	   208:     move.b  D0,(PPU_SCRL_X).l
02:0000040C 13FC000100FF0800	   209:     move.b  #1,(PPU_LATCH).l
02:00000414 4CDF0002        	   210:     movem.l (SP)+,D1
02:00000418 4E75            	   211:     rts
                            	   212: .second_write_5:
                            	   213:     ; Second write — vertical scroll
02:0000041A 13C000FF0807    	   214:     move.b  D0,(PPU_SCRL_Y).l
02:00000420 423900FF0800    	   215:     clr.b   (PPU_LATCH).l
02:00000426 4CDF0002        	   216:     movem.l (SP)+,D1
02:0000042A 4E75            	   217:     rts
                            	   218: 
                            	   219: ;------------------------------------------------------------------------------
                            	   220: ; _ppu_write_6 — PPUADDR ($2006)  ← T5 key implementation
                            	   221: ;
                            	   222: ; The NES PPU address register uses a two-write protocol (shared "w" latch):
                            	   223: ;   First  write: high byte of 15-bit VRAM address (bit 14 is forced clear by
                            	   224: ;                 hardware — valid VRAM is $0000–$3FFF).
                            	   225: ;   Second write: low byte.  After this write PPU_VADDR is fully updated and
                            	   226: ;                 the latch resets to 0.
                            	   227: ;
                            	   228: ; Side effect: resets the even-byte PPUDATA buffer (PPU_DHALF = 0) so that a
                            	   229: ; fresh address is always treated as the start of a new word-pair.
                            	   230: ;
                            	   231: ; Preserves: D1.
                            	   232: ;------------------------------------------------------------------------------
                            	   233: _ppu_write_6:
02:0000042C 48E74000        	   234:     movem.l D1,-(SP)
02:00000430 123900FF0800    	   235:     move.b  (PPU_LATCH).l,D1
02:00000436 4A01            	   236:     tst.b   D1
02:00000438 6618            	   237:     bne.s   .second_write_6
                            	   238:     ; ---- First write: high byte ----
                            	   239:     ; High byte goes into PPU_VADDR+0.  Force bit 6 (addr bit 14) clear to
                            	   240:     ; keep address in the valid $0000–$3FFF window (matches NES hardware).
02:0000043A 0200003F        	   241:     andi.b  #$3F,D0
02:0000043E 13C000FF0802    	   242:     move.b  D0,(PPU_VADDR).l        ; store high byte
02:00000444 13FC000100FF0800	   243:     move.b  #1,(PPU_LATCH).l
02:0000044C 4CDF0002        	   244:     movem.l (SP)+,D1
02:00000450 4E75            	   245:     rts
                            	   246: .second_write_6:
                            	   247:     ; ---- Second write: low byte ----
02:00000452 13C000FF0803    	   248:     move.b  D0,(PPU_VADDR+1).l      ; store low byte
02:00000458 423900FF0800    	   249:     clr.b   (PPU_LATCH).l           ; reset w register
02:0000045E 423900FF0809    	   250:     clr.b   (PPU_DHALF).l           ; discard any pending even-byte buffer
02:00000464 4CDF0002        	   251:     movem.l (SP)+,D1
02:00000468 4E75            	   252:     rts
                            	   253: 
                            	   254: ;------------------------------------------------------------------------------
                            	   255: ; _ppu_write_7 — PPUDATA ($2007)  ← T16 full implementation
                            	   256: ;
                            	   257: ; Routes byte writes to one of two paths based on PPU_VADDR:
                            	   258: ;
                            	   259: ;   CHR-RAM path  (PPU_VADDR $0000–$1FFF):
                            	   260: ;     Accumulates 16 bytes per NES tile in CHR_TILE_BUF, then on the 16th
                            	   261: ;     byte converts the 2BPP NES tile to 4BPP Genesis format and writes the
                            	   262: ;     32-byte result to VDP VRAM at Genesis addr = NES_addr × 2.
                            	   263: ;
                            	   264: ;   Nametable/palette path (PPU_VADDR $2000–$3FFF):
                            	   265: ;     Buffers even-address bytes and flushes pairs as 16-bit VDP words
                            	   266: ;     (unchanged from T5 — correct for nametable clears and palette writes).
                            	   267: ;
                            	   268: ; NES 2BPP → Genesis 4BPP conversion:
                            	   269: ;   16 bytes in: 8 bytes plane-0 then 8 bytes plane-1 (one bit per pixel)
                            	   270: ;   32 bytes out: 4 bytes per row, 2 pixels per byte, high-nibble = left pixel
                            	   271: ;   Pixel color = (plane1_bit << 1) | plane0_bit   (values 0–3)
                            	   272: ;
                            	   273: ; VDP auto-increment = 2 (Reg 15 = $8F02 set by genesis_shell).
                            	   274: ; PPU_VADDR increments by 1 (horizontal mode, bit 2 of PPUCTRL = 0).
                            	   275: ;
                            	   276: ; Preserves: D0–D5, A0–A6 (all saved/restored).
                            	   277: ;------------------------------------------------------------------------------
                            	   278: _ppu_write_7:
02:0000046A 48E7FC80        	   279:     movem.l D0-D5/A0,-(SP)          ; save all working registers (D0 = NES acc)
                            	   280: 
02:0000046E 323900FF0802    	   281:     move.w  (PPU_VADDR).l,D1        ; D1 = current NES PPU address
                            	   282: 
                            	   283:     ; Route: CHR range ($0000–$1FFF) vs nametable/palette ($2000–$3FFF)
02:00000474 0C412000        	   284:     cmpi.w  #$2000,D1
02:00000478 6444            	   285:     bhs     .nt_write               ; ≥$2000 → nametable / palette path
                            	   286: 
                            	   287:     ;==========================================================================
                            	   288:     ; CHR TILE BUFFER PATH
                            	   289:     ;==========================================================================
                            	   290:     ; Buffer each byte.  On the 16th byte, convert the tile and upload it.
02:0000047A 7400            	   291:     moveq   #0,D2
02:0000047C 143900FF0830    	   292:     move.b  (CHR_BUF_CNT).l,D2     ; D2 = bytes accumulated so far (0–15)
                            	   293: 
                            	   294:     ; Save this tile's base address on the first byte (aligned to 16 bytes)
02:00000482 4A02            	   295:     tst.b   D2
02:00000484 660C            	   296:     bne.s   .chr_store_byte
02:00000486 3601            	   297:     move.w  D1,D3
02:00000488 0243FFF0        	   298:     andi.w  #$FFF0,D3               ; round down to 16-byte tile boundary
02:0000048C 33C300FF0831    	   299:     move.w  D3,(CHR_BUF_VADDR).l
                            	   300: 
                            	   301: .chr_store_byte:
02:00000492 41F900FF0820    	   302:     lea     (CHR_TILE_BUF).l,A0
02:00000498 11802000        	   303:     move.b  D0,(A0,D2.w)            ; CHR_TILE_BUF[count] = byte
02:0000049C 523900FF0830    	   304:     addq.b  #1,(CHR_BUF_CNT).l     ; increment count
02:000004A2 616E            	   305:     bsr     .inc_ppuaddr            ; advance PPU_VADDR
                            	   306: 
02:000004A4 0C39001000FF0830	   307:     cmpi.b  #16,(CHR_BUF_CNT).l
02:000004AC 660A            	   308:     bne.s   .chr_ret                ; not yet 16 bytes — keep buffering
                            	   309: 
                            	   310:     ; Complete tile — convert 2BPP → 4BPP and upload to VDP VRAM
02:000004AE 61000086        	   311:     bsr     .chr_convert_upload
02:000004B2 423900FF0830    	   312:     clr.b   (CHR_BUF_CNT).l
                            	   313: 
                            	   314: .chr_ret:
02:000004B8 4CDF013F        	   315:     movem.l (SP)+,D0-D5/A0
02:000004BC 4E75            	   316:     rts
                            	   317: 
                            	   318:     ;==========================================================================
                            	   319:     ; NAMETABLE / PALETTE PATH  (PPU_VADDR $2000–$3FFF)
                            	   320:     ;==========================================================================
                            	   321:     ; Word-pair buffering: buffer even-address byte, flush word on odd address.
                            	   322:     ;==========================================================================
                            	   323: .nt_write:
02:000004BE 08010000        	   324:     btst    #0,D1
02:000004C2 6616            	   325:     bne.s   .nt_odd_byte            ; odd address → flush word
                            	   326: 
                            	   327:     ; ---- Even address: buffer the byte ----
02:000004C4 13C000FF0808    	   328:     move.b  D0,(PPU_DBUF).l
02:000004CA 13FC000100FF0809	   329:     move.b  #1,(PPU_DHALF).l
02:000004D2 613E            	   330:     bsr     .inc_ppuaddr
02:000004D4 4CDF013F        	   331:     movem.l (SP)+,D0-D5/A0
02:000004D8 4E75            	   332:     rts
                            	   333: 
                            	   334: .nt_odd_byte:
                            	   335:     ; ---- Odd address: assemble word and write to VDP VRAM ----
                            	   336:     ; VDP VRAM write command for word-aligned address (D1–1):
02:000004DA 7400            	   337:     moveq   #0,D2
02:000004DC 3401            	   338:     move.w  D1,D2                   ; D2.w = odd VRAM address
02:000004DE 5342            	   339:     subq.w  #1,D2                   ; D2.w = even (word-aligned)
02:000004E0 4842            	   340:     swap    D2                      ; D2   = word_addr << 16
02:000004E2 008240000000    	   341:     ori.l   #$40000000,D2           ; D2   = VDP VRAM-write command long
02:000004E8 23C200C00004    	   342:     move.l  D2,(VDP_CTRL).l
                            	   343: 
                            	   344:     ; Build word: high byte = PPU_DBUF (even), low byte = D0 (odd)
02:000004EE 7400            	   345:     moveq   #0,D2
02:000004F0 143900FF0808    	   346:     move.b  (PPU_DBUF).l,D2        ; D2.b = buffered even byte
02:000004F6 E14A            	   347:     lsl.w   #8,D2                  ; shift to high byte of word
02:000004F8 024000FF        	   348:     andi.w  #$00FF,D0              ; mask to byte
02:000004FC 8440            	   349:     or.w    D0,D2                  ; D2.w = complete word
02:000004FE 33C200C00000    	   350:     move.w  D2,(VDP_DATA).l        ; commit to VDP VRAM
                            	   351: 
02:00000504 423900FF0809    	   352:     clr.b   (PPU_DHALF).l
02:0000050A 6106            	   353:     bsr     .inc_ppuaddr
02:0000050C 4CDF013F        	   354:     movem.l (SP)+,D0-D5/A0
02:00000510 4E75            	   355:     rts
                            	   356: 
                            	   357:     ;==========================================================================
                            	   358:     ; .inc_ppuaddr — advance PPU_VADDR by 1 or 32.
                            	   359:     ; PPUCTRL bit 2: 0 → +1 horizontal, 1 → +32 vertical.
                            	   360:     ; Modifies D1.w.
                            	   361:     ;==========================================================================
                            	   362: .inc_ppuaddr:
02:00000512 323900FF0802    	   363:     move.w  (PPU_VADDR).l,D1
02:00000518 0839000200FF0804	   364:     btst    #2,(PPU_CTRL).l
02:00000520 6604            	   365:     bne.s   .inc32
02:00000522 5241            	   366:     addq.w  #1,D1
02:00000524 6004            	   367:     bra.s   .store_inc
                            	   368: .inc32:
02:00000526 06410020        	   369:     addi.w  #32,D1
                            	   370: .store_inc:
02:0000052A 02413FFF        	   371:     andi.w  #$3FFF,D1               ; clamp to valid PPU address range
02:0000052E 33C100FF0802    	   372:     move.w  D1,(PPU_VADDR).l
02:00000534 4E75            	   373:     rts
                            	   374: 
                            	   375:     ;==========================================================================
                            	   376:     ; .chr_convert_upload — convert 16-byte NES 2BPP tile to 32-byte Genesis
                            	   377:     ;                        4BPP and write to VDP VRAM.
                            	   378:     ;
                            	   379:     ; Input: CHR_TILE_BUF holds the 16 tile bytes.
                            	   380:     ;        CHR_BUF_VADDR holds the NES CHR base address (× 16-aligned).
                            	   381:     ;
                            	   382:     ; Genesis VRAM tile address = CHR_BUF_VADDR × 2 (tiles are 32 bytes each).
                            	   383:     ;
                            	   384:     ; For each of 8 rows:
                            	   385:     ;   plane0_row = CHR_TILE_BUF[row]       (bit 0 of each of 8 pixels)
                            	   386:     ;   plane1_row = CHR_TILE_BUF[row+8]     (bit 1 of each of 8 pixels)
                            	   387:     ;
                            	   388:     ; Pixel color = (plane1_bit << 1) | plane0_bit  →  4-bit Genesis nibble
                            	   389:     ;
                            	   390:     ; Output format per row (4 Genesis bytes = 2 VDP words):
                            	   391:     ;   byte 0: pixels 0,1  (high nibble = pixel 0, low nibble = pixel 1)
                            	   392:     ;   byte 1: pixels 2,3
                            	   393:     ;   byte 2: pixels 4,5
                            	   394:     ;   byte 3: pixels 6,7
                            	   395:     ;
                            	   396:     ; expand_nibble(n) helper: scatters 4-bit value n to positions 12,8,4,0
                            	   397:     ; of a 16-bit word (one bit per nibble).  Then OR-ing plane0 expansion
                            	   398:     ; with (plane1 expansion << 1) gives the correct Genesis word.
                            	   399:     ;
                            	   400:     ; Uses D0–D5/A0 (all caller-saved at _ppu_write_7 entry).
                            	   401:     ;==========================================================================
                            	   402: .chr_convert_upload:
                            	   403:     ; Set VDP write address: Genesis tile addr = NES CHR addr × 2
02:00000536 323900FF0831    	   404:     move.w  (CHR_BUF_VADDR).l,D1
02:0000053C D241            	   405:     add.w   D1,D1                   ; D1 = NES_addr × 2  (lsl #1)
                            	   406:     ; VDP VRAM write command for D1.w (< $4000, so upper word = 0):
02:0000053E 2401            	   407:     move.l  D1,D2
02:00000540 4842            	   408:     swap    D2                      ; D2 = D1.w << 16 (high word = addr)
02:00000542 008240000000    	   409:     ori.l   #$40000000,D2           ; VDP VRAM-write command
02:00000548 23C200C00004    	   410:     move.l  D2,(VDP_CTRL).l
                            	   411: 
02:0000054E 41F900FF0820    	   412:     lea     (CHR_TILE_BUF).l,A0     ; A0 → plane-0 row bytes (0..7)
02:00000554 7A07            	   413:     moveq   #7,D5                   ; 8 rows, counter 7..0
                            	   414: 
                            	   415: .ccu_row:
02:00000556 1610            	   416:     move.b  0(A0),D3                ; D3.b = plane 0 for this row
02:00000558 18280008        	   417:     move.b  8(A0),D4                ; D4.b = plane 1 for this row
02:0000055C 5288            	   418:     addq.l  #1,A0                   ; advance to next plane-0 row byte
                            	   419: 
                            	   420:     ; ---- Pixels 0-3 (upper nibbles of D3 and D4) ----
02:0000055E 1203            	   421:     move.b  D3,D1
02:00000560 E809            	   422:     lsr.b   #4,D1                   ; D1.b = upper nibble of plane0 (pix 0-3)
02:00000562 0201000F        	   423:     andi.b  #$0F,D1
02:00000566 6138            	   424:     bsr     .expand_nibble          ; D2.w = plane0 expansion (bit0 of each nibble)
02:00000568 3002            	   425:     move.w  D2,D0                   ; save plane0 expansion
                            	   426: 
02:0000056A 1204            	   427:     move.b  D4,D1
02:0000056C E809            	   428:     lsr.b   #4,D1                   ; D1.b = upper nibble of plane1 (pix 0-3)
02:0000056E 0201000F        	   429:     andi.b  #$0F,D1
02:00000572 612C            	   430:     bsr     .expand_nibble          ; D2.w = plane1 expansion
02:00000574 E34A            	   431:     lsl.w   #1,D2                   ; ×2 → puts plane1 bits in bit1 of each nibble
02:00000576 8440            	   432:     or.w    D0,D2                   ; combine: each nibble = (p1_bit<<1)|p0_bit
02:00000578 33C200C00000    	   433:     move.w  D2,(VDP_DATA).l         ; write pixels 0-3 (2 VDP bytes via auto-incr)
                            	   434: 
                            	   435:     ; ---- Pixels 4-7 (lower nibbles of D3 and D4) ----
02:0000057E 1203            	   436:     move.b  D3,D1
02:00000580 0201000F        	   437:     andi.b  #$0F,D1                 ; D1.b = lower nibble of plane0 (pix 4-7)
02:00000584 611A            	   438:     bsr     .expand_nibble
02:00000586 3002            	   439:     move.w  D2,D0                   ; save plane0 expansion
                            	   440: 
02:00000588 1204            	   441:     move.b  D4,D1
02:0000058A 0201000F        	   442:     andi.b  #$0F,D1                 ; D1.b = lower nibble of plane1 (pix 4-7)
02:0000058E 6110            	   443:     bsr     .expand_nibble
02:00000590 E34A            	   444:     lsl.w   #1,D2                   ; ×2 for plane1
02:00000592 8440            	   445:     or.w    D0,D2
02:00000594 33C200C00000    	   446:     move.w  D2,(VDP_DATA).l         ; write pixels 4-7
                            	   447: 
02:0000059A 5305            	   448:     subq.b  #1,D5
02:0000059C 6CB8            	   449:     bge.s   .ccu_row                ; loop for all 8 rows
02:0000059E 4E75            	   450:     rts
                            	   451: 
                            	   452:     ;==========================================================================
                            	   453:     ; .expand_nibble — scatter 4-bit nibble to bit-0 of each output nibble.
                            	   454:     ;
                            	   455:     ; Input:  D1.b = 4-bit value n (bits 3..0 = pixels 0..3 of one plane)
                            	   456:     ; Output: D2.w = bit3→pos12, bit2→pos8, bit1→pos4, bit0→pos0
                            	   457:     ;         Represents the plane-0 (or plane-1) contribution to 4 pixels.
                            	   458:     ;         Caller left-shifts by 1 for plane-1 (bit-1 contribution).
                            	   459:     ;
                            	   460:     ; Example: n = 0b1010 (pixels 0,2 set; pixels 1,3 clear)
                            	   461:     ;   output = $1010  ($1000 | $0010)
                            	   462:     ;   Meaning: pixel 0 nibble = 1, pixel 1 = 0, pixel 2 = 1, pixel 3 = 0.
                            	   463:     ;
                            	   464:     ; Uses: D0 (caller's D0 is saved on stack by _ppu_write_7).
                            	   465:     ;==========================================================================
                            	   466: .expand_nibble:
02:000005A0 7400            	   467:     moveq   #0,D2
                            	   468: 
                            	   469:     ; bit 3 of D1 → bit 12 of D2  (shift: 3→12, i.e. ×(4096/8) = ×512 = <<9)
02:000005A2 1001            	   470:     move.b  D1,D0
02:000005A4 02000008        	   471:     andi.b  #$08,D0                 ; isolate bit 3 ($08)
02:000005A8 E148            	   472:     lsl.w   #8,D0                   ; shift 8: $08 → $0800
02:000005AA E348            	   473:     lsl.w   #1,D0                   ; shift 1 more: $0800 → $1000  (bit 12)
02:000005AC 8440            	   474:     or.w    D0,D2
                            	   475: 
                            	   476:     ; bit 2 of D1 → bit 8 of D2  (<<6: $04 → $0100)
02:000005AE 1001            	   477:     move.b  D1,D0
02:000005B0 02000004        	   478:     andi.b  #$04,D0
02:000005B4 ED48            	   479:     lsl.w   #6,D0
02:000005B6 8440            	   480:     or.w    D0,D2
                            	   481: 
                            	   482:     ; bit 1 of D1 → bit 4 of D2  (<<3: $02 → $0010)
02:000005B8 1001            	   483:     move.b  D1,D0
02:000005BA 02000002        	   484:     andi.b  #$02,D0
02:000005BE E748            	   485:     lsl.w   #3,D0
02:000005C0 8440            	   486:     or.w    D0,D2
                            	   487: 
                            	   488:     ; bit 0 of D1 → bit 0 of D2  (no shift: $01 → $0001)
02:000005C2 1001            	   489:     move.b  D1,D0
02:000005C4 02000001        	   490:     andi.b  #$01,D0
02:000005C8 8440            	   491:     or.w    D0,D2
                            	   492: 
02:000005CA 4E75            	   493:     rts
                            	   494: 
                            	   495: ;==============================================================================
