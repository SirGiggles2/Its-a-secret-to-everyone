; dmc_samples.inc - auto-generated by tools/extract_dmc_samples.py
; DO NOT EDIT BY HAND. Regenerate from Legend of Zelda, The (USA).nes.
;
; 7 DMC samples ripped from the stock NES ROM, available in two forms:
;
;   data/dmc_samples.bin     — raw DMC delta-PCM bytes. Kept for a
;                              possible future true-NES-DMC emulation
;                              path. The current Phase-C scaffold does
;                              NOT consume this.
;   data/dmc_samples_pcm.bin — decoded 8-bit unsigned linear PCM,
;                              ready to stream byte-by-byte to YM2612
;                              register $2A (DAC). Each delta byte
;                              expands to 8 PCM bytes.
;
; Each sample's metadata matches the NES $4010/$4012/$4013 values so the
; APU register stubs in nes_io.asm can look them up by 1-based index.

DMC_SAMPLE_COUNT    equ     7

; --- Delta form (raw DMC bytes) ----------------------------------------
DMC_SFX_01_DELTA_OFF equ     $0000
DMC_SFX_01_DELTA_LEN equ     $0751
DMC_SFX_02_DELTA_OFF equ     $0751
DMC_SFX_02_DELTA_LEN equ     $0C01
DMC_SFX_03_DELTA_OFF equ     $1352
DMC_SFX_03_DELTA_LEN equ     $0401
DMC_SFX_04_DELTA_OFF equ     $1753
DMC_SFX_04_DELTA_LEN equ     $00A1
DMC_SFX_05_DELTA_OFF equ     $17F4
DMC_SFX_05_DELTA_LEN equ     $0B01
DMC_SFX_06_DELTA_OFF equ     $22F5
DMC_SFX_06_DELTA_LEN equ     $0901
DMC_SFX_07_DELTA_OFF equ     $2BF6
DMC_SFX_07_DELTA_LEN equ     $0D01

; --- PCM form (decoded, ready for YM reg $2A) --------------------------
DMC_SFX_01_PCM_OFF   equ     $000000
DMC_SFX_01_PCM_LEN   equ     $003A88
DMC_SFX_02_PCM_OFF   equ     $003A88
DMC_SFX_02_PCM_LEN   equ     $006008
DMC_SFX_03_PCM_OFF   equ     $009A90
DMC_SFX_03_PCM_LEN   equ     $002008
DMC_SFX_04_PCM_OFF   equ     $00BA98
DMC_SFX_04_PCM_LEN   equ     $000508
DMC_SFX_05_PCM_OFF   equ     $00BFA0
DMC_SFX_05_PCM_LEN   equ     $005808
DMC_SFX_06_PCM_OFF   equ     $0117A8
DMC_SFX_06_PCM_LEN   equ     $004808
DMC_SFX_07_PCM_OFF   equ     $015FB0
DMC_SFX_07_PCM_LEN   equ     $006808

; --- Shared metadata ---------------------------------------------------
DMC_SFX_01_RATE      equ     $0F   ; $4010 raw
DMC_SFX_01_NESADDR   equ     $C000   ; $4012 -> NES addr
DMC_SFX_02_RATE      equ     $0F   ; $4010 raw
DMC_SFX_02_NESADDR   equ     $D300   ; $4012 -> NES addr
DMC_SFX_03_RATE      equ     $0D   ; $4010 raw
DMC_SFX_03_NESADDR   equ     $E000   ; $4012 -> NES addr
DMC_SFX_04_RATE      equ     $0F   ; $4010 raw
DMC_SFX_04_NESADDR   equ     $C740   ; $4012 -> NES addr
DMC_SFX_05_RATE      equ     $0E   ; $4010 raw
DMC_SFX_05_NESADDR   equ     $C800   ; $4012 -> NES addr
DMC_SFX_06_RATE      equ     $0F   ; $4010 raw
DMC_SFX_06_NESADDR   equ     $CA00   ; $4012 -> NES addr
DMC_SFX_07_RATE      equ     $0E   ; $4010 raw
DMC_SFX_07_NESADDR   equ     $D300   ; $4012 -> NES addr

; --- Parallel lookup tables, 1-based --------------------------------
; Note: DMC_SAMPLE_PCM_OFFS/LENS are long-word because decoded
; samples are up to ~26 KB each (larger than a 16-bit offset).
    even
DMC_SAMPLE_PCM_OFFS:
    dc.l    DMC_SFX_01_PCM_OFF       ; 1
    dc.l    DMC_SFX_02_PCM_OFF       ; 2
    dc.l    DMC_SFX_03_PCM_OFF       ; 3
